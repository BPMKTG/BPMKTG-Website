---
import Layout from '../layouts/Layout.astro';
import BookCall from '../components/BookCall.astro';
import { Image } from 'astro:assets';

import heroBg       from '../assets/images/portfolio/crowd-grimefest.jpg';
import masonPhoto   from '../assets/images/about-us/mason-celum.jpg';
import claytonPhoto from '../assets/images/about-us/clayton-ward.jpg';

const founders = [
  {
    photo: masonPhoto,
    name: 'Mason Celum',
    role: 'Founder & CEO — Strategy, Systems & Client Relations',
    bio: `Mason is a Texas-based EDM photographer, strategist, and the founder of Blueprint Marketing. After years embedded in the bass music scene — shooting headline sets, festival floors, and backstage moments with artists like Martin Garrix, Excision, and Flux Pavilion — he saw the same problem everywhere: incredible artists with no real system behind their growth. Blueprint was built to fix that. Mason leads client strategy, offer development, and the growth systems that power every partnership.`,
  },
  {
    photo: claytonPhoto,
    name: 'Clayton Ward',
    role: 'Co-Founder & CTO — Content, Production & Operations',
    bio: `Clayton is Blueprint's technical architect. He designs and manages the systems, workflows, reporting dashboards, and operational infrastructure that allow Blueprint to deliver consistent, scalable results. While Mason leads on the creative and strategy side, Clayton builds the backend systems that make everything run — turning Blueprint from an agency into a growth machine.`,
  },
];

const principles = [
  { title: 'EDM-native',                body: "We don't import playbooks from other industries. We live in this scene, we shoot these shows, we know these artists." },
  { title: 'Systems, not campaigns',    body: 'Campaigns end. Systems compound. We build the boring, repeatable infrastructure that turns shows and releases into long-term growth.' },
  { title: 'Built on integrity',         body: "Christian values at the core: honesty, integrity, and genuine investment in every artist we work with. We don't take clients we can't help." },
  { title: 'Building toward a platform', body: 'Content, distribution, fan capture, monetization. The full growth stack — built specifically for bass music.' },
];
---
<Layout
  title="About — Blueprint Marketing"
  description="The growth infrastructure behind bass music's next chapter. Built by photographers and editors who live inside the scene."
>
  <!-- ─────────── Hero with photo background ─────────── -->
  <section class="about-hero">
    <div class="hero-bg" data-parallax-bg data-scale-bg data-scale-start="1" data-scale-end="1.18" aria-hidden="true">
      <Image
        src={heroBg}
        alt=""
        width={1920}
        height={1280}
        format="webp"
        quality={82}
        loading="eager"
      />
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="container hero-inner">
      <p class="label" data-reveal="left">About Blueprint</p>
      <h1 data-reveal>
        We're not an agency.<br/>
        <span class="highlight">We're growth infrastructure.</span>
      </h1>
      <p class="hero-tagline" data-reveal>
        We don't just market music — <em>we live and breathe the culture.</em>
      </p>
      <p class="lede" data-reveal>
        Built by photographers and editors who live inside the bass music scene —
        for the artists ready to turn their work into something that compounds.
      </p>
    </div>
  </section>

  <!-- ─────────── Vision / Manifesto ─────────── -->
  <section class="vision bp-texture">
    <div class="vision-glow vision-glow--a" aria-hidden="true"></div>
    <div class="vision-glow vision-glow--b" aria-hidden="true"></div>

    <div class="container vision-inner">
      <p class="label" data-reveal="left">The Vision</p>
      <h2 data-reveal>Where art meets <span class="glow-blue">infrastructure.</span></h2>

      <div class="vision-body">
        <p data-reveal>
          We built Blueprint because the EDM industry was full of agencies running campaigns —
          and no one was building <span class="hl">systems</span>. Artists deserved better.
        </p>
        <p data-reveal>
          We're EDM-native. We don't adapt marketing playbooks from other industries — we live in
          this scene, we shoot these shows, we know these artists. Blueprint exists at the intersection
          of creativity and systems, where art meets infrastructure.
        </p>
        <p data-reveal>
          Our goal is to become the growth infrastructure layer behind the most exciting artists in
          bass music — not just a vendor, but a long-term partner embedded in their career. By 2027,
          we want to be the <span class="hl">first name every mid-level bass artist thinks of</span>
          when they're ready to turn their career into something that compounds.
        </p>
        <p data-reveal>
          How we operate matters as much as what we build. Christian values sit at the core:
          honesty, integrity, and genuine investment in every artist we work with.
          We don't take clients we can't help.
        </p>
      </div>
    </div>
  </section>

  <!-- ─────────── Mission · Vision · Values (brand-exact) ─────────── -->
  <section class="mvv">
    <div class="container">
      <header class="mvv-head">
        <p class="label" data-reveal="left">What We Stand For</p>
        <h2 data-reveal>Mission, vision, values.<br/><span class="glow-blue">In our own words.</span></h2>
      </header>

      <div class="mvv-grid" data-reveal-group>
        <article class="mvv-card mission" data-reveal data-scroll-focus>
          <p class="mvv-eyebrow">Mission</p>
          <p class="mvv-body">
            To empower artists, labels, and music professionals with honest, effective, and
            results-driven marketing that <em>amplifies their vision and elevates their impact</em> —
            growing their audience, reputation, and revenue through creativity, innovation, and integrity.
          </p>
        </article>

        <article class="mvv-card vision" data-reveal data-scroll-focus>
          <p class="mvv-eyebrow">Vision</p>
          <p class="mvv-body">
            To become the most trusted creative partner for artists, labels, and music brands in
            EDM and bass — <em>setting a new standard for values-based marketing</em> in an industry
            built on hype. We want creatives to thrive without compromising who they are.
          </p>
        </article>

        <article class="mvv-card values" data-reveal data-scroll-focus>
          <p class="mvv-eyebrow">Values</p>
          <ul class="mvv-values">
            <li><strong>Honesty</strong> — no inflated metrics, no unrealistic promises, no hidden costs.</li>
            <li><strong>Integrity</strong> — we don't take clients we can't help, and we don't pretend otherwise.</li>
            <li><strong>Service</strong> — your wins are our wins. We work shoulder to shoulder, not over the top.</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ─────────── Founders ─────────── -->
  <section class="founders">
    <div class="container">
      <header class="founders-head">
        <p class="label" data-reveal="left">The Founders</p>
        <h2 data-reveal>The two people<br/>behind the system.</h2>
        <p class="founders-creed" data-reveal>
          <span class="creed-tick" aria-hidden="true"></span>
          <em>Your wins are our wins.</em> Partnership, not delivery queue.
        </p>
      </header>

      <div class="founder-rows">
        {founders.map((f, i) => (
          <article class={`founder-row ${i % 2 === 1 ? 'reversed' : ''}`} data-reveal data-scroll-focus>
            <div class="founder-photo">
              <span class="founder-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="photo-frame">
                <Image
                  src={f.photo}
                  alt={f.name}
                  width={900}
                  height={1200}
                  format="webp"
                  quality={86}
                  loading="lazy"
                />
                <div class="photo-glow" aria-hidden="true"></div>
              </div>
            </div>
            <div class="founder-body">
              <h3>{f.name}</h3>
              <p class="founder-role">{f.role}</p>
              <p class="founder-bio">{f.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────── Principles ─────────── -->
  <section class="principles bp-texture">
    <div class="container">
      <header class="principles-head">
        <p class="label" data-reveal="left">What We Believe</p>
        <h2 data-reveal>Four lines we operate by.</h2>
      </header>

      <div class="principles-grid" data-reveal-group>
        {principles.map((p, i) => (
          <article class="principle" data-reveal data-scroll-focus>
            <span class="principle-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <BookCall />
</Layout>

<style>
  /* ═══════════════════════════════════════════════
     HERO — full-bleed photo with atmospheric overlay
     ═══════════════════════════════════════════════ */
  .about-hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(560px, 80vh, 840px);
    display: flex;
    align-items: center;
    isolation: isolate;
  }
  .hero-bg {
    position: absolute;
    inset: -10% 0;
    z-index: 0;
  }
  .hero-bg :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }
  .hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(180deg, rgba(10,10,15,0.42) 0%, rgba(10,10,15,0.60) 60%, rgba(10,10,15,0.82) 100%),
      radial-gradient(60% 60% at 80% 20%, rgba(38, 79, 160, 0.22), transparent 70%);
  }
  .hero-grid {
    position: absolute; inset: 0; z-index: 1;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(70% 70% at 50% 30%, #000 30%, transparent 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 5rem 1.5rem;
  }
  .about-hero h1 {
    margin: 1rem 0 1.5rem;
    max-width: 20ch;
    text-shadow: 0 4px 30px rgba(0,0,0,0.65);
  }
  .about-hero .hero-tagline {
    color: var(--bp-light);
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.4;
    margin: 0 0 1.25rem;
    max-width: 56ch;
    text-shadow: 0 2px 14px rgba(0,0,0,0.6);
  }
  .about-hero .hero-tagline em {
    color: #fff;
    font-style: normal;
    font-weight: 700;
  }
  .about-hero .lede {
    color: var(--ink);
    opacity: 0.88;
    font-size: 1.15rem;
    max-width: 60ch;
    text-shadow: 0 2px 14px rgba(0,0,0,0.6);
  }

  /* ═══════════════════════════════════════════════
     VISION — atmospheric radial glows + texture
     ═══════════════════════════════════════════════ */
  .vision {
    padding: 6rem 0 7rem;
    position: relative;
    overflow: hidden;
  }
  .vision-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }
  .vision-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }
  .vision-glow--a {
    width: 540px; height: 540px;
    top: -120px; right: -120px;
    background: radial-gradient(circle, rgba(98, 166, 219, 0.18), transparent 70%);
  }
  .vision-glow--b {
    width: 460px; height: 460px;
    bottom: -160px; left: -100px;
    background: radial-gradient(circle, rgba(38, 79, 160, 0.22), transparent 70%);
  }
  .vision h2 {
    margin: 1rem 0 2rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .vision-body { display: flex; flex-direction: column; gap: 1.5rem; }
  .vision-body p {
    color: var(--ink);
    opacity: 0.85;
    font-size: 1.1rem;
    line-height: 1.65;
  }
  .vision-body .hl { color: var(--bp-light); font-weight: 500; }

  /* ═══════════════════════════════════════════════
     MISSION · VISION · VALUES — brand-exact panel
     ═══════════════════════════════════════════════ */
  .mvv { padding: 6rem 0 5rem; position: relative; }
  .mvv-head { max-width: 60ch; margin-bottom: 3rem; }
  .mvv-head h2 { margin-top: 1rem; }
  .mvv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .mvv-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .mvv-card:hover {
    border-color: rgba(98, 166, 219, 0.45);
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -22px rgba(0, 0, 0, 0.6);
  }
  .mvv-card::before {
    content: "";
    position: absolute;
    inset: -1px -1px auto -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bp-blue), transparent);
    opacity: 0.55;
  }
  .mvv-card.values::before { background: linear-gradient(90deg, transparent, var(--bp-orange), transparent); }
  .mvv-eyebrow {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .mvv-card.values .mvv-eyebrow { color: var(--bp-orange); }
  .mvv-body {
    color: var(--ink);
    opacity: 0.88;
    font-size: 1rem;
    line-height: 1.55;
  }
  .mvv-body em { font-style: normal; color: var(--bp-light); font-weight: 600; }
  .mvv-values {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .mvv-values li {
    color: var(--ink);
    opacity: 0.88;
    font-size: 0.95rem;
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }
  .mvv-values li::before {
    content: "";
    position: absolute;
    left: 0; top: 0.55rem;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--bp-orange);
  }
  .mvv-values strong { color: var(--ink); font-weight: 800; font-family: var(--font-display); text-transform: uppercase; letter-spacing: 0.02em; font-size: 0.92rem; margin-right: 0.3rem; }

  @media (max-width: 880px) {
    .mvv-grid { grid-template-columns: 1fr; }
  }

  /* ═══════════════════════════════════════════════
     FOUNDERS — alternating rows, big numbered photos
     ═══════════════════════════════════════════════ */
  .founders {
    padding: 6rem 0;
    position: relative;
  }
  .founders-head { max-width: 60ch; margin-bottom: 4rem; }
  .founders-head h2 { margin-top: 1rem; }
  .founders-creed {
    margin-top: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.55rem 1rem 0.55rem 0.8rem;
    background: rgba(227, 112, 59, 0.08);
    border: 1px solid rgba(227, 112, 59, 0.35);
    border-radius: 999px;
    color: var(--ink);
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .founders-creed em {
    color: var(--bp-orange);
    font-style: normal;
    font-weight: 700;
  }
  .creed-tick {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--bp-orange);
    box-shadow: 0 0 10px rgba(227, 112, 59, 0.7);
    flex-shrink: 0;
  }

  .founder-rows {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }
  .founder-row {
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: 3rem;
    align-items: center;
  }
  .founder-row.reversed .founder-photo { grid-column: 2; }
  .founder-row.reversed .founder-body { grid-column: 1; grid-row: 1; }

  /* Photo column with big numbered overlay */
  .founder-photo {
    position: relative;
    isolation: isolate;
  }
  .founder-num {
    position: absolute;
    top: -2.5rem;
    left: -1rem;
    font-family: var(--font-display);
    font-size: clamp(5rem, 10vw, 9rem);
    font-weight: 900;
    color: rgba(98, 166, 219, 0.18);
    line-height: 1;
    letter-spacing: -0.04em;
    pointer-events: none;
    z-index: 0;
    text-shadow: 0 0 30px rgba(98, 166, 219, 0.12);
  }
  .founder-row.reversed .founder-num {
    left: auto;
    right: -1rem;
  }

  .photo-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 22px;
    background: var(--card);
    border: 1px solid var(--line);
    z-index: 1;
    box-shadow:
      0 30px 80px -30px rgba(0, 0, 0, 0.75),
      0 0 0 1px rgba(98, 166, 219, 0.12);
    transition: border-color 0.4s, transform 0.5s cubic-bezier(.2,.7,.3,1), box-shadow 0.4s;
  }
  .photo-frame :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(.2,.7,.3,1);
  }
  .photo-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(70% 50% at 50% 100%, rgba(98, 166, 219, 0.18), transparent 60%);
    mix-blend-mode: screen;
    opacity: 0;
    transition: opacity 0.5s;
  }
  .founder-row:hover .photo-frame {
    border-color: rgba(98, 166, 219, 0.5);
    transform: translateY(-4px);
    box-shadow:
      0 36px 90px -30px rgba(0, 0, 0, 0.85),
      0 0 0 1px rgba(98, 166, 219, 0.35);
  }
  .founder-row:hover .photo-frame :global(img) { transform: scale(1.04); }
  .founder-row:hover .photo-glow { opacity: 1; }

  /* Body column */
  .founder-body { display: flex; flex-direction: column; gap: 1rem; }
  .founder-row h3 {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .founder-role {
    color: var(--bp-light);
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }
  .founder-bio {
    color: var(--ink);
    opacity: 0.85;
    font-size: 1.02rem;
    line-height: 1.6;
  }

  /* ═══════════════════════════════════════════════
     PRINCIPLES — kept as cards, added texture wrapper
     ═══════════════════════════════════════════════ */
  .principles {
    padding: 6rem 0 5rem;
    position: relative;
  }
  .principles-head { max-width: 60ch; margin-bottom: 3rem; }
  .principles-head h2 { margin-top: 1rem; }
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .principle {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    position: relative;
    overflow: hidden;
  }
  .principle:hover {
    border-color: rgba(98, 166, 219, 0.45);
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -22px rgba(0, 0, 0, 0.6);
  }
  .principle::before {
    content: "";
    position: absolute;
    inset: -1px -1px auto -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bp-blue), transparent);
    opacity: 0.55;
  }
  .principle-num {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
  }
  .principle h3 {
    color: var(--ink);
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: 0.02em;
    line-height: 1.15;
  }
  .principle p { color: var(--muted); font-size: 0.9rem; }

  /* ═══════════════════════════════════════════════
     Responsive
     ═══════════════════════════════════════════════ */
  @media (max-width: 880px) {
    .founder-row,
    .founder-row.reversed {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .founder-row.reversed .founder-photo,
    .founder-row.reversed .founder-body { grid-column: auto; grid-row: auto; }
    .founder-rows { gap: 4.5rem; }
    .founder-num { top: -1.75rem; font-size: 5rem; }
    .principles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .principles-grid { grid-template-columns: 1fr; }
  }
</style>
