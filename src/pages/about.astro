---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About — Blueprint Marketing">
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">About</p>
      <h1>We build growth systems, not campaigns.</h1>
      <p class="lede">
        Blueprint Marketing is a placeholder bio — swap this with your real
        origin story. Why does Blueprint exist? Who do you serve? What's the
        wedge that makes you different from every other agency?
      </p>
      <p class="lede">
        Two or three paragraphs is plenty. Mention the team, your principles,
        and the kind of clients you do your best work with. End with a clear
        call to action.
      </p>
      <a class="button" href="/contact">Work with us
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .narrow { max-width: 760px; }
  .lede { color: var(--bp-muted); font-size: 1.1rem; margin: 1rem 0; }
</style>
