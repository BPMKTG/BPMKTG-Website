---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About — BPMKTG">
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">About</p>
      <h1>We build growth systems, not campaigns.</h1>
      <p>
        This is placeholder copy. Tell your origin story here — why BPMKTG exists,
        who you serve, and the wedge that makes you different. Two or three
        paragraphs is usually plenty.
      </p>
      <p>
        Mention the team, your principles, and a sentence on the kinds of clients
        you do your best work with. End with a clear call to action.
      </p>
      <a class="button" href="/contact">Work with us</a>
    </div>
  </section>
</Layout>

<style>
  .narrow { max-width: 720px; }
</style>
