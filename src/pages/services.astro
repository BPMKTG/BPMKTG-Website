---
import Layout from '../layouts/Layout.astro';
import FeatureGrid from '../components/FeatureGrid.astro';

const services = [
  { title: 'Brand & Positioning', body: 'Narrative, naming, visual identity, and messaging frameworks.' },
  { title: 'Paid Media', body: 'Meta, Google, TikTok, and programmatic — built for ROAS and payback.' },
  { title: 'SEO & Content', body: 'Topical authority, technical SEO, and editorial pipelines.' },
  { title: 'Lifecycle Marketing', body: 'Email, SMS, push, and onboarding flows that drive retention.' },
  { title: 'Creative Production', body: 'Static, motion, and short-form video at iteration speed.' },
  { title: 'Analytics & Attribution', body: 'Server-side tracking, MMM, and clean dashboards.' },
];
---
<Layout title="Services — BPMKTG">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>What we do.</h1>
      <p style="max-width: 60ch;">
        Placeholder service descriptions. Replace these cards with the offers you
        actually sell — or fold them into packages and pricing tiers.
      </p>
    </div>
  </section>
  <FeatureGrid features={services} />
</Layout>
