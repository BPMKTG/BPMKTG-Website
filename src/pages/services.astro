---
import Layout from '../layouts/Layout.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import GetSeenCTA from '../components/GetSeenCTA.astro';
---
<Layout title="Services — Blueprint Marketing">
  <section class="section page-intro">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>What we do.</h1>
      <p class="lede">A full marketing department, on tap. Pick what you need or hire the whole stack.</p>
    </div>
  </section>
  <ServicesGrid />
  <GetSeenCTA />
</Layout>

<style>
  .page-intro { padding-top: 3rem; padding-bottom: 1rem; }
  .lede { color: var(--bp-muted); font-size: 1.1rem; max-width: 60ch; margin-top: 1rem; }
</style>
