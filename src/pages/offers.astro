---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Offers — Blueprint Marketing">
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Offers</p>
      <h1>Packages, coming soon.</h1>
      <p class="lede">
        We're putting the finishing touches on our productized offers — starter,
        growth, and full-service retainers. Drop your details and we'll send
        pricing the day they go live.
      </p>
      <a class="button" href="/contact">Join the waitlist
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  .narrow { max-width: 720px; }
  .lede { color: #4a4a4a; font-size: 1.1rem; margin: 1rem 0 2rem; }
</style>
