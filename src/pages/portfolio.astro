---
import Layout from '../layouts/Layout.astro';
import BookCall from '../components/BookCall.astro';
import { Image } from 'astro:assets';

import heroImg from '../assets/images/portfolio/portfolio-hero-theresistance-grimefest.jpeg';

// Lead the grid with the high-access shots (brief §15)
import fluxDoctorP   from '../assets/images/carousel/carousel-flux-doctorp-rv.jpeg';
import wooliAP       from '../assets/images/carousel/carousel-wooli-alienpark-backstage.jpeg';
import atliens       from '../assets/images/carousel/carousel-atliens-sidestage.jpeg';

// Rest of the carousel shots
import fireworks     from '../assets/images/carousel/carousel-fireworks-dft.jpeg';
import sanpachoSelfie from '../assets/images/carousel/carousel-sanpacho-selfie.jpeg';
import subtronicsRed from '../assets/images/carousel/carousel-subtronics-red.jpeg';
import subLevelUp    from '../assets/images/carousel/carousel-subtronics-levelup.jpeg';
import allTheReason  from '../assets/images/carousel/carousel-allthereason-graffiti.jpeg';
import sanpachoYR    from '../assets/images/carousel/carousel-sanpacho-yellowred.jpeg';
import sanpachoRL    from '../assets/images/carousel/carousel-sanpacho-redlasers.jpeg';
import ahee          from '../assets/images/carousel/carousel-ahee-crowd.jpeg';
import levelUpWide   from '../assets/images/carousel/carousel-levelup-wide.jpeg';
import yookie        from '../assets/images/carousel/carousel-yookie-grimefest.jpeg';
import martinGarrix  from '../assets/images/carousel/carousel-martingarrix-freakyducky.jpeg';
import wooliees      from '../assets/images/carousel/carousel-wooliees-silo.jpeg';

// The additional ~19 unsorted shots from the broader set
const extras = await Promise.all(
  Object.entries(import.meta.glob<{ default: ImageMetadata }>(
    '../assets/images/portfolio/portfolio-*.jpeg',
    { eager: true }
  ))
    .filter(([path]) => !path.includes('portfolio-hero'))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([path, mod]) => ({ path, src: mod.default }))
);

const featured = [
  { src: fluxDoctorP, caption: 'Backstage with Flux Pavilion & Doctor P', tag: 'Backstage' },
  { src: wooliAP,     caption: 'Backstage with Wooli & Alien Park',       tag: 'Backstage · Silo Dallas' },
  { src: atliens,     caption: 'Sidestage with ATLiens — Dancefestopia',  tag: 'Sidestage' },
];

const gallery = [
  { src: subtronicsRed,  caption: 'Subtronics',              tag: 'Dancefestopia' },
  { src: martinGarrix,   caption: 'Martin Garrix',            tag: 'Freaky Deaky' },
  { src: yookie,         caption: 'Yookie',                   tag: 'Grimefest' },
  { src: levelUpWide,    caption: 'Level Up',                 tag: 'Dancefestopia' },
  { src: ahee,           caption: 'AHEE',                     tag: 'Dancefestopia' },
  { src: subLevelUp,     caption: 'Subtronics + Level Up',    tag: 'Sidestage · DFT' },
  { src: sanpachoSelfie, caption: 'San Pacho',                tag: 'Silo Dallas' },
  { src: sanpachoRL,     caption: 'San Pacho',                tag: 'Silo Dallas' },
  { src: sanpachoYR,     caption: 'San Pacho',                tag: 'Silo Dallas' },
  { src: allTheReason,   caption: 'All The Reason',           tag: 'Grimefest' },
  { src: wooliees,       caption: 'Wooli',                    tag: 'Silo Dallas' },
  { src: fireworks,      caption: 'Dancefestopia \'25',       tag: 'Festival' },
];

const extrasMapped = extras.map((e, i) => ({
  src: e.src,
  caption: 'In The Field',
  tag: `Frame ${String(i + 1).padStart(2, '0')}`,
}));

const allTiles = [...gallery, ...extrasMapped];
---
<Layout
  title="Portfolio — Blueprint Marketing"
  description="In The Field: Blueprint Marketing's media access across festivals, headline sets, and backstage with EDM's biggest names."
>
  <section class="portfolio-hero">
    <div class="bg" aria-hidden="true">
      <Image
        src={heroImg}
        alt="The Resistance performing at Grimefest"
        width={1600}
        height={2400}
        format="webp"
        quality={85}
        loading="eager"
      />
      <div class="overlay"></div>
    </div>

    <div class="container hero-inner">
      <p class="label">In The Field</p>
      <h1>We don't just market EDM.<br/><span class="highlight">We live it.</span></h1>
      <p class="lede">
        Credentialed media access across festivals, headline sets, and backstage
        with the artists shaping the scene. The portfolio you're scrolling
        through is the proof.
      </p>
    </div>
  </section>

  <section class="featured-block">
    <div class="container">
      <p class="label">Access</p>
      <h2>Where most cameras don't get to stand.</h2>

      <div class="featured-grid">
        {featured.map(f => (
          <figure class="feat-card">
            <div class="img-wrap">
              <Image
                src={f.src}
                alt={f.caption}
                width={900}
                height={1200}
                format="webp"
                quality={82}
                loading="lazy"
              />
            </div>
            <figcaption>
              <span class="tag">{f.tag}</span>
              <strong>{f.caption}</strong>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="gallery-block">
    <div class="container">
      <header class="gallery-head">
        <p class="label">The Full Set</p>
        <h2>Festival floors, headline sets,<br/><span class="glow-blue">and everything between.</span></h2>
      </header>

      <div class="masonry">
        {allTiles.map(tile => (
          <figure class="tile">
            <div class="img-wrap">
              <Image
                src={tile.src}
                alt={tile.caption}
                width={800}
                height={1000}
                format="webp"
                quality={78}
                loading="lazy"
              />
            </div>
            <figcaption>
              <strong>{tile.caption}</strong>
              <span>{tile.tag}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <BookCall />
</Layout>

<style>
  .portfolio-hero {
    position: relative;
    min-height: clamp(520px, 75vh, 760px);
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .bg { position: absolute; inset: 0; z-index: 0; }
  .bg :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(10,10,15,0.55) 0%, rgba(10,10,15,0.7) 50%, rgba(10,10,15,0.96) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 5rem 1.5rem;
  }
  .hero-inner h1 {
    max-width: 16ch;
    margin-top: 0.75rem;
    text-shadow: 0 4px 30px rgba(0,0,0,0.6);
  }
  .lede {
    margin-top: 1.5rem;
    color: var(--ink);
    opacity: 0.85;
    max-width: 56ch;
    font-size: 1.1rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }

  .featured-block { padding: 5rem 0 2rem; }
  .featured-block h2 { margin-top: 1rem; margin-bottom: 2.5rem; max-width: 22ch; }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .feat-card { margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .feat-card .img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 16px;
    background: var(--card);
    position: relative;
  }
  .feat-card .img-wrap :global(img) { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .feat-card:hover .img-wrap :global(img) { transform: scale(1.04); }
  .feat-card figcaption { padding: 0 0.25rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .feat-card .tag {
    color: var(--bp-blue);
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .feat-card strong {
    color: var(--ink);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 1rem;
  }

  .gallery-block { padding: 4rem 0 6rem; }
  .gallery-head { margin-bottom: 2.5rem; max-width: 60ch; }
  .gallery-head h2 { margin-top: 1rem; }

  .masonry {
    column-count: 4;
    column-gap: 1rem;
  }
  .tile {
    margin: 0 0 1rem;
    display: block;
    break-inside: avoid;
    border-radius: 14px;
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--line);
    position: relative;
    isolation: isolate;
  }
  .tile .img-wrap { width: 100%; line-height: 0; }
  .tile .img-wrap :global(img) { width: 100%; height: auto; display: block; transition: transform 0.4s ease; }
  .tile:hover .img-wrap :global(img) { transform: scale(1.04); }
  .tile figcaption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1.5rem 1rem 0.85rem;
    background: linear-gradient(to top, rgba(10,10,15,0.92), rgba(10,10,15,0) 100%);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 2;
  }
  .tile:hover figcaption { opacity: 1; }
  .tile figcaption strong {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.95rem;
  }
  .tile figcaption span { color: var(--bp-light); font-size: 0.78rem; }

  @media (max-width: 1080px) { .masonry { column-count: 3; } }
  @media (max-width: 760px)  {
    .masonry { column-count: 2; }
    .featured-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px)  { .masonry { column-count: 1; } }
</style>
