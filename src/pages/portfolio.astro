---
import Layout from '../layouts/Layout.astro';
import BookCall from '../components/BookCall.astro';
import { Image, getImage } from 'astro:assets';

// Page hero (kept as a direct import for the eager-loaded background)
import heroImg from '../assets/images/portfolio/portfolio-hero-theresistance-grimefest.jpg';

// Explicit imports for the Access featured row
import mgWickedOaks  from '../assets/images/carousel/carousel-martingarrix-wickedoaks.jpg';
import fluxDoctorP   from '../assets/images/carousel/carousel-flux-doctorp-rv.jpg';
import wooliAP       from '../assets/images/carousel/carousel-wooli-alienpark-backstage.jpg';
import atliens       from '../assets/images/carousel/carousel-atliens-sidestage.jpg';
import subLevelUp    from '../assets/images/carousel/carousel-subtronics-levelup.jpg';

// Glob every image folder — gallery shows everything we've shot
const heroGlob       = import.meta.glob<{ default: ImageMetadata }>('../assets/images/hero/*.jpg',        { eager: true });
const bgGlob         = import.meta.glob<{ default: ImageMetadata }>('../assets/images/backgrounds/*.jpg', { eager: true });
const carouselGlob   = import.meta.glob<{ default: ImageMetadata }>('../assets/images/carousel/*.jpg',    { eager: true });
const portfolioGlob  = import.meta.glob<{ default: ImageMetadata }>('../assets/images/portfolio/*.jpg',   { eager: true });

// Featured Access row — Martin Garrix Wicked Oaks leads, then existing five
const featured = [
  { src: mgWickedOaks, caption: 'Martin Garrix — Wicked Oaks',              tag: 'Headline · Wicked Oaks' },
  { src: fluxDoctorP,  caption: 'Backstage with Flux Pavilion & Doctor P',  tag: 'Backstage' },
  { src: wooliAP,      caption: 'Backstage with Wooli & Alien Park',        tag: 'Backstage · Silo Dallas' },
  { src: atliens,      caption: 'Sidestage with ATLiens — Dancefestopia',   tag: 'Sidestage' },
  { src: subLevelUp,   caption: 'Subtronics + Level Up — Dancefestopia',    tag: 'Sidestage · DFT' },
  { src: heroImg,      caption: 'The Resistance — Grimefest',               tag: 'Headline · Grimefest' },
];

// Build a slug -> ImageMetadata lookup across every folder
const allFolders = { ...heroGlob, ...bgGlob, ...carouselGlob, ...portfolioGlob };
const imageBySlug: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(allFolders)) {
  const slug = path.split('/').pop()!.replace(/\.jpg$/, '');
  imageBySlug[slug] = mod.default;
}

// Explicit gallery order — left to right, top to bottom, like a book.
// Each entry has the file slug, big-text caption (uppercased via CSS),
// and small blue tag. Order and captions per the curated 55-tile spec.
// The duplicate `neotek-silo-onstage` at #21 and #23 is intentional.
const galleryOrder: { slug: string; caption: string; tag: string }[] = [
  { slug: 'hero-4-martingarrix-wickedoaks',             caption: 'Martin Garrix',             tag: 'Wicked Oaks' },
  { slug: 'portfolio-hero-theresistance-grimefest',     caption: 'The Resistance',            tag: 'Grimefest' },
  { slug: 'hero-1-excision-magenta-713',                caption: 'Excision',                  tag: '713 Music Hall - Houston' },
  { slug: 'atliens-dft-sidestage',                      caption: 'ATLiens',                   tag: 'Sidestage - DFT' },
  { slug: 'martingarrix-onstage-pyro',                  caption: 'Martin Garrix',             tag: 'Wicked Oaks' },
  { slug: 'hero-3-grimefest-crowd-lightsaber',          caption: 'The Crowd',                 tag: 'Grimefest' },
  { slug: 'carousel-subtronics-red',                    caption: 'Subtronics',                tag: 'Dancefestopia' },
  { slug: 'hero-2-alienpark-green-silo',                caption: 'Alien Park',                tag: 'Silo - Dallas' },
  { slug: 'bg-1-svddendeath-red-wickedoaks',            caption: 'Svdden Death - Voyd',       tag: 'Wicked Oaks' },
  { slug: 'svddendeath-productionteam-screaming',       caption: 'Svdden Death Production',   tag: 'FOH - Wicked Oaks' },
  { slug: 'wankdat-wooli-crankdat-dancefestopia',       caption: 'Wankdat - Wooli + Crankdat',tag: 'Dancefestopia' },
  { slug: 'carousel-fireworks-dft',                     caption: 'Level Up',                  tag: 'Dancefestopia' },
  { slug: 'carousel-sanpacho-redlasers',                caption: 'San Pacho',                 tag: 'Silo - Dallas' },
  { slug: 'carousel-ahee-crowd',                        caption: 'AHEE',                      tag: 'Dancefestopia' },
  { slug: 'carousel-allthereason-graffiti',             caption: 'All The Reason',            tag: 'Vulcan Gas Co.' },
  { slug: 'carousel-levelup-wide',                      caption: 'Level Up',                  tag: 'Dancefestopia' },
  { slug: 'carousel-wooliees-silo',                     caption: 'Wooli',                     tag: 'Silo - Dallas' },
  { slug: 'carousel-sanpacho-selfie',                   caption: 'San Pacho',                 tag: 'Silo - Dallas' },
  { slug: 'yookie-grimefest-bassface',                  caption: 'Yookie',                    tag: 'Grimefest' },
  { slug: 'blankface-b2b-sqishi-grimefest',             caption: 'Blankface B2B Sqishi',      tag: 'Grimefest' },
  { slug: 'neotek-silo-onstage',                        caption: 'Neotek',                    tag: 'Silo - Dallas' },
  { slug: 'martingarrix-wickedoaks-festivalstage-pyro', caption: 'Martin Garrix',             tag: 'Wicked Oaks' },
  { slug: 'neotek-silo-onstage',                        caption: 'Neotek',                    tag: 'Silo - Dallas' },
  { slug: 'svddendeath-productionteam-foh',             caption: 'Svdden Death Production',   tag: 'Wicked Oaks' },
  { slug: 'subtronics-dancefestopia',                   caption: 'Subtronics',                tag: 'Dancefestopia' },
  { slug: 'laurenmia-fluffycloud-silo',                 caption: 'Lauren Mia X Fluffy Cloud', tag: 'Silo - Dallas' },
  { slug: 'carousel-yookie-grimefest',                  caption: 'Yookie',                    tag: 'Grimefest' },
  { slug: 'carousel-sanpacho-yellowred',                caption: 'San Pacho',                 tag: 'Silo Dallas' },
  { slug: 'rzrkt-drinkurwater-vulcangasco',             caption: 'Rzrkt X Drinkurwater',      tag: 'Vulcan Gas Co.' },
  { slug: 'bg-2-perrywayne-purple-dft',                 caption: 'Perry Wayne',               tag: 'Dancefestopia' },
  { slug: 'automhate-grimefest',                        caption: 'Automhate',                 tag: 'Grimefest' },
  { slug: 'alienpark-dft',                              caption: 'Alien Park',                tag: 'Dancefestopia' },
  { slug: 'ognixin-grimefest',                          caption: 'OG Nixin',                  tag: 'Grimefest' },
  { slug: 'sqishi-grimefest-beer',                      caption: 'Sqishi',                    tag: 'Grimefest' },
  { slug: 'adventureclub-silo',                         caption: 'Adventure Club',            tag: 'Silo - Dallas' },
  { slug: 'izzyvadim-grimefest-wideangle',              caption: 'Izzy Vadim',                tag: 'Grimefest' },
  { slug: 'ahee-dft',                                   caption: 'AHEE',                      tag: 'Dancefestopia' },
  { slug: 'carousel-martingarrix-freakyducky',          caption: 'Martin Garrix',             tag: 'Wicked Oaks' },
  { slug: 'izyyvadim-grimefest-smoking',                caption: 'Izzy Vadim',                tag: 'Grimefest' },
  { slug: 'svddendeath-wickedoaks',                     caption: 'Svdden Death - Voyd',       tag: 'Wicked Oaks' },
  { slug: 'spira-toatsatx',                             caption: 'Spira',                     tag: 'Toats - Austin' },
  { slug: 'blankface-b2b-sqishi-surprised-grimefest',   caption: 'Blankface B2B Sqishi',      tag: 'Grimefest' },
  { slug: 'neotek-silo',                                caption: 'Neotek',                    tag: 'Silo - Dallas' },
  { slug: 'ahee-managment-dft-backstage',               caption: 'AHEE Management',           tag: 'Backstage - DFT' },
  { slug: 'blankface-b2b-sqishi-grimefest-blue',        caption: 'Blankface B2B Sqishi',      tag: 'Grimefest' },
  { slug: 'crowd-alienpark-dft',                        caption: 'The Crowd - Alien Park',    tag: 'Dancefestopia' },
  { slug: 'crowd-grimefest',                            caption: 'The Crowd',                 tag: 'Grimefest' },
  { slug: 'dancefestopia',                              caption: 'Emerald Stage',             tag: 'Dancefestopia' },
  { slug: 'svddendeath-productionteam-lasers-pyro',     caption: 'Svdden Death Production',   tag: 'FOH - Wicked Oaks' },
  { slug: 'alienpark-silo',                             caption: 'Alien Park',                tag: 'Silo - Dallas' },
  { slug: 'allthereason-vulcangasco',                   caption: 'All The Reason',            tag: 'Vulcan Gas Co.' },
  { slug: 'blankface-b2b-sqishi-grimefest-wide',        caption: 'Grimefest',                 tag: 'The Galactic Wars II' },
  { slug: 'sanpacho-silo',                              caption: 'San Pacho',                 tag: 'Silo - Dallas' },
  { slug: 'laurenmia-fluffycloud-silo-red',             caption: 'Lauren Mia X Fluffy Cloud', tag: 'Silo - Dallas' },
  { slug: 'legendofshellda-toatsatx',                   caption: 'Legend of Shellda',         tag: 'Toats - Austin' },
];

const allTiles = galleryOrder
  .filter(item => imageBySlug[item.slug])
  .map(item => ({
    src: imageBySlug[item.slug],
    slug: item.slug,
    caption: item.caption,
    tag: item.tag,
  }));

// Generate larger variants for the lightbox
const lightboxOf = async (src: ImageMetadata) =>
  (await getImage({ src, width: 1800, format: 'webp', quality: 86 })).src;

const orientationOf = (src: ImageMetadata) => (src.width >= src.height ? 'h' : 'v');

const featuredLB = await Promise.all(
  featured.map(async f => ({ ...f, full: await lightboxOf(f.src) }))
);
const tilesLBRaw = await Promise.all(
  allTiles.map(async t => ({
    ...t,
    full: await lightboxOf(t.src),
    orient: orientationOf(t.src),
  }))
);

// Preserve the explicit user-defined order — no shuffling
const tilesLB = tilesLBRaw;
---
<Layout
  title="Portfolio — Blueprint Marketing"
  description="In The Field: Blueprint Marketing's media access across festivals, headline sets, and backstage with EDM's biggest names."
>
  <section class="portfolio-hero">
    <div class="bg" aria-hidden="true">
      <Image
        src={heroImg}
        alt="The Resistance performing at Grimefest"
        width={1600}
        height={2400}
        format="webp"
        quality={85}
        loading="eager"
      />
      <div class="overlay"></div>
    </div>

    <div class="container hero-inner">
      <p class="label" data-reveal="left">In The Field</p>
      <h1 data-reveal>We don't just market EDM.<br/><span class="highlight">We live it.</span></h1>
      <p class="lede" data-reveal>
        Credentialed media access across festivals, headline sets, and backstage
        with the artists shaping the scene. The portfolio you're scrolling
        through is the proof.
      </p>
    </div>
  </section>

  <section class="featured-block">
    <div class="container">
      <p class="label" data-reveal="left">Access</p>
      <h2 data-reveal>Where most cameras don't get to stand.</h2>

      <div class="featured-grid" data-reveal-group>
        {featuredLB.map(f => (
          <button
            class="feat-card"
            type="button"
            data-lightbox-open
            data-tilt
            data-reveal
            data-full={f.full}
            data-caption={f.caption}
            aria-label={`Open larger view: ${f.caption}`}
          >
            <span class="img-wrap">
              <Image
                src={f.src}
                alt={f.caption}
                width={900}
                height={1200}
                format="webp"
                quality={82}
                loading="lazy"
              />
              <span class="hover-meta">
                <span class="tag">{f.tag}</span>
                <strong>{f.caption}</strong>
              </span>
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="gallery-block">
    <div class="container">
      <header class="gallery-head">
        <p class="label" data-reveal="left">The Full Set</p>
        <h2 data-reveal>Festival floors, headline sets,<br/><span class="glow-blue">and everything between.</span></h2>
      </header>

      <div class="masonry" data-reveal-group>
        {tilesLB.map(tile => (
          <button
            class="tile"
            type="button"
            data-lightbox-open
            data-reveal
            data-orientation={tile.orient}
            data-full={tile.full}
            data-caption={`${tile.caption} — ${tile.tag}`}
            aria-label={`Open larger view: ${tile.caption}`}
          >
            <span class="img-wrap">
              <Image
                src={tile.src}
                alt={tile.caption}
                width={800}
                height={1000}
                format="webp"
                quality={78}
                loading="lazy"
              />
            </span>
            <span class="caption">
              <strong>{tile.caption}</strong>
              <span>{tile.tag}</span>
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox overlay -->
  <dialog class="lightbox" data-lightbox>
    <button type="button" class="lightbox-close" data-lightbox-close aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <figure>
      <img alt="" data-lightbox-img />
      <figcaption data-lightbox-caption></figcaption>
    </figure>
  </dialog>

  <script>
    const dialog = document.querySelector<HTMLDialogElement>('[data-lightbox]');
    const img = dialog?.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const cap = dialog?.querySelector<HTMLElement>('[data-lightbox-caption]');

    const openers = document.querySelectorAll<HTMLElement>('[data-lightbox-open]');

    const open = (full: string, caption: string) => {
      if (!dialog || !img || !cap) return;
      img.src = full;
      img.alt = caption;
      cap.textContent = caption;
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
      document.body.style.overflow = 'hidden';
      // Move custom cursor into the dialog so it renders in the top layer
      const cursor = document.querySelector<HTMLElement>('.bp-cursor');
      if (cursor) dialog.appendChild(cursor);
    };
    const close = () => {
      if (!dialog) return;
      // Move custom cursor back to body before closing
      const cursor = document.querySelector<HTMLElement>('.bp-cursor');
      if (cursor) document.body.appendChild(cursor);
      if (typeof dialog.close === 'function') dialog.close();
      else dialog.removeAttribute('open');
      document.body.style.overflow = '';
      if (img) img.removeAttribute('src');
    };

    openers.forEach(btn => btn.addEventListener('click', () => {
      open(btn.dataset.full || '', btn.dataset.caption || '');
    }));

    dialog?.querySelector('[data-lightbox-close]')?.addEventListener('click', close);
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });
    dialog?.addEventListener('cancel', (e) => { e.preventDefault(); close(); });
  </script>

  <BookCall />
</Layout>

<style>
  .portfolio-hero {
    position: relative;
    min-height: clamp(520px, 75vh, 760px);
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .bg { position: absolute; inset: 0; z-index: 0; }
  .bg :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(10,10,15,0.45) 0%, rgba(10,10,15,0.6) 50%, rgba(10,10,15,0.94) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 5rem 1.5rem;
  }
  .hero-inner h1 {
    max-width: 16ch;
    margin-top: 0.75rem;
    text-shadow: 0 4px 30px rgba(0,0,0,0.6);
  }
  .lede {
    margin-top: 1.5rem;
    color: var(--ink);
    opacity: 0.85;
    max-width: 56ch;
    font-size: 1.1rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }

  .featured-block { padding: 5rem 0 2rem; }
  .featured-block h2 { margin-top: 1rem; margin-bottom: 2.5rem; max-width: 22ch; }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
  }
  .feat-card {
    margin: 0;
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .feat-card .img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 16px;
    background: var(--card);
    position: relative;
    display: block;
  }
  .feat-card .img-wrap :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .feat-card:hover .img-wrap :global(img),
  .feat-card:focus-visible .img-wrap :global(img) { transform: scale(1.05); }

  /* Hover caption: slides up from bottom of the photo */
  .feat-card .hover-meta {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 2.2rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: linear-gradient(to top, rgba(10,10,15,0.94), rgba(10,10,15,0) 100%);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s cubic-bezier(.2,.7,.3,1),
                transform 0.4s cubic-bezier(.2,.7,.3,1);
    pointer-events: none;
    z-index: 4; /* above the tilt light-leak overlay */
  }
  .feat-card:hover .hover-meta,
  .feat-card:focus-visible .hover-meta {
    opacity: 1;
    transform: translateY(0);
  }
  .feat-card .hover-meta .tag {
    color: var(--bp-blue);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .feat-card .hover-meta strong {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .gallery-block { padding: 4rem 0 6rem; }
  .gallery-head { margin-bottom: 2.5rem; max-width: 60ch; }
  .gallery-head h2 { margin-top: 1rem; }
  .gallery-sub { color: var(--muted); margin-top: 0.85rem; font-size: 0.95rem; }

  /* Row-span grid: H tiles span 3 rows (square at col width), V tiles span
     4 rows (~1:1.35 portrait). Row-major auto-flow places items in source
     order into the next available cell — so the visual order is roughly
     the source order, with minor row-fill adjustments around tall V tiles.
     This packs the grid tightly with no empty rows underneath.

     --masonry-w = .container's content box width = min(viewport, max-width)
     minus the .container's 3rem horizontal padding. The grid-auto-rows
     calc is what makes H tiles render as exact squares at the column
     width regardless of viewport. */
  .masonry {
    --masonry-w: calc(min(100vw, var(--max-width)) - 3rem);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: calc((var(--masonry-w) - 11rem) / 12);
    gap: 1rem;
  }
  .tile {
    margin: 0;
    display: block;
    grid-row: span 3; /* H tiles = 3 rows = square */
    border-radius: 14px;
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--line);
    position: relative;
    isolation: isolate;
    width: 100%;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .tile[data-orientation="v"] { grid-row: span 4; /* V tiles = 4 rows = ~1:1.35 portrait */ }
  .tile:hover, .tile:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(98, 166, 219, 0.45);
    box-shadow: 0 24px 50px -25px rgba(0,0,0,0.7);
  }
  .tile .img-wrap {
    width: 100%;
    height: 100%;
    line-height: 0;
    display: block;
    overflow: hidden;
  }
  .tile .img-wrap :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .tile:hover .img-wrap :global(img),
  .tile:focus-visible .img-wrap :global(img) { transform: scale(1.05); }
  .tile .caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 2rem 1rem 0.95rem;
    background: linear-gradient(to top, rgba(10,10,15,0.94), rgba(10,10,15,0) 100%);
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.35s cubic-bezier(.2,.7,.3,1),
                transform 0.35s cubic-bezier(.2,.7,.3,1);
    z-index: 2;
    pointer-events: none;
  }
  .tile:hover .caption, .tile:focus-visible .caption {
    opacity: 1;
    transform: translateY(0);
  }
  .tile .caption strong {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.95rem;
    font-weight: 700;
  }
  .tile .caption span { color: var(--bp-light); font-size: 0.78rem; }

  /* ───────── Lightbox ───────── */
  .lightbox {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    color: #fff;
    overflow: visible;
  }
  .lightbox::backdrop {
    background: rgba(5, 6, 12, 0.92);
    backdrop-filter: blur(14px);
  }
  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: lbFade 0.25s ease;
  }
  @keyframes lbFade { from { opacity: 0; } to { opacity: 1; } }

  .lightbox figure {
    margin: 0;
    max-width: min(94vw, 1600px);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    pointer-events: none;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 78vh;
    height: auto;
    width: auto;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.8), 0 0 0 1px rgba(98, 166, 219, 0.15);
    pointer-events: auto;
  }
  .lightbox figcaption {
    color: var(--bp-light);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
    text-align: center;
    pointer-events: auto;
  }
  .lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    background: rgba(15, 17, 25, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    z-index: 10;
  }
  .lightbox-close:hover {
    background: var(--bp-orange);
    border-color: var(--bp-orange);
    transform: scale(1.05);
  }

  /* Each breakpoint recalcs grid-auto-rows so H tiles stay square at the
     current column width. Formula: (masonry-w - (cols-1)*4 rem) / (cols*3),
     since H spans 3 rows. */
  @media (max-width: 1080px) {
    .masonry {
      grid-template-columns: repeat(3, 1fr);
