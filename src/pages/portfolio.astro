---
import Layout from '../layouts/Layout.astro';
import BookCall from '../components/BookCall.astro';
import { Image, getImage } from 'astro:assets';

import heroImg from '../assets/images/portfolio/portfolio-hero-theresistance-grimefest.jpeg';

// Lead the grid with the high-access shots (brief §15)
import fluxDoctorP   from '../assets/images/carousel/carousel-flux-doctorp-rv.jpeg';
import wooliAP       from '../assets/images/carousel/carousel-wooli-alienpark-backstage.jpeg';
import atliens       from '../assets/images/carousel/carousel-atliens-sidestage.jpeg';
import subLevelUp    from '../assets/images/carousel/carousel-subtronics-levelup.jpeg';

// Rest of the carousel shots
import fireworks     from '../assets/images/carousel/carousel-fireworks-dft.jpeg';
import sanpachoSelfie from '../assets/images/carousel/carousel-sanpacho-selfie.jpeg';
import subtronicsRed from '../assets/images/carousel/carousel-subtronics-red.jpeg';
import allTheReason  from '../assets/images/carousel/carousel-allthereason-graffiti.jpeg';
import sanpachoYR    from '../assets/images/carousel/carousel-sanpacho-yellowred.jpeg';
import sanpachoRL    from '../assets/images/carousel/carousel-sanpacho-redlasers.jpeg';
import ahee          from '../assets/images/carousel/carousel-ahee-crowd.jpeg';
import levelUpWide   from '../assets/images/carousel/carousel-levelup-wide.jpeg';
import yookie        from '../assets/images/carousel/carousel-yookie-grimefest.jpeg';
import martinGarrix  from '../assets/images/carousel/carousel-martingarrix-freakyducky.jpeg';
import wooliees      from '../assets/images/carousel/carousel-wooliees-silo.jpeg';

// The additional ~19 unsorted shots from the broader set
const extras = Object.entries(import.meta.glob<{ default: ImageMetadata }>(
    '../assets/images/portfolio/portfolio-*.jpeg',
    { eager: true }
  ))
    .filter(([path]) => !path.includes('portfolio-hero'))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([path, mod]) => ({ path, src: mod.default }));

const featured = [
  { src: fluxDoctorP, caption: 'Backstage with Flux Pavilion & Doctor P',  tag: 'Backstage' },
  { src: wooliAP,     caption: 'Backstage with Wooli & Alien Park',        tag: 'Backstage · Silo Dallas' },
  { src: atliens,     caption: 'Sidestage with ATLiens — Dancefestopia',   tag: 'Sidestage' },
  { src: subLevelUp,  caption: 'Subtronics + Level Up — Dancefestopia',    tag: 'Sidestage · DFT' },
  { src: heroImg,     caption: 'The Resistance — Grimefest',               tag: 'Headline · Grimefest' },
];

const gallery = [
  { src: subtronicsRed,  caption: 'Subtronics',              tag: 'Dancefestopia' },
  { src: martinGarrix,   caption: 'Martin Garrix',            tag: 'Freaky Deaky' },
  { src: yookie,         caption: 'Yookie',                   tag: 'Grimefest' },
  { src: levelUpWide,    caption: 'Level Up',                 tag: 'Dancefestopia' },
  { src: ahee,           caption: 'AHEE',                     tag: 'Dancefestopia' },
  { src: sanpachoSelfie, caption: 'San Pacho',                tag: 'Silo Dallas' },
  { src: sanpachoRL,     caption: 'San Pacho',                tag: 'Silo Dallas' },
  { src: sanpachoYR,     caption: 'San Pacho',                tag: 'Silo Dallas' },
  { src: allTheReason,   caption: 'All The Reason',           tag: 'Grimefest' },
  { src: wooliees,       caption: 'Wooli',                    tag: 'Silo Dallas' },
  { src: fireworks,      caption: 'Dancefestopia \'25',       tag: 'Festival' },
];

const extrasMapped = extras.map((e, i) => ({
  src: e.src,
  caption: 'In The Field',
  tag: `Frame ${String(i + 1).padStart(2, '0')}`,
}));

const allTiles = [...gallery, ...extrasMapped];

// Generate larger variants for the lightbox
const lightboxOf = async (src: ImageMetadata) =>
  (await getImage({ src, width: 1800, format: 'webp', quality: 86 })).src;

const featuredLB = await Promise.all(
  featured.map(async f => ({ ...f, full: await lightboxOf(f.src) }))
);
const tilesLB = await Promise.all(
  allTiles.map(async t => ({ ...t, full: await lightboxOf(t.src) }))
);
---
<Layout
  title="Portfolio — Blueprint Marketing"
  description="In The Field: Blueprint Marketing's media access across festivals, headline sets, and backstage with EDM's biggest names."
>
  <section class="portfolio-hero">
    <div class="bg" aria-hidden="true">
      <Image
        src={heroImg}
        alt="The Resistance performing at Grimefest"
        width={1600}
        height={2400}
        format="webp"
        quality={85}
        loading="eager"
      />
      <div class="overlay"></div>
    </div>

    <div class="container hero-inner">
      <p class="label">In The Field</p>
      <h1>We don't just market EDM.<br/><span class="highlight">We live it.</span></h1>
      <p class="lede">
        Credentialed media access across festivals, headline sets, and backstage
        with the artists shaping the scene. The portfolio you're scrolling
        through is the proof.
      </p>
    </div>
  </section>

  <section class="featured-block">
    <div class="container">
      <p class="label">Access</p>
      <h2>Where most cameras don't get to stand.</h2>

      <div class="featured-grid">
        {featuredLB.map(f => (
          <button
            class="feat-card"
            type="button"
            data-lightbox-open
            data-full={f.full}
            data-caption={f.caption}
            aria-label={`Open larger view: ${f.caption}`}
          >
            <span class="img-wrap">
              <Image
                src={f.src}
                alt={f.caption}
                width={900}
                height={1200}
                format="webp"
                quality={82}
                loading="lazy"
              />
            </span>
            <span class="meta">
              <span class="tag">{f.tag}</span>
              <strong>{f.caption}</strong>
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="gallery-block">
    <div class="container">
      <header class="gallery-head">
        <p class="label">The Full Set</p>
        <h2>Festival floors, headline sets,<br/><span class="glow-blue">and everything between.</span></h2>
      </header>

      <div class="masonry">
        {tilesLB.map(tile => (
          <button
            class="tile"
            type="button"
            data-lightbox-open
            data-full={tile.full}
            data-caption={`${tile.caption} — ${tile.tag}`}
            aria-label={`Open larger view: ${tile.caption}`}
          >
            <span class="img-wrap">
              <Image
                src={tile.src}
                alt={tile.caption}
                width={800}
                height={1000}
                format="webp"
                quality={78}
                loading="lazy"
              />
            </span>
            <span class="caption">
              <strong>{tile.caption}</strong>
              <span>{tile.tag}</span>
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox overlay -->
  <dialog class="lightbox" data-lightbox>
    <button type="button" class="lightbox-close" data-lightbox-close aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <figure>
      <img alt="" data-lightbox-img />
      <figcaption data-lightbox-caption></figcaption>
    </figure>
  </dialog>

  <script>
    const dialog = document.querySelector<HTMLDialogElement>('[data-lightbox]');
    const img = dialog?.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const cap = dialog?.querySelector<HTMLElement>('[data-lightbox-caption]');

    const openers = document.querySelectorAll<HTMLElement>('[data-lightbox-open]');

    const open = (full: string, caption: string) => {
      if (!dialog || !img || !cap) return;
      img.src = full;
      img.alt = caption;
      cap.textContent = caption;
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      if (!dialog) return;
      if (typeof dialog.close === 'function') dialog.close();
      else dialog.removeAttribute('open');
      document.body.style.overflow = '';
      if (img) img.removeAttribute('src');
    };

    openers.forEach(btn => btn.addEventListener('click', () => {
      open(btn.dataset.full || '', btn.dataset.caption || '');
    }));

    dialog?.querySelector('[data-lightbox-close]')?.addEventListener('click', close);
    dialog?.addEventListener('click', (e) => {
      // backdrop click — close only if the click landed on the dialog itself, not its children
      if (e.target === dialog) close();
    });
    dialog?.addEventListener('cancel', (e) => { e.preventDefault(); close(); });
  </script>

  <BookCall />
</Layout>

<style>
  .portfolio-hero {
    position: relative;
    min-height: clamp(520px, 75vh, 760px);
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .bg { position: absolute; inset: 0; z-index: 0; }
  .bg :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .overlay {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(10,10,15,0.45) 0%, rgba(10,10,15,0.6) 50%, rgba(10,10,15,0.94) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 5rem 1.5rem;
  }
  .hero-inner h1 {
    max-width: 16ch;
    margin-top: 0.75rem;
    text-shadow: 0 4px 30px rgba(0,0,0,0.6);
  }
  .lede {
    margin-top: 1.5rem;
    color: var(--ink);
    opacity: 0.85;
    max-width: 56ch;
    font-size: 1.1rem;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }

  .featured-block { padding: 5rem 0 2rem; }
  .featured-block h2 { margin-top: 1rem; margin-bottom: 2.5rem; max-width: 22ch; }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }
  .feat-card {
    margin: 0;
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .feat-card .img-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 16px;
    background: var(--card);
    position: relative;
    display: block;
  }
  .feat-card .img-wrap :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .feat-card:hover .img-wrap :global(img),
  .feat-card:focus-visible .img-wrap :global(img) { transform: scale(1.05); }
  .feat-card .meta { padding: 0 0.25rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .feat-card .tag {
    color: var(--bp-blue);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .feat-card strong {
    color: var(--ink);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .gallery-block { padding: 4rem 0 6rem; }
  .gallery-head { margin-bottom: 2.5rem; max-width: 60ch; }
  .gallery-head h2 { margin-top: 1rem; }

  .masonry {
    column-count: 4;
    column-gap: 1rem;
  }
  .tile {
    margin: 0 0 1rem;
    display: block;
    break-inside: avoid;
    border-radius: 14px;
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--line);
    position: relative;
    isolation: isolate;
    width: 100%;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .tile:hover, .tile:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(98, 166, 219, 0.45);
    box-shadow: 0 24px 50px -25px rgba(0,0,0,0.7);
  }
  .tile .img-wrap { width: 100%; line-height: 0; display: block; }
  .tile .img-wrap :global(img) { width: 100%; height: auto; display: block; transition: transform 0.5s ease; }
  .tile:hover .img-wrap :global(img),
  .tile:focus-visible .img-wrap :global(img) { transform: scale(1.05); }
  .tile .caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1.5rem 1rem 0.85rem;
    background: linear-gradient(to top, rgba(10,10,15,0.92), rgba(10,10,15,0) 100%);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 2;
    pointer-events: none;
  }
  .tile:hover .caption, .tile:focus-visible .caption { opacity: 1; }
  .tile .caption strong {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.95rem;
    font-weight: 700;
  }
  .tile .caption span { color: var(--bp-light); font-size: 0.78rem; }

  /* ───────── Lightbox ───────── */
  .lightbox {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    color: #fff;
    overflow: visible;
  }
  .lightbox::backdrop {
    background: rgba(5, 6, 12, 0.92);
    backdrop-filter: blur(14px);
  }
  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: lbFade 0.25s ease;
  }
  @keyframes lbFade { from { opacity: 0; } to { opacity: 1; } }

  .lightbox figure {
    margin: 0;
    max-width: min(94vw, 1600px);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    pointer-events: none; /* clicks inside fall to image/caption, not backdrop */
  }
  .lightbox img {
    max-width: 100%;
    max-height: 78vh;
    height: auto;
    width: auto;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.8), 0 0 0 1px rgba(98, 166, 219, 0.15);
    pointer-events: auto;
  }
  .lightbox figcaption {
    color: var(--bp-light);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
    text-align: center;
    pointer-events: auto;
  }
  .lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    background: rgba(15, 17, 25, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    z-index: 10;
  }
  .lightbox-close:hover {
    background: var(--bp-orange);
    border-color: var(--bp-orange);
    transform: scale(1.05);
  }

  @media (max-width: 1080px) {
    .masonry { column-count: 3; }
    .featured-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 760px) {
    .masonry { column-count: 2; }
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px)  {
    .masonry { column-count: 1; }
    .featured-grid { grid-template-columns: 1fr; }
  }
</style>
