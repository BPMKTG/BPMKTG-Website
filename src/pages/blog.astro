---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Blog — Blueprint Marketing">
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow">Blog</p>
      <h1>Field notes.</h1>
      <p class="lede">
        Long-form on positioning, paid media playbooks, and what's actually
        working in 2026. First posts ship soon.
      </p>
    </div>
  </section>
</Layout>

<style>
  .narrow { max-width: 720px; }
  .lede { color: var(--bp-muted); font-size: 1.1rem; margin-top: 1rem; }
</style>
