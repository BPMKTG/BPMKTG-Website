---
import TierPage from '../../components/tiers/TierPage.astro';
import { tiers } from '../../data/tiers';

// Routes every entry in src/data/tiers.ts. Adding a new tier =
// adding it to the tiers map and it auto-routes. No image asset
// required — the hero is fully CSS/SVG HUD.
export async function getStaticPaths() {
  return Object.values(tiers).map(tier => ({
    params: { slug: tier.slug },
    props: { tier },
  }));
}

const { tier } = Astro.props;
---
<TierPage tier={tier} />
