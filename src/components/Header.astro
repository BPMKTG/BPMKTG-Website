---
const navItems = [
  { href: '/#process',     label: 'How It Works' },
  { href: '/#offers',      label: 'Offers' },
  { href: '/#why',         label: 'Why Blueprint' },
  { href: '/portfolio',    label: 'In The Field' },
  { href: '/blog',         label: 'Blog' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Blueprint Marketing home">
      <img src="/brand/logo-white.svg" alt="Blueprint Marketing" />
    </a>

    <nav class="nav-pill" aria-label="Primary">
      <ul>
        {navItems.map(item => (
          <li>
            <a href={item.href} class:list={[{ active: path === item.href }]}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="#book" class="cta-link button">
      Book a Call
      <span class="arrow" aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 10, 15, 0.7);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 1.5rem;
  }
  .brand img { height: 36px; width: auto; }

  .nav-pill {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.35rem 0.45rem;
  }
  .nav-pill ul {
    list-style: none;
    display: flex;
    gap: 0.15rem;
    margin: 0; padding: 0;
  }
  .nav-pill a {
    display: inline-block;
    padding: 0.55rem 1rem;
    color: var(--ink);
    opacity: 0.78;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 999px;
    transition: background 0.15s, opacity 0.15s, color 0.15s;
  }
  .nav-pill a:hover { opacity: 1; background: rgba(255,255,255,0.06); }
  .nav-pill a.active { background: rgba(98, 166, 219, 0.18); color: var(--bp-light); opacity: 1; }

  .cta-link { padding: 0.65rem 1.1rem; font-size: 0.78rem; }

  @media (max-width: 980px) { .nav-pill { display: none; } }
  @media (max-width: 520px) { .cta-link { display: none; } }
</style>
