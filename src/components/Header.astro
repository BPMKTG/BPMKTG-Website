---
const navItems = [
  { href: '/services', label: 'Our Services' },
  { href: '/offers', label: 'Offers' },
  { href: '/work', label: 'Our Work' },
  { href: '/about', label: 'About Us' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Blueprint Marketing home">
      <img src="/brand/logo-full.svg" alt="Blueprint Marketing" />
    </a>

    <nav aria-label="Primary">
      <ul>
        {navItems.map(item => (
          <li>
            <a href={item.href} class:list={[{ active: path === item.href }]}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--bp-bg);
    border-bottom: 1px solid rgba(38, 79, 160, 0.08);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem 1.5rem;
  }
  .brand img { height: 38px; width: auto; }

  nav ul {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--bp-ink);
    font-size: 0.92rem;
    font-weight: 500;
    padding: 0.4rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  nav a:hover { color: var(--bp-deep); }
  nav a.active { color: var(--bp-deep); border-bottom-color: var(--bp-orange); }

  @media (max-width: 900px) { nav { display: none; } }
</style>
