---
const clients = [
  { name: 'Ava R.',   role: 'Boutique Owner', hue: 140 },
  { name: 'Marcus T.', role: 'Restaurant Group', hue: 18 },
  { name: 'Priya S.',  role: 'SaaS Founder', hue: 220 },
  { name: 'Devon W.',  role: 'Fitness Studio', hue: 280 },
  { name: 'Lena K.',   role: 'Real Estate', hue: 45 },
  { name: 'Jamie O.',  role: 'E-commerce', hue: 340 },
];
---
<section class="client-strip">
  <div class="container">
    <div class="strip-header">
      <p class="eyebrow">Clients</p>
      <h2>Brands we've built.</h2>
    </div>
    <div class="avatars">
      {clients.map(c => (
        <figure class="avatar">
          <div class="avatar-bubble" style={`background: radial-gradient(120% 120% at 30% 25%, hsl(${c.hue} 75% 60%), hsl(${c.hue} 70% 22%) 70%);`}>
            <span>{c.name.split(' ').map(p => p[0]).join('')}</span>
          </div>
          <figcaption>
            <strong>{c.name}</strong>
            <span>{c.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .client-strip { padding: 4rem 0 5rem; }
  .strip-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .strip-header h2 { max-width: 18ch; }
  .avatars {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }
  .avatar { margin: 0; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
  .avatar-bubble {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.92);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    letter-spacing: 0.02em;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08);
  }
  figcaption { display: flex; flex-direction: column; gap: 0.1rem; font-size: 0.85rem; }
  figcaption strong { font-weight: 700; color: var(--color-ink); }
  figcaption span { color: #6b6b6b; font-size: 0.8rem; }

  @media (max-width: 880px) { .avatars { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 480px) { .avatars { grid-template-columns: repeat(2, 1fr); } }
</style>
