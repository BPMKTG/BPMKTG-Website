---
import { Image } from 'astro:assets';
import hero from '../assets/images/hero/hero-4-martingarrix-wickedoaks.jpg';

const stats = [
  { value: '$12.9B', label: 'EDM industry 2025' },
  { value: '2.4×',   label: 'Growth from daily short-form' },
  { value: '73%',    label: 'Discover artists on social' },
];

const subhead = "Blueprint Marketing builds growth infrastructure for EDM artists — turning content, shows, and releases into real fans and real revenue.";
---
<section class="hero">
  <div class="slides" data-parallax-bg aria-hidden="true">
    <div class="slide">
      <Image
        src={hero}
        alt="Martin Garrix headlining Wicked Oaks"
        width={1920}
        height={1280}
        format="webp"
        quality={84}
        loading="eager"
      />
    </div>
  </div>
  <div class="overlay" aria-hidden="true"></div>
  <div class="grid-layer" aria-hidden="true"></div>

  <div class="container hero-inner">
    <p class="label" data-reveal="left">For touring EDM artists</p>

    <h1>
      <span data-reveal>Turn every show, release,</span><br />
      <span data-reveal>and moment into a</span><br />
      <span class="highlight blue glitch" data-glitch data-reveal>growth system.</span>
    </h1>

    <p class="hero-sub" data-reveal>
      <span data-typewriter data-typewriter-text={subhead}>{subhead}</span>
    </p>

    <div class="cta-row" data-reveal-group>
      <a href="#book" class="button accent" data-reveal>
        Book a Free Strategy Call
        <span class="arrow" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
      <a href="#process" class="button ghost" data-reveal>See how it works</a>
    </div>

    <div class="stats" data-reveal-group>
      {stats.map(s => (
        <div class="stat" data-reveal>
          <span class="stat-value" data-counter={s.value}>{s.value}</span>
          <span class="stat-underline" aria-hidden="true"></span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;
    min-height: clamp(620px, 85vh, 900px);
    display: flex;
    align-items: center;
    isolation: isolate;
  }

  .slides { position: absolute; inset: 0; z-index: 0; }
  .slide { position: absolute; inset: 0; }
  .slide :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 55%;
    animation: heroKenBurns 36s ease-in-out infinite alternate;
    transform-origin: center 55%;
  }
  @keyframes heroKenBurns {
    0%   { transform: scale(1.03); }
    100% { transform: scale(1.12) translate(-1%, -1%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .slide :global(img) { animation: none; }
  }

  .overlay {
    position: absolute; inset: 0; z-index: 2;
    background:
      linear-gradient(180deg, rgba(10,10,15,0.45) 0%, rgba(10,10,15,0.65) 50%, rgba(10,10,15,0.95) 100%),
      radial-gradient(60% 60% at 80% 20%, rgba(38, 79, 160, 0.18), transparent 70%);
  }
  .grid-layer {
    position: absolute; inset: 0; z-index: 2;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(70% 70% at 50% 30%, #000 30%, transparent 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .hero h1 {
    max-width: 18ch;
    font-size: clamp(2.1rem, 4.8vw, 4rem);
    text-shadow: 0 4px 30px rgba(0,0,0,0.6);
  }
  .hero h1 > span[data-reveal] { display: inline-block; }
  .hero-sub {
    color: var(--ink);
    opacity: 0.85;
    font-size: 1.15rem;
    max-width: 60ch;
    min-height: 4em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }
  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }

  .stats {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.14);
    width: 100%;
    max-width: 720px;
  }
  .stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--bp-blue);
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.78rem;
    color: var(--ink);
    opacity: 0.78;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (max-width: 600px) {
    .stats { grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .stat:nth-child(3) { grid-column: 1 / -1; }
  }
</style>
