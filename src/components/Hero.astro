---
import { Image } from 'astro:assets';
// Poster == the video's actual first frame (extracted from hero-montage.mp4),
// so there's no visual jump when the video starts playing over it.
import hero from '../assets/images/hero/hero-montage-poster.jpg';
import editorBackdrop from '../assets/images/hero/editor-backdrop.png';

const stats = [
  { value: '$12.9B', label: 'EDM industry 2025' },
  { value: '2.4×',   label: 'Growth from daily short-form' },
  { value: '73%',    label: 'Discover artists on social' },
];

const subhead = "Blueprint Marketing builds growth infrastructure for EDM artists — turning content, shows, and releases into real fans and real revenue.";
---
<section class="hero" data-hero-cine>
  <div class="hero-track">
    <div class="hero-sticky">

      <!-- ───────── Editor backdrop (real Premiere screenshot) ─────────
           Fades in as the video shrinks into the program monitor. -->
      <div class="editor" aria-hidden="true">
        <Image
          class="editor-shot"
          src={editorBackdrop}
          alt=""
          width={2560}
          height={1440}
          format="webp"
          quality={88}
          loading="eager"
        />
        <!-- The live media group lands exactly here (program monitor) -->
        <span class="editor-monitor" data-monitor></span>
      </div>

      <!-- ───────── Media group: video + attached copy. Scales as one
           unit (uniform) from full-screen into the program monitor. ───────── -->
      <div class="hero-media" data-hero-media>
        <Image
          class="hero-poster"
          src={hero}
          alt="Festival main stage under lights and haze"
          width={1456}
          height={816}
          format="webp"
          quality={84}
          loading="eager"
        />
        <video class="hero-video" autoplay muted loop playsinline preload="auto">
          <source src="/videos/hero-montage.mp4" type="video/mp4" />
        </video>
        <div class="media-overlay" aria-hidden="true"></div>
        <div class="media-grid" aria-hidden="true"></div>

        <!-- Copy is INSIDE the morphing group so it shrinks with the video -->
        <div class="hero-copy">
          <div class="container hero-inner">
            <p class="label" data-reveal="left">For touring EDM artists</p>

            <h1>
              <span data-reveal>Turn every show, release,</span><br />
              <span data-reveal>and moment into a</span><br />
              <span class="highlight blue glitch" data-glitch data-reveal>growth system.</span>
            </h1>

            <p class="hero-sub" data-reveal>
              <span data-typewriter data-typewriter-text={subhead}>{subhead}</span>
            </p>

            <div class="cta-row" data-reveal-group>
              <a href="#book" class="button accent" data-reveal>
                Book a Free Strategy Call
                <span class="arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </a>
              <a href="#process" class="button ghost" data-reveal>See how it works</a>
            </div>

            <div class="stats" data-reveal-group>
              {stats.map(s => (
                <div class="stat" data-reveal>
                  <span class="stat-value" data-counter={s.value}>{s.value}</span>
                  <span class="stat-underline" aria-hidden="true"></span>
                  <span class="stat-label">{s.label}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <span class="scroll-cue" aria-hidden="true">
        <span class="scroll-cue-text">Scroll into the edit</span>
        <span class="scroll-cue-line"></span>
      </span>

    </div>
  </div>
</section>

<script>
  // ───────── Cinematic hero: the video + its overlaid copy shrink as one
  //           unit into the program monitor of a Premiere screenshot, then
  //           park as a section. Desktop + fine pointer + no reduced-motion
  //           only; mobile/reduced gets the static hero via CSS. ─────────
  const clamp = (v: number, a = 0, b = 1) => Math.min(b, Math.max(a, v));
  const easeInOut = (t: number) => (t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2);
  const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

  // Backdrop screenshot natural size + the program-monitor rectangle as
  // fractions of that natural image (measured from editor-backdrop.png).
  const IMG_W = 2558, IMG_H = 1380;
  // Program-monitor target as fractions of the screenshot. Centered on the
  // monitor (~43.6%, 29.7%); sized 16:9 in PIXELS for the 2558x1380 image
  // (w/h fractions differ because the image isn't exactly 16:9). A ~40%
  // width gives a ~2.5x zoom — a clean reveal that keeps the editor crisp.
  const MON = { l: 0.236, t: 0.0885, w: 0.40, h: 0.417 };

  const init = () => {
    const hero = document.querySelector<HTMLElement>('[data-hero-cine]');
    if (!hero || hero.dataset.cineInit) return;
    hero.dataset.cineInit = '1';

    const track  = hero.querySelector<HTMLElement>('.hero-track');
    const sticky = hero.querySelector<HTMLElement>('.hero-sticky');
    const media  = hero.querySelector<HTMLElement>('[data-hero-media]');
    const slot   = hero.querySelector<HTMLElement>('[data-monitor]');
    const editor = hero.querySelector<HTMLElement>('.editor');
    if (!track || !sticky || !media || !slot || !editor) return;

    const mq = window.matchMedia(
      '(min-width: 981px) and (hover: hover) and (prefers-reduced-motion: no-preference)'
    );

    let active = false;
    let ticking = false;

    const reset = () => {
      media.style.transform = '';
      media.style.left = media.style.top = media.style.width = media.style.height = '';
      editor.style.transform = '';
      hero.style.removeProperty('--cine-p');
      hero.style.removeProperty('--cine-morph');
    };

    const update = () => {
      ticking = false;
      if (!active) return;

      const trackTop = track.getBoundingClientRect().top;
      const total = track.offsetHeight - window.innerHeight;
      const p = total > 0 ? clamp(-trackTop / total) : 0;

      // Morph runs from p=0.04 and completes by p=0.6, leaving the last
      // 40% as a parked beat before release.
      const morph = easeInOut(clamp((p - 0.04) / 0.56));

      const sRect = sticky.getBoundingClientRect();
      const SW = sRect.width, SH = sRect.height;

      // The morphing group is ALWAYS 16:9 so it fits the 16:9 monitor with
      // no aspect mismatch. At the start it's sized to COVER the stage
      // (cropped by overflow), so the full-screen state has no gaps.
      const coverW = Math.max(SW, SH * 16 / 9);
      const coverH = coverW * 9 / 16;
      const coverLeft = (SW - coverW) / 2;
      const coverTop  = (SH - coverH) / 2;
      media.style.left = `${coverLeft}px`;
      media.style.top = `${coverTop}px`;
      media.style.width = `${coverW}px`;
      media.style.height = `${coverH}px`;

      // Program-monitor rect after object-fit:contain fits the whole 16:9
      // screenshot into the stage (letterboxed, never cropped) — exact for
      // any viewport aspect ratio.
      const fit = Math.min(SW / IMG_W, SH / IMG_H);
      const rW = IMG_W * fit, rH = IMG_H * fit;
      const offX = (SW - rW) / 2, offY = (SH - rH) / 2;
      const monL = offX + MON.l * rW;
      const monT = offY + MON.t * rH;
      const monW = MON.w * rW;
      const monH = MON.h * rH;
      slot.style.left = `${monL}px`;
      slot.style.top = `${monT}px`;
      slot.style.width = `${monW}px`;
      slot.style.height = `${monH}px`;

      // ── Video + copy: shrink from full-screen (cover box) into the monitor.
      //    Scales DOWN only, so the video and text stay crisp. ──
      const targetScale = monW / coverW;
      const s  = lerp(1, targetScale, morph);
      const tx = lerp(0, monL - coverLeft, morph);
      const ty = lerp(0, monT - coverTop, morph);
      media.style.transform = `translate(${tx}px, ${ty}px) scale(${s})`;

      // ── Editor: zoom OUT in lock-step. At the start it's scaled up so its
      //    program monitor exactly fills the viewport (hidden behind the
      //    full-screen video); as you scroll it pulls back to its natural
      //    fit, revealing the whole editor around the video. Because both the
      //    video's shrink path and the editor's monitor share the same two
      //    endpoints (full-screen ↔ monitor rect) and both interpolate
      //    linearly, the video stays locked to the monitor the entire time. ──
      const zoom = Math.max(SW / monW, SH / monH);
      const cx = monL + monW / 2, cy = monT + monH / 2;
      const ez = lerp(zoom, 1, morph);
      const etx = lerp(SW / 2 - cx * zoom, 0, morph);
      const ety = lerp(SH / 2 - cy * zoom, 0, morph);
      editor.style.transform = `translate(${etx}px, ${ety}px) scale(${ez})`;

      hero.style.setProperty('--cine-p', String(p));
      hero.style.setProperty('--cine-morph', String(morph));
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    const enable = () => {
      if (active) return;
      active = true;
      hero.classList.add('hero--cinematic');
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      update();
    };
    const disable = () => {
      if (!active) return;
      active = false;
      hero.classList.remove('hero--cinematic');
      window.removeEventListener('scroll', onScroll);
      window.removeEventListener('resize', onScroll);
      reset();
    };

    if (mq.matches) enable();
    mq.addEventListener('change', e => (e.matches ? enable() : disable()));
  };

  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>

<style>
  /* ════════════════════════════════════════════════════════════════
     BASE / STATIC HERO (mobile + reduced-motion fallback)
     Wrappers collapse via display:contents so layout matches the
     original single-screen hero.
     ════════════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(620px, 85vh, 900px);
    display: flex;
    align-items: center;
    isolation: isolate;
  }
  .hero-track, .hero-sticky { display: contents; }
  .editor { display: none; }

  /* The media group fills the hero as the background layer in static mode */
  .hero-media { position: absolute; inset: 0; z-index: 0; }
  .hero-poster,
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 55%;
  }
  .hero-poster { animation: heroKenBurns 36s ease-in-out infinite alternate; transform-origin: center 55%; }
  .hero-video { z-index: 1; }
  @keyframes heroKenBurns {
    0%   { transform: scale(1.03); }
    100% { transform: scale(1.12) translate(-1%, -1%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-poster { animation: none; }
    .hero-video { display: none; }
  }

  .media-overlay {
    position: absolute; inset: 0; z-index: 2;
    background:
      linear-gradient(180deg, rgba(10,10,15,0.45) 0%, rgba(10,10,15,0.65) 50%, rgba(10,10,15,0.95) 100%),
      radial-gradient(60% 60% at 80% 20%, rgba(38, 79, 160, 0.18), transparent 70%);
  }
  .media-grid {
    position: absolute; inset: 0; z-index: 2;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(70% 70% at 50% 30%, #000 30%, transparent 100%);
  }

  /* Copy overlays the video, vertically centered */
  .hero-copy {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    align-items: center;
  }
  .hero-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .hero h1 {
    max-width: 18ch;
    font-size: clamp(2.1rem, 4.8vw, 4rem);
    text-shadow: 0 4px 30px rgba(0,0,0,0.6);
  }
  .hero h1 > span[data-reveal] { display: inline-block; }
  .hero-sub {
    color: var(--ink);
    opacity: 0.85;
    font-size: 1.15rem;
    max-width: 60ch;
    min-height: 4em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
  }
  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }

  .stats {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.14);
    width: 100%;
    max-width: 720px;
  }
  .stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--bp-blue);
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.78rem;
    color: var(--ink);
    opacity: 0.78;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .scroll-cue { display: none; }

  @media (max-width: 600px) {
    .stats { grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .stat:nth-child(3) { grid-column: 1 / -1; }
    .hero-inner { padding: 0 1.5rem; }
  }
  /* Static mode keeps the inner copy inside the container gutter */
  .hero:not(.hero--cinematic) .hero-inner { padding-left: 1.5rem; padding-right: 1.5rem; }

  /* ════════════════════════════════════════════════════════════════
     CINEMATIC MODE (desktop, hover, no reduced-motion)
     ════════════════════════════════════════════════════════════════ */
  .hero--cinematic { display: block; min-height: 0; overflow: visible; }
  .hero--cinematic .hero-track { display: block; height: 240vh; }
  .hero--cinematic .hero-sticky {
    display: block;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #05060a;
  }
  .hero--cinematic :global(.hero-particles) { display: none; }

  /* ── Editor backdrop ── */
  .hero--cinematic .editor {
    display: block;
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 1;                 /* revealed by the zoom-out, not a fade */
    transform-origin: 0 0;      /* JS drives the zoom-out transform */
    will-change: transform;
  }
  .editor-shot {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: contain;   /* show the WHOLE editor, never crop; letterbox on
                              non-16:9 windows (bars match the dark stage bg) */
    object-position: center;
  }
  /* Program-monitor slot — the morph target. Coordinates are % of the
     stage (which equals % of the 16:9 screenshot on a 16:9 viewport).
     Tuned to sit exactly on the cars frame. */
  .editor-monitor {
    position: absolute;
    left:  var(--mon-l, 23.6%);
    top:   var(--mon-t, 8.85%);
    width: var(--mon-w, 40%);
    height: var(--mon-h, 41.7%);
    pointer-events: none;
  }

  /* ── Morphing media group ── */
  .hero--cinematic .hero-media {
    z-index: 3;
    inset: auto;            /* JS drives left/top/width/height (16:9 cover box) */
    transform-origin: 0 0;
    will-change: transform;
  }
  .hero--cinematic .hero-poster { animation: none; }

  /* Overlay/grid fade as the editor takes over so the parked clip reads clean */
  .hero--cinematic .media-overlay,
  .hero--cinematic .media-grid {
    opacity: calc(1 - var(--cine-morph, 0));
  }

  /* Copy stays attached and scales with the group — no fade. */
  .hero--cinematic .hero-inner { padding: 0 4vw; }

  /* Scroll cue (separate from the group) fades as you scroll */
  .hero--cinematic .scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 2rem;
    transform: translateX(-50%);
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--bp-light);
    opacity: clamp(0, calc(1 - var(--cine-p, 0) * 5), 1);
  }
  .scroll-cue-text {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.66rem;
    opacity: 0.8;
  }
  .scroll-cue-line {
    width: 1px; height: 38px;
    background: linear-gradient(to bottom, var(--bp-blue), transparent);
    animation: cuePulse 1.8s ease-in-out infinite;
  }
  @keyframes cuePulse {
    0%, 100% { transform: scaleY(0.5); opacity: 0.4; transform-origin: top; }
    50%      { transform: scaleY(1);   opacity: 1;   transform-origin: top; }
  }
</style>
