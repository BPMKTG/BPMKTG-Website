---
const stats = [
  { value: '$12.9B', label: 'EDM industry 2025' },
  { value: '2.4×',   label: 'Growth from daily short-form' },
  { value: '73%',    label: 'Discover artists on social' },
];
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="grid-layer"></div>
    <div class="glow glow-a"></div>
    <div class="glow glow-b"></div>
    <div class="glow glow-c"></div>
  </div>

  <div class="container hero-inner">
    <p class="label">For touring EDM artists</p>

    <h1>
      Turn every show, release,<br />
      and moment into a<br />
      <span class="highlight">growth system.</span>
    </h1>

    <p class="hero-sub">
      Blueprint Marketing builds growth infrastructure for EDM artists —
      turning content, shows, and releases into real fans and real revenue.
    </p>

    <div class="cta-row">
      <a href="#book" class="button">
        Book a Free Strategy Call
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a href="#process" class="button ghost">See how it works</a>
    </div>

    <div class="stats">
      {stats.map(s => (
        <div class="stat">
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 6rem 0 5rem;
  }
  .hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .grid-layer {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(70% 70% at 50% 30%, #000 30%, transparent 100%);
  }
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
  }
  .glow-a { width: 540px; height: 540px; top: -180px; left: -180px; background: radial-gradient(circle, var(--bp-deep), transparent 70%); }
  .glow-b { width: 620px; height: 620px; top: -120px; right: -180px; background: radial-gradient(circle, var(--bp-blue), transparent 70%); opacity: 0.35; }
  .glow-c { width: 380px; height: 380px; bottom: -180px; left: 40%; background: radial-gradient(circle, var(--bp-orange), transparent 70%); opacity: 0.2; }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .hero h1 { max-width: 18ch; }
  .hero-sub {
    color: var(--ink);
    opacity: 0.75;
    font-size: 1.15rem;
    max-width: 60ch;
  }
  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }

  .stats {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
    width: 100%;
    max-width: 720px;
  }
  .stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: var(--bp-blue);
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.78rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  @media (max-width: 600px) {
    .stats { grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .stat:nth-child(3) { grid-column: 1 / -1; }
  }
</style>
