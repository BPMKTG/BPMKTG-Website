---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
}

const { eyebrow, title, subtitle, primaryCta, secondaryCta } = Astro.props;
---
<section class="hero section">
  <div class="container hero-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    {(primaryCta || secondaryCta) && (
      <div class="cta-row">
        {primaryCta && <a class="button" href={primaryCta.href}>{primaryCta.label}</a>}
        {secondaryCta && <a class="button secondary" href={secondaryCta.href}>{secondaryCta.label}</a>}
      </div>
    )}
  </div>
</section>

<style>
  .hero { padding-top: 6rem; padding-bottom: 4rem; }
  .hero-inner { max-width: 780px; }
  .subtitle { font-size: 1.15rem; color: var(--color-muted); max-width: 60ch; }
  .cta-row { display: flex; gap: 0.75rem; margin-top: 1.75rem; flex-wrap: wrap; }
</style>
