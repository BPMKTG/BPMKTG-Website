---
const artists = [
  'Martin Garrix', 'Excision', 'Flux Pavilion', 'Subtronics', 'Doctor P',
  'Slander', 'Adventure Club', 'Crankdat', 'Kai Wachi', 'ATLiens',
  'Wooli', 'The Resistance', 'Svdden Death', 'Voyd', 'Space Laces',
  'Level Up', 'Dion Timmer', 'San Pacho', 'Drinkurwater', 'Inzo',
  'Beauz', 'AlleyCvt', 'Yookie', 'Ahee', 'Automhate',
  'Alien Park', 'Neotek', 'Lauren Mia', 'Silver Panda', 'Perry Wayne',
  'All The Reason', 'Blankface', 'Sqishi', 'OG Nixin', 'Izzy Vadim',
  'Rzrkt', 'Nimda', 'Yvm3', 'Skyvak', 'Ophion',
  'Mushroom Cloud', 'Destroyah', 'Krazz', 'Spira', 'LegendOfShellda',
  'Gabetoldmeto',
];

// Duplicate the list so the CSS animation can translate -50% for a seamless loop
const trackList = [...artists, ...artists];
---
<section class="marquee" aria-label="Artists in the field">
  <div class="container">
    <p class="marquee-label">In The Field With</p>
  </div>

  <div class="marquee-track" aria-hidden="true">
    <ul class="marquee-row" role="presentation">
      {trackList.map((name, i) => (
        <li class="marquee-item">
          <span class="artist">{name}</span>
          <span class="sep" aria-hidden="true">
            <svg viewBox="0 0 12 12" width="10" height="10" fill="currentColor">
              <polygon points="2.5,1.5 10,6 2.5,10.5" />
            </svg>
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>

<script>
  // Web Animations API instead of CSS animation so hover can smoothly
  // change playback rate WITHOUT jumping to a new playhead position.
  const init = () => {
    document.querySelectorAll<HTMLElement>('.marquee').forEach(marquee => {
      if (marquee.dataset.marqueeInit) return;
      marquee.dataset.marqueeInit = '1';

      const row = marquee.querySelector<HTMLElement>('.marquee-row');
      if (!row) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const isMobile = window.innerWidth < 700;
      const duration = isMobile ? 130_000 : 180_000;

      const animation = row.animate(
        [
          { transform: 'translate3d(0, 0, 0)' },
          { transform: 'translate3d(-50%, 0, 0)' },
        ],
        { duration, iterations: Infinity, easing: 'linear' }
      );

      // updatePlaybackRate keeps the current visual position and just changes
      // how fast time advances — no jump.
      marquee.addEventListener('pointerenter', () => animation.updatePlaybackRate(0.12));
      marquee.addEventListener('pointerleave', () => animation.updatePlaybackRate(1));

      // Pause when tab is hidden so we don't burn cycles in the background
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) animation.pause();
        else animation.play();
      });
    });
  };

  document.addEventListener('astro:page-load', init);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>

<style>
  .marquee {
    background: transparent;
    padding: 2rem 0 2.25rem;
    overflow: hidden;
    position: relative;
  }
  .marquee-label {
    text-align: center;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--bp-light);
    font-family: var(--font-display);
  }

  .marquee-track {
    display: flex;
    width: 100%;
    overflow: hidden;
    /* Edge fade in/out */
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 7%,
      #000 93%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 7%,
      #000 93%,
      transparent 100%
    );
  }

  .marquee-row {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    white-space: nowrap;
    will-change: transform;
    /* The motion is driven by JS via Web Animations API (see <script> below)
       so we can smoothly change playback rate on hover without jumping. */
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .artist {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
    padding: 0 1.6rem 0 0;
    transition: color 0.2s;
  }
  .marquee-item:hover .artist { color: var(--bp-light); }

  .sep {
    color: var(--bp-orange);
    display: inline-flex;
    align-items: center;
    padding-right: 1.6rem;
    opacity: 0.85;
    filter: drop-shadow(0 0 6px rgba(227, 112, 59, 0.35));
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { overflow-x: auto; }
  }

  @media (max-width: 700px) {
    .marquee { padding: 1.5rem 0 1.75rem; }
    .artist { font-size: 0.85rem; letter-spacing: 0.18em; padding-right: 1.1rem; }
    .sep { padding-right: 1.1rem; }
  }
</style>
