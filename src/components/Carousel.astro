---
import { Image } from 'astro:assets';

import mgWickedOaks from '../assets/images/carousel/carousel-martingarrix-wickedoaks.jpg';
import fireworks    from '../assets/images/carousel/carousel-fireworks-dft.jpg';
import fluxDoctorP  from '../assets/images/carousel/carousel-flux-doctorp-rv.jpg';
import sanpachoSelfie from '../assets/images/carousel/carousel-sanpacho-selfie.jpg';
import wooliAP      from '../assets/images/carousel/carousel-wooli-alienpark-backstage.jpg';
import atliens      from '../assets/images/carousel/carousel-atliens-sidestage.jpg';
import subtronicsRed from '../assets/images/carousel/carousel-subtronics-red.jpg';
import subLevelUp   from '../assets/images/carousel/carousel-subtronics-levelup.jpg';
import allTheReason from '../assets/images/carousel/carousel-allthereason-graffiti.jpg';
import sanpachoYR   from '../assets/images/carousel/carousel-sanpacho-yellowred.jpg';
import sanpachoRL   from '../assets/images/carousel/carousel-sanpacho-redlasers.jpg';
import ahee         from '../assets/images/carousel/carousel-ahee-crowd.jpg';
import levelUpWide  from '../assets/images/carousel/carousel-levelup-wide.jpg';
import yookie       from '../assets/images/carousel/carousel-yookie-grimefest.jpg';
import martinGarrix from '../assets/images/carousel/carousel-martingarrix-freakyducky.jpg';
import wooliees     from '../assets/images/carousel/carousel-wooliees-silo.jpg';

const shots = [
  { src: mgWickedOaks,   caption: 'Martin Garrix',           venue: 'Onstage · Wicked Oaks',      orient: 'v' },
  { src: fluxDoctorP,    caption: 'Flux Pavilion X Doctor P',venue: 'Artist Trailer · Wicked Oaks', orient: 'v' },
  { src: wooliAP,        caption: 'Wooli X Alien Park',      venue: 'Backstage · Silo Dallas',    orient: 'v' },
  { src: atliens,        caption: 'ATLiens',                 venue: 'Sidestage · Dancefestopia',  orient: 'v' },
  { src: subtronicsRed,  caption: 'Subtronics',              venue: 'Dancefestopia',              orient: 'v' },
  { src: martinGarrix,   caption: 'Martin Garrix',           venue: 'Wicked Oaks',                orient: 'h' },
  { src: sanpachoSelfie, caption: 'San Pacho',               venue: 'Silo - Dallas',              orient: 'v' },
  { src: fireworks,      caption: 'Level Up',                venue: 'Dancefestopia',              orient: 'v' },
  { src: yookie,         caption: 'Yookie',                  venue: 'Grimefest',                  orient: 'h' },
  { src: subLevelUp,     caption: 'Subtronics X Level Up',   venue: 'Sidestage · Dancefestopia',  orient: 'v' },
  { src: ahee,           caption: 'AHEE',                    venue: 'Dancefestopia',              orient: 'h' },
  { src: sanpachoRL,     caption: 'San Pacho',               venue: 'Silo - Dallas',              orient: 'v' },
  { src: levelUpWide,    caption: 'Level Up',                venue: 'Dancefestopia',              orient: 'h' },
  { src: allTheReason,   caption: 'All The Reason',          venue: 'Vulcan Gas Co.',             orient: 'v' },
  { src: sanpachoYR,     caption: 'San Pacho',               venue: 'Silo Dallas',                orient: 'v' },
  { src: wooliees,       caption: 'Wooli',                   venue: 'Silo - Dallas',              orient: 'h' },
];
---
<section class="field-section" id="field">
  <div class="container head">
    <div class="head-text">
      <p class="label" data-reveal="left">In The Field</p>
      <h2 data-reveal>We don't just market EDM —<br/><span class="glow-blue">we live it.</span></h2>
    </div>
    <a href="/portfolio" class="see-all" data-reveal>
      See full portfolio
      <span class="arrow" aria-hidden="true">→</span>
    </a>
  </div>

  <div class="rail-wrap">
    <button class="nav prev" type="button" aria-label="Scroll left" data-rail-prev>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <div class="edge edge-left" data-rail-edge="left" aria-hidden="true"></div>
    <div class="edge edge-right" data-rail-edge="right" aria-hidden="true"></div>

    <div class="rail" data-rail>
      {shots.map(shot => (
        <figure class={`card ${shot.orient === 'v' ? 'v' : 'h'}`}>
          <div class="img-wrap">
            <Image
              src={shot.src}
              alt={`${shot.caption} — ${shot.venue}`}
              width={shot.orient === 'v' ? 720 : 1280}
              height={shot.orient === 'v' ? 1080 : 720}
              format="webp"
              quality={80}
              loading="lazy"
            />
          </div>
          <figcaption>
            <strong>{shot.caption}</strong>
            <span>{shot.venue}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <button class="nav next" type="button" aria-label="Scroll right" data-rail-next>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
</section>

<script>
  const AUTO_MS = 3000;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('[data-rail]').forEach(rail => {
    const wrap = rail.parentElement!;
    const step = () => Math.round(rail.clientWidth * 0.42);
    const maxScroll = () => rail.scrollWidth - rail.clientWidth - 4;

    let timer: number | null = null;
    let paused = false;
    let userInteracted = false;

    const tick = () => {
      if (paused) return;
      if (rail.scrollLeft >= maxScroll()) {
        rail.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        rail.scrollBy({ left: step(), behavior: 'smooth' });
      }
    };
    const start = () => { stop(); if (!reduceMotion) timer = window.setInterval(tick, AUTO_MS); };
    const stop  = () => { if (timer !== null) { clearInterval(timer); timer = null; } };
    const pause = () => { paused = true; stop(); };
    const resume = () => { paused = false; if (!timer) start(); };

    // Buttons
    wrap.querySelector('[data-rail-prev]')?.addEventListener('click', () => {
      userInteracted = true; pause();
      rail.scrollBy({ left: -step() * 2, behavior: 'smooth' });
      window.setTimeout(resume, 2500);
    });
    wrap.querySelector('[data-rail-next]')?.addEventListener('click', () => {
      userInteracted = true; pause();
      rail.scrollBy({ left:  step() * 2, behavior: 'smooth' });
      window.setTimeout(resume, 2500);
    });

    // Pause on hover (mouse)
    rail.addEventListener('mouseenter', pause);
    rail.addEventListener('mouseleave', resume);

    // Pause when tab hidden
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) pause(); else if (!userInteracted) resume();
    });

    // Mouse drag-to-pan (touch uses native scroll-snap so we skip it)
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = false;

    rail.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return;
      dragging = true;
      moved = false;
      startX = e.clientX;
      startScroll = rail.scrollLeft;
      rail.setPointerCapture(e.pointerId);
      rail.style.scrollBehavior = 'auto';
      rail.style.cursor = 'grabbing';
      pause();
    });
    rail.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 4) moved = true;
      rail.scrollLeft = startScroll - dx;
    });
    const endDrag = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      try { rail.releasePointerCapture(e.pointerId); } catch {}
      rail.style.scrollBehavior = '';
      rail.style.cursor = '';
      userInteracted = true;
      window.setTimeout(resume, 2000);
    };
    rail.addEventListener('pointerup', endDrag);
    rail.addEventListener('pointercancel', endDrag);

    // Suppress click handlers if user dragged
    rail.addEventListener('click', (e) => {
      if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; }
    }, true);

    // Pause briefly on native touch scroll too
    rail.addEventListener('touchstart', pause, { passive: true });
    rail.addEventListener('touchend',   () => window.setTimeout(resume, 2000));

    // Edge-hover continuous scroll — speed scales with how close the
    // cursor is to the outer edge (slowest at 90px in, fastest at the
    // edge itself). Both speed AND direction reset cleanly on leave so
    // no in-flight rAF can keep scrolling after the cursor exits.
    let edgeRaf = 0;
    let edgeDir: 0 | 1 | -1 = 0;
    let edgeSpeed = 0;
    let snapRestoreT = 0;
    const MIN_SPEED = 1.2;   // px / frame
    const MAX_SPEED = 9;     // px / frame at the very edge

    // Distance from cursor to the OUTER edge of the zone. 0 = at edge,
    // up to zone.width away = furthest in. Mapped to speed via easing.
    const computeSpeed = (zone: HTMLElement, dir: 1 | -1, clientX: number) => {
      const r = zone.getBoundingClientRect();
      const dist = dir === -1 ? (clientX - r.left) : (r.right - clientX);
      const w = r.width || 90;
      const clamped = Math.max(0, Math.min(w, dist));
      const t = 1 - (clamped / w);        // 0 (far) → 1 (at edge)
      const eased = t * t;                 // ease-in so close-to-edge is dramatic
      return MIN_SPEED + eased * (MAX_SPEED - MIN_SPEED);
    };

    const edgeTick = () => {
      // Belt-and-braces: if either piece of state was cleared between
      // the cancelAnimationFrame and this frame firing, bail out and
      // do not schedule another frame.
      if (!edgeDir || !edgeSpeed) { edgeRaf = 0; return; }
      rail.scrollLeft += edgeDir * edgeSpeed;
      edgeRaf = requestAnimationFrame(edgeTick);
    };

    const startEdge = (zone: HTMLElement, dir: 1 | -1, clientX: number) => {
      edgeDir = dir;
      edgeSpeed = computeSpeed(zone, dir, clientX);
      pause();
      rail.style.scrollBehavior = 'auto';
      rail.style.scrollSnapType = 'none';
      window.clearTimeout(snapRestoreT);
      cancelAnimationFrame(edgeRaf);
      edgeRaf = requestAnimationFrame(edgeTick);
    };

    const stopEdge = () => {
      // Clear state FIRST, then cancel — any frame that fires between
      // these calls will hit the bail in edgeTick().
      edgeDir = 0;
      edgeSpeed = 0;
      cancelAnimationFrame(edgeRaf);
      edgeRaf = 0;
      rail.style.scrollBehavior = '';
      // Defer snap restore one frame so the rail "lands" softly — if
      // we flip snap back on in the same frame the scrollBy stopped
      // in, the browser yanks to the nearest card and looks janky.
      window.clearTimeout(snapRestoreT);
      snapRestoreT = window.setTimeout(() => { rail.style.scrollSnapType = ''; }, 80);
      userInteracted = true;
      window.setTimeout(resume, 1500);
    };

    wrap.querySelectorAll<HTMLElement>('[data-rail-edge]').forEach(zone => {
      const dir: 1 | -1 = zone.dataset.railEdge === 'left' ? -1 : 1;
      zone.addEventListener('pointerenter', (e) => startEdge(zone, dir, e.clientX));
      zone.addEventListener('pointermove',  (e) => {
        if (edgeDir === dir) edgeSpeed = computeSpeed(zone, dir, e.clientX);
      });
      zone.addEventListener('pointerleave',  stopEdge);
      zone.addEventListener('pointercancel', stopEdge);
    });

    // Defer the first auto-advance until the carousel enters the viewport,
    // then wait ~2.5s before the first scroll so the user gets to look first.
    let started = false;
    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting && !started) {
        started = true;
        window.setTimeout(() => { tick(); start(); }, 2500);
        io.unobserve(rail);
      }
    }, { threshold: 0.25 });
    io.observe(rail);
  });
</script>

<style>
  .field-section { padding: 5rem 0 6rem; }
  .head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .head-text h2 { margin-top: 1rem; }
  .see-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--bp-light);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.85rem;
    padding: 0.7rem 1.1rem;
    border: 1px solid rgba(98, 166, 219, 0.35);
    border-radius: 999px;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .see-all:hover { background: rgba(98, 166, 219, 0.12); color: #fff; border-color: var(--bp-blue); }

  .rail-wrap {
    position: relative;
  }
  .rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 280px;
    gap: 1rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    padding: 0.5rem 1.5rem 1rem;
    scroll-padding-left: 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.2) transparent;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }
  .rail:active { cursor: grabbing; }
  .rail :global(img) { -webkit-user-drag: none; user-drag: none; }
  .rail::-webkit-scrollbar { height: 8px; }
  .rail::-webkit-scrollbar-track { background: transparent; }
  .rail::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 999px; }

  .card {
    margin: 0;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .card.h { grid-column: span 2; }
  .img-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 14px;
    background: var(--card);
    position: relative;
    isolation: isolate;
  }
  .card.h .img-wrap { aspect-ratio: 16 / 9; }
  .img-wrap :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .card:hover .img-wrap :global(img) { transform: scale(1.04); }
  .img-wrap::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.4), transparent 50%);
    pointer-events: none;
  }
  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0 0.25rem;
  }
  figcaption strong {
    color: var(--ink);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.92rem;
  }
  figcaption span { color: var(--muted); font-size: 0.82rem; }

  /* Edge-hover zones — invisible but cursor-targetable. Hover triggers
     continuous gliding scroll; subtle gradient hints at the affordance. */
  .edge {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 90px;
    z-index: 2;
    pointer-events: auto;
    transition: opacity 0.25s ease;
  }
  .edge-left  { left: 0;  background: linear-gradient(to right, rgba(98,166,219,0.10), transparent); }
  .edge-right { right: 0; background: linear-gradient(to left,  rgba(98,166,219,0.10), transparent); }
  .edge:hover { background-image: linear-gradient(to right, rgba(98,166,219,0.22), transparent); }
  .edge-right:hover { background-image: linear-gradient(to left, rgba(98,166,219,0.22), transparent); }
  @media (max-width: 700px) { .edge { display: none; } }

  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    color: var(--ink);
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .nav:hover { background: rgba(38, 79, 160, 0.5); border-color: var(--bp-blue); }
  .nav.prev { left: 0.5rem; }
  .nav.next { right: 0.5rem; }

  @media (max-width: 700px) {
    .rail { grid-auto-columns: 220px; }
    .nav { display: none; }
  }
</style>
