---
import Layout from '../../layouts/Layout.astro';
import TierHero from './TierHero.astro';
import TierWhoFor from './TierWhoFor.astro';
import TierWhatYouGet from './TierWhatYouGet.astro';
import TierRoadmap from './TierRoadmap.astro';
import TierAddOns from './TierAddOns.astro';
import FAQ from '../FAQ.astro';
import BookCall from '../BookCall.astro';
import type { Tier } from '../../data/tiers';
import { CALENDLY_URL } from '../../config/cta';

interface Props {
  tier: Tier;
}
const { tier } = Astro.props;
---
<Layout
  title={`Tier ${tier.number} — ${tier.name} — Blueprint Marketing`}
  description={`${tier.name}: ${tier.positioning}`}
>
  <TierHero
    markerLabel={tier.hero.markerLabel}
    markerNumber={tier.number}
    eyebrow={tier.hero.eyebrow}
    name={tier.name}
    headline={tier.hero.headline}
    sub={tier.hero.sub}
    pills={tier.hero.pills}
    primaryCta={tier.hero.primaryCta}
    secondaryCta={tier.hero.secondaryCta}
    shortName={tier.shortName}
    price={tier.price}
    priceNote={tier.priceNote}
    offerHighlights={tier.hero.offerHighlights}
    offerCardCta={tier.hero.offerCardCta}
    offerCardFootLabel={tier.hero.offerCardFootLabel}
    pif={tier.hero.pif}
  />
  <TierWhoFor {...tier.whoFor} id="who" />
  <TierWhatYouGet {...tier.whatYouGet} id="deliverables" />
  <TierRoadmap {...tier.howItWorks} id="process" />
  <TierAddOns tier={tier} />
  <FAQ
    eyebrow={tier.faq.eyebrow}
    headline={tier.faq.headline}
    lede={tier.faq.lede}
    faqs={tier.faq.items}
    footnote={`Question we didn't cover? <a href="${CALENDLY_URL}" target="_blank" rel="noopener noreferrer">Bring it up on the call</a> — that's what it's for.`}
  />
  <BookCall />
</Layout>
