---
import type { Tier } from '../../data/tiers';

interface Props { tier: Tier; }
const { tier } = Astro.props;
---
<section class="tier-deliv" id="deliverables">
  <div class="container">
    <header class="tier-section-head wide">
      <p class="label" data-reveal="left">{tier.whatYouGet.eyebrow}</p>
      <h2 data-reveal>{tier.whatYouGet.headline}</h2>
      <p class="tier-section-sub" data-reveal>{tier.whatYouGet.sub}</p>
    </header>

    <div class="tier-deliv-grid" data-reveal-group>
      {tier.whatYouGet.cards.map((c, i) => (
        <article class="tier-deliv-card card-trace card-inner-glow" data-reveal data-scroll-focus>
          <span class="tier-deliv-num" data-icon-pop>{String(i + 1).padStart(2, '0')}</span>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* This is the centerpiece of a tier page — keep card density high,
     but tighten outer breathing room. */
  .tier-deliv { padding: 4rem 0; position: relative; isolation: isolate; }
  .tier-section-head { max-width: 60ch; margin-bottom: 2.25rem; }
  .tier-section-head.wide { max-width: 70ch; }
  .tier-section-head h2 { margin-top: 0.85rem; text-wrap: balance; }
  .tier-section-sub { color: var(--ink); opacity: 0.78; font-size: 1rem; margin-top: 0.85rem; max-width: 60ch; }

  .tier-deliv-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .tier-deliv-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.3s ease;
  }
  .tier-deliv-card:hover {
    border-color: rgba(98, 166, 219, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 20px 40px -22px rgba(0, 0, 0, 0.6);
  }
  .tier-deliv-card::before {
    content: "";
    position: absolute; inset: -1px -1px auto -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bp-blue), transparent);
    opacity: 0.55;
  }
  .tier-deliv-num {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
  }
  .tier-deliv-card h3 {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.25;
  }
  .tier-deliv-card p { color: var(--muted); font-size: 0.92rem; line-height: 1.55; }

  @media (max-width: 980px) { .tier-deliv-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .tier-deliv-grid { grid-template-columns: 1fr; } }
</style>
