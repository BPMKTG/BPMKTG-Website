---
import { CALENDLY_URL } from '../config/cta';

const steps = [
  { title: 'Book the call',          body: 'Free, 30 minutes, no pitch deck — pick a slot that works.' },
  { title: 'Discovery + audit',      body: 'We dig into your content, audience, and growth gaps so the conversation is specific to you.' },
  { title: 'Custom proposal',        body: 'A tailored plan with clear deliverables, timeline, and pricing — no inflated numbers, no fine print.' },
  { title: 'Quick-win launch',       body: 'We ship something fast — a content drop, a funnel, a campaign test — to prove the system works.' },
  { title: 'Long-term partnership',  body: 'The growth system runs in the background. We optimize. You make music.' },
];
---
<section class="book" id="book">
  <div class="container">
    <div class="bg" aria-hidden="true">
      <div class="grid-layer"></div>
      <div class="glow glow-a"></div>
      <div class="glow glow-b"></div>
      <div class="cta-particles" aria-hidden="true"></div>
    </div>

    <div class="content">
      <p class="label" data-reveal="left">Book a Call</p>
      <h2 data-reveal>Let's build your <span class="text-neon">Blueprint.</span></h2>
      <p class="lede" data-reveal>
        Book a strategy call and find out exactly how we'd grow your fanbase
        and turn your content into a system that compounds.
      </p>

      <div class="cta-row" data-reveal>
        <a href={CALENDLY_URL} class="button" target="_blank" rel="noopener noreferrer">
          Book a Strategy Call
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a href="mailto:hello@blueprintmkt.com" class="button ghost">
          hello@blueprintmkt.com
        </a>
      </div>

      <ul class="trust" data-reveal>
        <li>Free · 30 minutes</li>
        <li>No-pressure intro</li>
        <li>No inflated metrics. No hidden costs.</li>
        <li>Walk away with a growth plan</li>
      </ul>

      <!-- What happens after you book (5-step sales process from the brand) -->
      <div class="process" data-reveal-group>
        <p class="process-label" data-reveal>What happens after you book</p>
        <ol class="process-steps">
          {steps.map((s, i) => (
            <li class="process-step" data-reveal>
              <span class="ps-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="ps-body">
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>

<style>
  /* Opaque dark backdrop so the page-wide SpaceBackground doesn't show
     here — this section has its own grid + glows + floating particles
     and they need a clean dark stage to read against. */
  .book { padding: 6rem 0 7rem; position: relative; overflow: hidden; background: #06060c; }
  .bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .grid-layer {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(70% 70% at 50% 50%, #000 30%, transparent 100%);
  }
  .glow { position: absolute; border-radius: 50%; filter: blur(80px); }
  .glow-a { width: 480px; height: 480px; top: -120px; left: 20%; background: radial-gradient(circle, var(--bp-deep), transparent 70%); opacity: 0.6; }
  .glow-b { width: 420px; height: 420px; bottom: -160px; right: 10%; background: radial-gradient(circle, var(--bp-light), transparent 70%); opacity: 0.3; }

  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .content h2 { font-size: clamp(2.5rem, 5vw, 4.25rem); margin-top: 0.5rem; }
  .lede { color: var(--ink); opacity: 0.78; font-size: 1.1rem; max-width: 56ch; }
  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; margin-top: 0.75rem; }
  .trust {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    gap: 1.75rem;
    flex-wrap: wrap;
    justify-content: center;
    color: var(--muted);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .trust li { display: flex; align-items: center; gap: 0.5rem; }
  .trust li::before {
    content: "";
    width: 6px; height: 6px;
    background: var(--bp-blue);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--bp-blue);
  }

  /* ─────────── Process steps (what happens after you book) ─────────── */
  .process {
    width: 100%;
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.12);
    text-align: left;
  }
  .process-label {
    font-family: var(--font-display);
    color: var(--bp-light);
    font-size: 0.74rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    text-align: center;
    margin-bottom: 1.75rem;
  }
  .process-steps {
    list-style: none;
    margin: 0; padding: 0;
    display: grid;
    /* minmax(0, 1fr) — without min: 0, grid items use their
       intrinsic min-content width (longest unbreakable word) which
       made the cards visibly unequal whenever one had a longer phrase. */
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
    counter-reset: ps;
  }
  .process-step {
    background: rgba(18, 19, 28, 0.55);
    backdrop-filter: blur(6px);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.1rem 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    position: relative;
    min-width: 0;
    overflow-wrap: break-word;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .process-step:hover {
    border-color: rgba(98, 166, 219, 0.35);
    transform: translateY(-2px);
  }
  .ps-num {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
  }
  .ps-body { display: flex; flex-direction: column; gap: 0.3rem; }
  .ps-body h3 {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 0.88rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin: 0;
  }
  .ps-body p {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.4;
    margin: 0;
  }

  @media (max-width: 980px) {
    .process-steps { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .process-steps { grid-template-columns: 1fr; }
  }
</style>
