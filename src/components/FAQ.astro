---
// Objection-handling FAQ. Pre-handles the 7 most common doubts artists raise
// before they ever get on a call, in the order they typically show up after
// seeing pricing. Lifted from the brand IOF "Objections + Solutions" doc and
// adapted for web tone.
const faqs = [
  {
    q: "Can't I just do this myself?",
    a: "You can. Plenty of artists do — and most of them stay stuck. The difference isn't effort, it's having a system behind the effort. DIY is slow and inconsistent because every post, every show, every release starts from zero. We build the system so growth compounds instead of starting over every time."
  },
  {
    q: "I've tried marketing before and it didn't work. Why is this different?",
    a: "Most agencies sell campaigns or content packages. Both run for 30–90 days and end. We don't run campaigns — we build infrastructure. Content, distribution, fan capture, and monetization stay running whether you're touring or in the studio. The system is the deliverable."
  },
  {
    q: "Won't this make my brand feel fake or forced?",
    a: "Opposite. We don't replace your creativity — we structure it so more people actually see it. Your voice, your shows, your music stay yours. We build the framework around them so the right people find them at the right moment."
  },
  {
    q: "I don't have time to add another thing to my plate.",
    a: "That's exactly why this works. We remove the need for you to think about what to post, when to post, or how to grow. You focus on music; we run the system behind it. Less mental load, not more."
  },
  {
    q: "What if it doesn't work?",
    a: "Two answers. First — we don't promise virality, we promise consistency and direction, which is what actually compounds. Second — if we don't deliver consistent, high-quality content and a clear growth system in the first 30 days, we work for free until we do. You don't carry the risk."
  },
  {
    q: "Don't I just need better content?",
    a: "Better content helps. Better content without a system gets wasted. We've seen 6-figure-quality shoots die in the algorithm because there was no distribution plan, no posting cadence, no funnel underneath. We make sure everything you create actually contributes to growth — not the void."
  },
  {
    q: "Is this worth the investment?",
    a: "Most artists aren't lacking money — they're lacking a system that turns attention into growth. Right now you're already investing time, energy, and footage into content that isn't converting. We don't add a cost — we fix wasted effort and turn it into a growth multiplier. Bring it up on the call and we'll map the math to your numbers."
  },
];
---
<section class="faq" id="faq">
  <div class="container">
    <header class="faq-head">
      <p class="label" data-reveal="left">Common Questions</p>
      <h2 data-reveal>
        Before you book,<br/>
        <span class="glow-blue">here's what most artists ask.</span>
      </h2>
      <p class="lede" data-reveal>
        Real questions we hear on strategy calls. Real answers — same as we'd give you over a coffee.
      </p>
    </header>

    <div class="faq-list" data-reveal-group>
      {faqs.map((f, i) => (
        <details class="faq-item" data-reveal data-scroll-focus>
          <summary>
            <span class="faq-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="faq-q">{f.q}</span>
            <span class="faq-chev" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="faq-a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>

    <p class="faq-footnote" data-reveal>
      Still wondering something specific? <a href="#book">Bring it up on the call</a> — that's what it's for.
    </p>
  </div>
</section>

<style>
  .faq { padding: 5rem 0; position: relative; overflow: hidden; isolation: isolate; }

  .faq-head {
    max-width: 60ch;
    margin-bottom: 3rem;
  }
  .faq-head h2 { margin: 1rem 0 1rem; text-wrap: balance; }
  .faq-head .lede {
    color: var(--ink);
    opacity: 0.78;
    font-size: 1.05rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    max-width: 920px;
  }

  .faq-item {
    background: rgba(18, 19, 28, 0.78);
    backdrop-filter: blur(8px);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .faq-item[open] {
    border-color: rgba(98, 166, 219, 0.4);
    background: rgba(26, 28, 40, 0.85);
  }
  .faq-item:hover { border-color: rgba(98, 166, 219, 0.3); }

  summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.15rem 1.25rem;
    color: var(--ink);
  }
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }

  .faq-num {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    flex-shrink: 0;
    width: 2.5ch;
  }
  .faq-q {
    flex: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }
  .faq-chev {
    color: var(--bp-light);
    opacity: 0.7;
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(.2,.7,.3,1), opacity 0.3s;
  }
  .faq-item[open] .faq-chev { transform: rotate(180deg); opacity: 1; color: var(--bp-blue); }

  .faq-a {
    padding: 0 1.25rem 1.4rem calc(1.25rem + 2.5ch + 1.1rem);
    color: var(--ink);
    opacity: 0.86;
  }
  .faq-a p {
    font-size: 0.96rem;
    line-height: 1.55;
    max-width: 70ch;
  }

  .faq-footnote {
    margin-top: 2.5rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .faq-footnote a {
    color: var(--bp-light);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: color 0.15s;
  }
  .faq-footnote a:hover { color: var(--bp-blue); }

  @media (max-width: 600px) {
    .faq-q { font-size: 0.92rem; }
    .faq-a { padding-left: 1.25rem; padding-right: 1.25rem; }
  }
</style>
