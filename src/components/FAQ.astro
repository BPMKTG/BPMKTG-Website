---
import { Image } from 'astro:assets';
import { CALENDLY_URL } from '../config/cta';
import btsImage from '../assets/images/about-us/mason-bts.jpg';

// Objection-handling FAQ. Defaults to the homepage's 7 universal questions
// but accepts overrides via props so the same accordion can be reused on
// tier pages without duplicating any CSS / animation / scoped behavior.
//
// Pass faqs / eyebrow / headline / lede / footnote to customize. Anything
// omitted falls back to the homepage defaults.
//
// `showBtsImage` mounts the BTS photo to the LEFT of the questions
// on desktop (homepage uses true; tier + event pages default to false).
interface FaqItem { q: string; a: string; }
interface Props {
  faqs?: FaqItem[];
  eyebrow?: string;
  headline?: string;
  lede?: string;
  footnote?: string;
  showFootnote?: boolean;
  showBtsImage?: boolean;
}

const defaultFaqs: FaqItem[] = [
  {
    q: "Can't I just do this myself?",
    a: "You can. Plenty of artists do — and most of them stay stuck. The difference isn't effort, it's having a system behind the effort. DIY is slow and inconsistent because every post, every show, every release starts from zero. We build the system so growth compounds instead of starting over every time."
  },
  {
    q: "I've tried marketing before and it didn't work. Why is this different?",
    a: "Most agencies sell campaigns or content packages. Both run for 30–90 days and end. We don't run campaigns — we build infrastructure. Content, distribution, fan capture, and monetization stay running whether you're touring or in the studio. The system is the deliverable."
  },
  {
    q: "Won't this make my brand feel fake or forced?",
    a: "Opposite. We don't replace your creativity — we structure it so more people actually see it. Your voice, your shows, your music stay yours. We build the framework around them so the right people find them at the right moment."
  },
  {
    q: "I don't have time to add another thing to my plate.",
    a: "That's exactly why this works. We remove the need for you to think about what to post, when to post, or how to grow. You focus on music; we run the system behind it. Less mental load, not more."
  },
  {
    q: "What if it doesn't work?",
    a: "Two answers. First — we don't promise virality, we promise consistency and direction, which is what actually compounds. Second — if we don't deliver consistent, high-quality content and a clear growth system in the first 30 days, we work for free until we do. You don't carry the risk."
  },
  {
    q: "Don't I just need better content?",
    a: "Better content helps. Better content without a system gets wasted. We've seen 6-figure-quality shoots die in the algorithm because there was no distribution plan, no posting cadence, no funnel underneath. We make sure everything you create actually contributes to growth — not the void."
  },
  {
    q: "Is this worth the investment?",
    a: "Most artists aren't lacking money — they're lacking a system that turns attention into growth. Right now you're already investing time, energy, and footage into content that isn't converting. We don't add a cost — we fix wasted effort and turn it into a growth multiplier. Bring it up on the call and we'll map the math to your numbers."
  },
];

const {
  faqs = defaultFaqs,
  eyebrow = 'Common Questions',
  headline = 'Before you book,<br/><span class="glow-blue">here\'s what most artists ask.</span>',
  lede = 'Real questions we hear on strategy calls. Real answers — same as we\'d give you over a coffee or joint. Whichever you\'re into.',
  footnote = `Still wondering something specific? <a href="${CALENDLY_URL}" target="_blank" rel="noopener noreferrer">Bring it up on the call</a> — that's what it's for.`,
  showFootnote = true,
  showBtsImage = false,
} = Astro.props;
---
<section class="faq" id="faq">
  <div class="container">
    <div class={`faq-body ${showBtsImage ? 'has-bts' : ''}`}>
      <!-- LEFT column: header + accordion. Wrapped together so the
           right-side BTS photo vertically centers against the WHOLE
           combined block (header + list), not just the question list. -->
      <div class="faq-main">
        <header class="faq-head">
          <p class="label" data-reveal="left">{eyebrow}</p>
          <h2 data-reveal set:html={headline}></h2>
          <p class="lede" data-reveal>{lede}</p>
        </header>

        <div class="faq-list" data-reveal-group data-faq-list>
          {faqs.map((f, i) => (
            <details class="faq-item" data-reveal data-scroll-focus open={i === 0}>
              <summary>
                <span class="faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="faq-q">{f.q}</span>
                <span class="faq-chev" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </summary>
              <div class="faq-a"><p>{f.a}</p></div>
            </details>
          ))}
        </div>
      </div>

      <!-- RIGHT column: BTS photo, centered vertically against the
           combined header + list height via align-items: center. -->
      {showBtsImage && (
        <div class="faq-bts" data-reveal aria-hidden="true">
          <Image
            src={btsImage}
            alt=""
            width={900}
            height={1200}
            format="webp"
            quality={82}
            loading="lazy"
          />
          <div class="faq-bts-glow" aria-hidden="true"></div>
        </div>
      )}
    </div>

    {showFootnote && footnote && (
      <p class="faq-footnote" data-reveal set:html={footnote}></p>
    )}
  </div>
</section>

<script>
  // Accordion mode: only one FAQ item can be open at a time. Listens for
  // the native `toggle` event on every <details> inside a [data-faq-list]
  // container and closes the others when one is opened.
  const initFaqAccordion = () => {
    const lists = document.querySelectorAll<HTMLElement>('[data-faq-list]:not([data-mx-faq])');
    lists.forEach(list => {
      list.setAttribute('data-mx-faq', '1');
      const items = list.querySelectorAll<HTMLDetailsElement>('.faq-item');
      items.forEach(d => {
        d.addEventListener('toggle', () => {
          if (!d.open) return;
          items.forEach(other => {
            if (other !== d && other.open) other.open = false;
          });
        });
      });
    });
  };

  document.addEventListener('astro:page-load', initFaqAccordion);
  if (document.readyState !== 'loading') initFaqAccordion();
  else document.addEventListener('DOMContentLoaded', initFaqAccordion, { once: true });
</script>

<style>
  .faq { padding: 5rem 0; position: relative; overflow: hidden; isolation: isolate; }

  .faq-head {
    max-width: 60ch;
    margin-bottom: 2.5rem;
  }
  .faq-head h2 { margin: 1rem 0 1rem; text-wrap: balance; }
  .faq-head .lede {
    color: var(--ink);
    opacity: 0.78;
    font-size: 1.05rem;
  }

  /* Single-column when no BTS. Two-column with the BTS on the RIGHT
     when has-bts: the left column wraps header + accordion together,
     align-items: center vertically centers the BTS against that whole
     combined block (not just the question list). */
  .faq-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .faq-body.has-bts {
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 3rem;
    align-items: center;
  }
  .faq-main {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .faq-bts {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--card);
    box-shadow: 0 24px 50px -28px rgba(0, 0, 0, 0.7);
  }
  .faq-bts :global(img) {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Subtle blue light leak at the bottom of the BTS photo — matches the
     atmospheric tone of the rest of the section. */
  .faq-bts-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(80% 50% at 50% 100%, rgba(98, 166, 219, 0.18), transparent 60%);
    mix-blend-mode: screen;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .faq-photo {
    position: sticky;
    top: 6rem;
  }
  .faq-photo-img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    object-fit: cover;
    border: 1px solid rgba(98, 166, 219, 0.2);
    box-shadow: 0 8px 40px rgba(0,0,0,0.45);
  }

  @media (max-width: 900px) {
    .faq-body {
      grid-template-columns: 1fr;
    }
    .faq-photo {
      position: static;
      max-width: 480px;
      margin: 2rem auto 0;
    }
  }

  .faq-item {
    background: rgba(18, 19, 28, 0.78);
    backdrop-filter: blur(8px);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    transition: border-color 0.3s ease, background 0.3s ease;
  }
  .faq-item[open] {
    border-color: rgba(98, 166, 219, 0.4);
    background: rgba(26, 28, 40, 0.85);
  }
  .faq-item:hover { border-color: rgba(98, 166, 219, 0.3); }

  /* Blue accent line on the left of the expanded answer. Draws downward
     when the details element opens. */
  .faq-item::before {
    content: "";
    position: absolute;
    left: 0; top: 56px;
    width: 2px;
    height: 0;
    background: linear-gradient(180deg, var(--bp-blue), transparent);
    box-shadow: 0 0 8px rgba(98, 166, 219, 0.5);
    transition: height 0.55s cubic-bezier(0.2, 0.7, 0.3, 1) 0.1s,
                opacity  0.3s ease;
    opacity: 0;
    pointer-events: none;
  }
  .faq-item[open]::before {
    height: calc(100% - 70px);
    opacity: 1;
  }

  summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.15rem 1.25rem;
    color: var(--ink);
  }
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }

  .faq-num {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    flex-shrink: 0;
    width: 2.5ch;
  }
  .faq-q {
    flex: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.01em;
    line-height: 1.3;
    transition: color 0.25s ease;
  }
  /* Question text turns blue on hover before a click. */
  .faq-item:hover summary .faq-q,
  summary:hover .faq-q { color: var(--bp-blue); }

  .faq-chev {
    color: var(--bp-light);
    opacity: 0.7;
    flex-shrink: 0;
    transition: transform 0.55s cubic-bezier(0.34, 1.42, 0.5, 1),
                opacity 0.3s ease,
                color 0.25s ease;
  }
  .faq-item[open] .faq-chev { transform: rotate(180deg); opacity: 1; color: var(--bp-blue); }

  .faq-a {
    padding: 0 1.25rem 1.4rem calc(1.25rem + 2.5ch + 1.1rem);
    color: var(--ink);
    opacity: 0.86;
  }
  .faq-a p {
    font-size: 0.96rem;
    line-height: 1.55;
    max-width: 70ch;
  }

  /* Footnote restyled as a calm centered body line. Link uses bp-blue
     with an underline that's the same color rather than a hard chip. */
  .faq-footnote {
    margin-top: 2.75rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.95rem;
    font-family: var(--font-sans);
    line-height: 1.5;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .faq-footnote a {
    color: var(--bp-blue);
    text-decoration: underline;
    text-decoration-color: rgba(98, 166, 219, 0.5);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
    border-bottom: none;
    padding-bottom: 0;
  }
  .faq-footnote a:hover {
    color: var(--bp-light);
    text-decoration-color: var(--bp-light);
  }

  @media (max-width: 900px) {
    .faq-body.has-bts {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    /* Order swap so the BTS appears ABOVE the questions on mobile,
       even though the markup keeps faq-main first for desktop layout. */
    .faq-body.has-bts .faq-bts  { order: 0; aspect-ratio: 16 / 10; max-width: 520px; margin: 0 auto; }
    .faq-body.has-bts .faq-main { order: 1; }
  }
  @media (max-width: 600px) {
    .faq-q { font-size: 0.92rem; }
    .faq-a { padding-left: 1.25rem; padding-right: 1.25rem; }
  }
</style>
