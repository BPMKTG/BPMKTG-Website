---
const sub = [
  { title: 'Content Delivery',    body: 'You receive your agreed number of content pieces every month — no delays, no gaps.' },
  { title: 'Strategy Clarity',    body: "You'll never be left guessing what to post. A clear, structured plan at all times." },
  { title: 'A System You Keep',   body: "You don't just get content. You leave with a repeatable system you can run forever." },
];
---
<section class="guarantee bp-texture" id="guarantee">
  <div class="container">
    <div class="card" data-reveal="scale">
      <div class="card-inner">
        <p class="label" data-reveal="left">The Guarantee</p>
        <h2 data-reveal>
          If we don't deliver consistent, high-quality content and a clear growth system in <span class="guarantee-30">30&nbsp;days</span>, we work for free until we do.
        </h2>

        <div class="sub-grid" data-reveal-group>
          {sub.map(s => (
            <div class="sub" data-reveal>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="glow" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .guarantee { padding: 5rem 0; }
  .card {
    position: relative;
    border-radius: var(--radius-lg);
    padding: 3.5rem 2.5rem;
    background:
      linear-gradient(140deg, rgba(38, 79, 160, 0.22), rgba(10, 10, 15, 0.6)),
      var(--card-elev);
    border: 1px solid rgba(98, 166, 219, 0.3);
    overflow: hidden;
    /* Dramatic dual-color breathing — cycles between blue and orange
       over 4s. Border + shadow + a glow halo all pulse together. */
    animation: guaranteeBreath 4s ease-in-out infinite;
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
  }
  .card:hover {
    border-color: rgba(98, 166, 219, 0.7);
    box-shadow:
      0 0 0 1px rgba(98, 166, 219, 0.5),
      0 30px 70px -30px rgba(38, 79, 160, 0.6),
      inset 0 0 40px -10px rgba(98, 166, 219, 0.18);
  }
  @keyframes guaranteeBreath {
    0%, 100% {
      border-color: rgba(38, 79, 160, 0.5);
      box-shadow:
        0 0 0 1px rgba(38, 79, 160, 0.25),
        0 20px 60px -30px rgba(38, 79, 160, 0.45),
        inset 0 0 60px -20px rgba(38, 79, 160, 0.25);
    }
    50% {
      border-color: rgba(227, 112, 59, 0.5);
      box-shadow:
        0 0 0 1px rgba(227, 112, 59, 0.25),
        0 20px 60px -30px rgba(227, 112, 59, 0.45),
        inset 0 0 60px -20px rgba(227, 112, 59, 0.2);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .card { animation: none; }
  }
  .card-inner { position: relative; z-index: 2; }
  .glow {
    position: absolute;
    top: -120px; right: -120px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(227, 112, 59, 0.35), transparent 70%);
    filter: blur(60px);
    z-index: 1;
  }
  .card h2 {
    margin-top: 1rem;
    font-size: clamp(1.5rem, 3.2vw, 2.4rem);
    max-width: 28ch;
    line-height: 1.3;
    text-wrap: balance;
  }

  .sub-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .sub h3 {
    color: var(--bp-light);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    margin-bottom: 0.4rem;
  }
  .sub p { color: var(--ink); opacity: 0.78; font-size: 0.92rem; }

  /* "30 days" — slow breathing orange glow on the text itself. No
     movement, no sweep, just a calm 3s pulse on the text-shadow. */
  .guarantee-30 {
    color: var(--bp-orange);
    font-weight: 700;
    text-shadow: 0 0 12px rgba(227, 112, 59, 0.35);
    animation: guarantee30Glow 3s ease-in-out infinite;
  }
  @keyframes guarantee30Glow {
    0%, 100% { text-shadow: 0 0 8px  rgba(227, 112, 59, 0.25); }
    50%      { text-shadow: 0 0 22px rgba(227, 112, 59, 0.7); }
  }
  @media (prefers-reduced-motion: reduce) {
    .guarantee-30 { animation: none; text-shadow: 0 0 12px rgba(227, 112, 59, 0.4); }
  }

  @media (max-width: 760px) {
    .sub-grid { grid-template-columns: 1fr; }
    .card { padding: 2.5rem 1.5rem; }
  }
</style>
