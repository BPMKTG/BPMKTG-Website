---
import SpaceBg from './SpaceBg.astro';

const pillars = [
  { title: 'Content',      body: 'Your shows, releases, and existing footage turned into a high-output content engine.' },
  { title: 'Distribution', body: 'Platform-native posting, hooks, and EDM-trend alignment that actually reaches new fans.' },
  { title: 'Fan Capture',  body: 'Link-in-bio funnels, email + SMS capture, and audience-owning infrastructure.' },
  { title: 'Monetization', body: 'Streams, ticket sales, merch, and release campaigns that convert attention into revenue.' },
];
---
<section class="solution" id="solution">
  <SpaceBg tone="blue" density="medium" />
  <div class="container">
    <div class="solution-head">
      <p class="label" data-reveal="left">The Blueprint Approach</p>
      <h2 data-reveal>Not a content team.<br/>Not a marketing agency.<br/><span class="highlight">The growth system behind your career.</span></h2>
      <p class="lede" data-reveal>
        We don't manage your content. We build the growth infrastructure behind it —
        content, distribution, fan capture, and monetization, running as one system.
      </p>
    </div>

    <div class="pillars" data-reveal-group>
      {pillars.map((p, i) => (
        <article class="pillar" data-reveal>
          <span class="pillar-step">0{i + 1}</span>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .solution { padding: 5rem 0; position: relative; overflow: hidden; isolation: isolate; }
  /* Wide enough that the H2's longest sentence ("NOT A MARKETING AGENCY.")
     fits on a single line in Orbitron uppercase at the H2 clamp size. */
  .solution-head { max-width: 880px; }
  .solution-head h2 { margin-bottom: 1rem; }
  .lede { margin-top: 1rem; color: var(--ink); opacity: 0.72; font-size: 1.05rem; max-width: 64ch; }

  .pillars {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    background:
      linear-gradient(135deg, rgba(38, 79, 160, 0.18), rgba(98, 166, 219, 0.05)) padding-box,
      linear-gradient(135deg, rgba(98, 166, 219, 0.4), rgba(38, 79, 160, 0.1)) border-box;
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    padding: 1rem;
  }
  .pillar {
    background: var(--card);
    border-radius: 18px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }
  .pillar::before {
    content: "";
    position: absolute; inset: -1px;
    background: radial-gradient(120% 80% at 50% 0%, rgba(98, 166, 219, 0.25), transparent 60%);
    pointer-events: none;
  }
  .pillar > * { position: relative; z-index: 1; }
  .pillar-step {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
  }
  .pillar h3 { color: var(--ink); }
  .pillar p { color: var(--muted); font-size: 0.92rem; }

  @media (max-width: 880px) { .pillars { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .pillars { grid-template-columns: 1fr; } }
</style>
