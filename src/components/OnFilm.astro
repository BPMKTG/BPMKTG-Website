---
// On Film — portfolio page video section.
// Renders three tile groups (feature / recap / moment) using the shared
// <FilmTile> component, plus its own video lightbox.

import FilmTile from './FilmTile.astro';
import grimefestAfterMoviePoster from '../assets/images/hero/hero-3-grimefest-crowd-lightsaber.jpg';
import fluxPoster         from '../assets/images/thumbnails/fluxpavilion-multicam.jpg';
import grimefestPoster    from '../assets/images/thumbnails/grimefest-recap.jpg';
import wooliPoster        from '../assets/images/thumbnails/wooli-recap.jpg';
import dftPoster          from '../assets/images/thumbnails/dancefestopia-recap.jpg';
import martingarrixPoster from '../assets/images/thumbnails/martingarrix-recap.jpg';
import excisionPoster     from '../assets/images/thumbnails/excision-moment.jpg';
import blankfacePoster    from '../assets/images/portfolio/blankface-b2b-sqishi-surprised-grimefest.jpg';
import izzyvadimPoster    from '../assets/images/thumbnails/izzyvadim-multicam.jpg';
import diontimmerPoster   from '../assets/images/thumbnails/diontimmer-moment.jpg';
import levelupPoster      from '../assets/images/thumbnails/levelup-moment.jpg';

interface FilmTileData {
  slug: string;
  caption: string;
  tag: string;
  category: string;
  posterImg?: ImageMetadata;
  preview?: string;
  vimeoId?: string;
}

const afterMovie: FilmTileData = {
  slug: 'grimefest-aftermovie',
  caption: 'Grimefest The Galactic Wars II',
  tag: 'Festival',
  category: 'After Movie',
  posterImg: grimefestAfterMoviePoster,
  preview: '/videos/previews/grimefest-aftermovie.mp4',
  vimeoId: '1194846780',
};

const recaps: FilmTileData[] = [
  { slug: 'wooli-silo-recap',     caption: 'Wooli',                          tag: 'Silo - Dallas', category: 'Recap', posterImg: wooliPoster,        preview: '/videos/previews/wooli-silo-recap.mp4',     vimeoId: '1122000651' },
  { slug: 'dft-recap',            caption: 'Dancefestopia',                  tag: 'Festival',      category: 'Recap', posterImg: dftPoster,          preview: '/videos/previews/dft-recap.mp4',            vimeoId: '1122003465' },
  { slug: 'martingarrix-recap',   caption: 'Martin Garrix',                  tag: 'Wicked Oaks',   category: 'Recap', posterImg: martingarrixPoster, preview: '/videos/previews/martingarrix-recap.mp4',   vimeoId: '1132975664' },
  { slug: 'grimefest-day2-recap', caption: 'Grimefest The Galactic Wars II', tag: 'Festival',      category: 'Recap', posterImg: grimefestPoster,    preview: '/videos/previews/grimefest-day2-recap.mp4', vimeoId: '1194846332' },
];

const moments: FilmTileData[] = [
  { slug: 'flux-multicam',                caption: 'Flux Pavilion',        tag: 'Wicked Oaks',              category: 'Multicam', posterImg: fluxPoster,       preview: '/videos/previews/flux-multicam.mp4',               vimeoId: '1130704802' },
  { slug: 'excision-ns-14',               caption: 'Excision',             tag: '713 Music Hall - Houston', category: 'Moment',   posterImg: excisionPoster,   preview: '/videos/previews/excision-ns-14.mp4',              vimeoId: '1194847477' },
  { slug: 'blankface-sqishi-multicam-1',  caption: 'Blankface b2b Sqishi', tag: 'Grimefest',                category: 'Multicam', posterImg: blankfacePoster,  preview: '/videos/previews/blankface-sqishi-multicam-1.mp4', vimeoId: '1194847014' },
  { slug: 'diontimmer-moment',            caption: 'Dion Timmer',          tag: '713 Music Hall - Houston', category: 'Moment',   posterImg: diontimmerPoster, preview: '/videos/previews/diontimmer-moment.mp4',           vimeoId: '1194917343' },
  { slug: 'izzyvadim-multicam-2',         caption: 'Izzy Vadim',           tag: 'Grimefest',                category: 'Multicam', posterImg: izzyvadimPoster,  preview: '/videos/previews/izzyvadim-multicam-2.mp4',        vimeoId: '1194847204' },
  { slug: 'levelup-dft',                  caption: 'Level Up',             tag: 'Dancefestopia',            category: 'Moment',   posterImg: levelupPoster,    preview: '/videos/previews/levelup-dft.mp4',                 vimeoId: '1122346566' },
];
---
<section class="on-film" id="on-film">
  <div class="container">
    <header class="head">
      <p class="label" data-reveal="left">On Film</p>
      <h2 data-reveal>Motion.<br/>Multicam.<br/><span class="glow-blue">Moments.</span></h2>
      <p class="lede" data-reveal>
        Recap videos, multicam productions, and key moments captured from inside the scene.
      </p>
    </header>

    <div class="feature-block" data-reveal="scale">
      <FilmTile {...afterMovie} variant="feature" />
    </div>

    <header class="sub-head">
      <p class="sub-label" data-reveal="left">Recap Videos</p>
    </header>
    <div class="film-grid film-grid--four" data-reveal-group>
      {recaps.map(item => <FilmTile {...item} />)}
    </div>

    <header class="sub-head">
      <p class="sub-label" data-reveal="left">Video Moments</p>
    </header>
    <div class="film-grid film-grid--five" data-reveal-group>
      {moments.map(item => <FilmTile {...item} />)}
    </div>
  </div>
</section>

<!-- Video lightbox (separate from photo lightbox to keep concerns clean) -->
<dialog class="vlb" data-vlb>
  <button type="button" class="vlb-close" data-vlb-close aria-label="Close">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
      <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <figure class="vlb-figure">
    <div class="vlb-frame" data-vlb-frame></div>
    <figcaption class="vlb-caption" data-vlb-caption></figcaption>
  </figure>
</dialog>

<script>
  // ── Hover-play on tiles with a preview video ──
  document.querySelectorAll<HTMLElement>('[data-film-tile]').forEach(tile => {
    const video = tile.querySelector<HTMLVideoElement>('.hover-video');
    if (video) {
      let played = false;
      tile.addEventListener('pointerenter', () => {
        document.querySelectorAll<HTMLVideoElement>('.hover-video').forEach(v => {
          if (v !== video) { v.pause(); v.currentTime = 0; }
        });
        video.play().catch(() => {});
        played = true;
      });
      tile.addEventListener('pointerleave', () => {
        if (played) { video.pause(); video.currentTime = 0; played = false; }
      });
    }

    // ── Click → open video lightbox if the tile has a Vimeo ID ──
    const vimeoId = tile.dataset.vimeoId;
    if (vimeoId) {
      tile.addEventListener('click', () => {
        openVideoLightbox(vimeoId, tile.dataset.caption || '');
      });
    }
  });

  // ── Video lightbox ──
  const dialog = document.querySelector<HTMLDialogElement>('[data-vlb]');
  const frame  = dialog?.querySelector<HTMLElement>('[data-vlb-frame]');
  const capEl  = dialog?.querySelector<HTMLElement>('[data-vlb-caption]');

  function openVideoLightbox(vimeoId: string, caption: string) {
    if (!dialog || !frame) return;
    document.querySelectorAll<HTMLVideoElement>('.hover-video').forEach(v => v.pause());
    frame.innerHTML = `<iframe
      src="https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0&dnt=1"
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
      title="${caption}"></iframe>`;
    if (capEl) capEl.textContent = caption;
    if (typeof dialog.showModal === 'function') dialog.showModal();
    else dialog.setAttribute('open', '');
    document.body.style.overflow = 'hidden';
    const cursor = document.querySelector<HTMLElement>('.bp-cursor');
    if (cursor) dialog.appendChild(cursor);
  }
  function closeVideoLightbox() {
    if (!dialog || !frame) return;
    const cursor = document.querySelector<HTMLElement>('.bp-cursor');
    if (cursor) document.body.appendChild(cursor);
    if (typeof dialog.close === 'function') dialog.close();
    else dialog.removeAttribute('open');
    document.body.style.overflow = '';
    frame.innerHTML = ''; // Removes iframe → stops Vimeo playback
  }
  dialog?.querySelector('[data-vlb-close]')?.addEventListener('click', closeVideoLightbox);
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) closeVideoLightbox(); });
  dialog?.addEventListener('cancel', (e) => { e.preventDefault(); closeVideoLightbox(); });
</script>

<style>
  .on-film { padding: 6rem 0 4rem; }
  .head { max-width: 60ch; margin-bottom: 3rem; }
  .head h2 { margin: 1rem 0 1.25rem; }
  .head .lede { color: var(--ink); opacity: 0.78; font-size: 1.05rem; }

  .sub-head { margin: 3rem 0 1.25rem; }
  .sub-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--bp-light);
    font-family: var(--font-display);
  }
  .sub-label::before {
    content: "";
    width: 32px; height: 1px;
    background: var(--bp-blue);
    display: inline-block;
  }

  .feature-block { margin-bottom: 1.25rem; }

  .film-grid { display: grid; gap: 1rem; }
  .film-grid--four { grid-template-columns: repeat(4, 1fr); }
  .film-grid--five { grid-template-columns: repeat(6, 1fr); }

  @media (max-width: 1080px) {
    .film-grid--four { grid-template-columns: repeat(2, 1fr); }
    .film-grid--five { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .film-grid--four,
    .film-grid--five { grid-template-columns: repeat(2, 1fr); }
  }

  /* ═════════ VIDEO LIGHTBOX ═════════ */
  .vlb {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    color: #fff;
    overflow: visible;
  }
  .vlb::backdrop {
    background: rgba(5, 6, 12, 0.94);
    backdrop-filter: blur(14px);
  }
  .vlb[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: vlbFade 0.3s ease;
  }
  @keyframes vlbFade { from { opacity: 0; } to { opacity: 1; } }

  .vlb-figure {
    margin: 0;
    width: min(94vw, 1400px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    pointer-events: none;
  }
  .vlb-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.85),
                0 0 0 1px rgba(98, 166, 219, 0.2);
    pointer-events: auto;
  }
  /* `:global()` is required because the iframe is injected via JS,
     so it doesn't carry Astro's auto-scoped cid attribute and the normal
     scoped selector wouldn't match. */
  .vlb-frame :global(iframe) {
    width: 100% !important;
    height: 100% !important;
    border: 0;
    display: block;
  }
  .vlb-caption {
    color: var(--bp-light);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
    text-align: center;
    pointer-events: auto;
  }
  .vlb-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    background: rgba(15, 17, 25, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    width: 46px; height: 46px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    z-index: 10;
  }
  .vlb-close:hover {
    background: var(--bp-orange);
    border-color: var(--bp-orange);
    transform: scale(1.05);
  }
</style>
