---
// On Film — portfolio page video section.
// Each tile needs: caption (big), tag (small), category (corner badge),
// and optionally posterImg / preview / vimeoId once assets are produced.

import { Image } from 'astro:assets';
import fluxPoster from '../assets/images/thumbnails/fluxpavilion-multicam.jpg';

interface FilmTile {
  slug: string;
  caption: string;
  tag: string;
  category: string;
  posterImg?: ImageMetadata;  // imported from /src/assets/ — processed by Astro
  preview?: string;            // /public path to hover-preview MP4
  vimeoId?: string;            // numeric Vimeo ID for lightbox playback
}

const afterMovie: FilmTile = {
  slug: 'grimefest-aftermovie',
  caption: 'Grimefest',
  tag: 'Festival Recap',
  category: 'After Movie',
};

const recaps: FilmTile[] = [
  { slug: 'wooli-silo-recap',     caption: 'Wooli',           tag: 'Silo Dallas', category: 'Recap' },
  { slug: 'dft-recap',            caption: 'Dancefestopia',   tag: 'Festival',    category: 'Recap' },
  { slug: 'martingarrix-recap',   caption: 'Martin Garrix',   tag: 'Wicked Oaks', category: 'Recap' },
  { slug: 'grimefest-day2-recap', caption: 'Grimefest Day 2', tag: 'Festival',    category: 'Recap' },
];

const moments: FilmTile[] = [
  {
    slug: 'flux-multicam',
    caption: 'Flux Pavilion',
    tag: 'Wicked Oaks',
    category: 'Multicam',
    posterImg: fluxPoster,
    preview: '/videos/previews/flux-multicam.mp4',
    vimeoId: '1130704802',
  },
  { slug: 'excision-ns-14',               caption: 'Excision',             tag: '713 Music Hall - Houston', category: 'Moment' },
  { slug: 'blankface-sqishi-multicam-1',  caption: 'Blankface B2B Sqishi', tag: 'Grimefest',                category: 'Multicam' },
  { slug: 'diontimmer-moment',            caption: 'Dion Timmer',          tag: '713 Music Hall - Houston', category: 'Moment' },
  { slug: 'izzyvadim-multicam-2',         caption: 'Izzy Vadim',           tag: 'Grimefest',                category: 'Multicam' },
  { slug: 'levelup-dft',                  caption: 'Level Up',             tag: 'Dancefestopia',            category: 'Moment' },
];
---
<section class="on-film" id="on-film">
  <div class="container">
    <header class="head">
      <p class="label" data-reveal="left">On Film</p>
      <h2 data-reveal>Motion.<br/>Multicam.<br/><span class="glow-blue">Moments.</span></h2>
      <p class="lede" data-reveal>
        Recap videos, multicam productions, and key moments captured from inside the scene.
      </p>
    </header>

    <!-- ─────────── Featured After Movie ─────────── -->
    <div class="feature-block" data-reveal="scale">
      <button
        class="film-tile film-tile--feature"
        type="button"
        data-orientation="h"
        data-film-tile
        data-slug={afterMovie.slug}
        data-caption={`${afterMovie.caption} — ${afterMovie.tag}`}
        data-vimeo-id={afterMovie.vimeoId}
        aria-label={`Play ${afterMovie.caption} after movie`}
      >
        <span class="img-wrap">
          <span class="category-badge">{afterMovie.category}</span>
          {afterMovie.posterImg ? (
            <Image src={afterMovie.posterImg} alt={afterMovie.caption} width={1280} height={720} format="webp" quality={82} loading="lazy" />
          ) : (
            <span class="placeholder-bg" aria-hidden="true"></span>
          )}
          {afterMovie.preview && (
            <video class="hover-video" preload="metadata" muted playsinline loop>
              <source src={afterMovie.preview} type="video/mp4" />
            </video>
          )}
          <span class="tile-name">{afterMovie.caption}</span>
          <span class="play-overlay" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="56" height="56" fill="currentColor">
              <polygon points="9,5 27,16 9,27" />
            </svg>
          </span>
          <span class="hover-meta">
            <span class="meta-tag">{afterMovie.tag}</span>
            <strong>{afterMovie.caption}</strong>
          </span>
        </span>
      </button>
    </div>

    <!-- ─────────── Recap Videos ─────────── -->
    <header class="sub-head">
      <p class="sub-label" data-reveal="left">Recap Videos</p>
    </header>
    <div class="film-grid film-grid--four" data-reveal-group>
      {recaps.map(item => (
        <button
          class="film-tile"
          type="button"
          data-orientation="v"
          data-film-tile
          data-slug={item.slug}
          data-caption={`${item.caption} — ${item.tag}`}
          data-vimeo-id={item.vimeoId}
          data-reveal="scale"
          aria-label={`Play ${item.caption} recap`}
        >
          <span class="img-wrap">
            <span class="category-badge">{item.category}</span>
            {item.posterImg ? (
              <Image src={item.posterImg} alt={item.caption} width={720} height={1280} format="webp" quality={82} loading="lazy" />
            ) : (
              <span class="placeholder-bg" aria-hidden="true"></span>
            )}
            {item.preview && (
              <video class="hover-video" preload="metadata" muted playsinline loop>
                <source src={item.preview} type="video/mp4" />
              </video>
            )}
            <span class="tile-name">{item.caption}</span>
            <span class="play-overlay" aria-hidden="true">
              <svg viewBox="0 0 32 32" width="38" height="38" fill="currentColor">
                <polygon points="9,5 27,16 9,27" />
              </svg>
            </span>
            <span class="hover-meta">
              <span class="meta-tag">{item.tag}</span>
              <strong>{item.caption}</strong>
            </span>
          </span>
        </button>
      ))}
    </div>

    <!-- ─────────── Video Moments ─────────── -->
    <header class="sub-head">
      <p class="sub-label" data-reveal="left">Video Moments</p>
    </header>
    <div class="film-grid film-grid--five" data-reveal-group>
      {moments.map(item => (
        <button
          class="film-tile"
          type="button"
          data-orientation="v"
          data-film-tile
          data-slug={item.slug}
          data-caption={`${item.caption} — ${item.tag}`}
          data-vimeo-id={item.vimeoId}
          data-reveal="scale"
          aria-label={`Play ${item.caption} moment`}
        >
          <span class="img-wrap">
            <span class="category-badge">{item.category}</span>
            {item.posterImg ? (
              <Image src={item.posterImg} alt={item.caption} width={720} height={1280} format="webp" quality={82} loading="lazy" />
            ) : (
              <span class="placeholder-bg" aria-hidden="true"></span>
            )}
            {item.preview && (
              <video class="hover-video" preload="metadata" muted playsinline loop>
                <source src={item.preview} type="video/mp4" />
              </video>
            )}
            <span class="tile-name">{item.caption}</span>
            <span class="play-overlay" aria-hidden="true">
              <svg viewBox="0 0 32 32" width="38" height="38" fill="currentColor">
                <polygon points="9,5 27,16 9,27" />
              </svg>
            </span>
            <span class="hover-meta">
              <span class="meta-tag">{item.tag}</span>
              <strong>{item.caption}</strong>
            </span>
          </span>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Video lightbox (separate from photo lightbox to keep concerns clean) -->
<dialog class="vlb" data-vlb>
  <button type="button" class="vlb-close" data-vlb-close aria-label="Close">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
      <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
  <figure class="vlb-figure">
    <div class="vlb-frame" data-vlb-frame></div>
    <figcaption class="vlb-caption" data-vlb-caption></figcaption>
  </figure>
</dialog>

<script>
  // ── Hover-play on tiles with a preview video ──
  document.querySelectorAll<HTMLElement>('[data-film-tile]').forEach(tile => {
    const video = tile.querySelector<HTMLVideoElement>('.hover-video');
    if (video) {
      let played = false;
      tile.addEventListener('pointerenter', () => {
        document.querySelectorAll<HTMLVideoElement>('.hover-video').forEach(v => {
          if (v !== video) { v.pause(); v.currentTime = 0; }
        });
        video.play().catch(() => {});
        played = true;
      });
      tile.addEventListener('pointerleave', () => {
        if (played) { video.pause(); video.currentTime = 0; played = false; }
      });
    }

    // ── Click → open video lightbox if the tile has a Vimeo ID ──
    const vimeoId = tile.dataset.vimeoId;
    if (vimeoId) {
      tile.addEventListener('click', () => {
        openVideoLightbox(vimeoId, tile.dataset.caption || '');
      });
    }
  });

  // ── Video lightbox ──
  const dialog = document.querySelector<HTMLDialogElement>('[data-vlb]');
  const frame  = dialog?.querySelector<HTMLElement>('[data-vlb-frame]');
  const capEl  = dialog?.querySelector<HTMLElement>('[data-vlb-caption]');

  function openVideoLightbox(vimeoId: string, caption: string) {
    if (!dialog || !frame) return;
    document.querySelectorAll<HTMLVideoElement>('.hover-video').forEach(v => v.pause());
    frame.innerHTML = `<iframe
      src="https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&byline=0&portrait=0&dnt=1"
      allow="autoplay; fullscreen; picture-in-picture"
      allowfullscreen
      title="${caption}"></iframe>`;
    if (capEl) capEl.textContent = caption;
    if (typeof dialog.showModal === 'function') dialog.showModal();
    else dialog.setAttribute('open', '');
    document.body.style.overflow = 'hidden';
    const cursor = document.querySelector<HTMLElement>('.bp-cursor');
    if (cursor) dialog.appendChild(cursor);
  }
  function closeVideoLightbox() {
    if (!dialog || !frame) return;
    const cursor = document.querySelector<HTMLElement>('.bp-cursor');
    if (cursor) document.body.appendChild(cursor);
    if (typeof dialog.close === 'function') dialog.close();
    else dialog.removeAttribute('open');
    document.body.style.overflow = '';
    frame.innerHTML = ''; // Removes iframe → stops Vimeo playback
  }
  dialog?.querySelector('[data-vlb-close]')?.addEventListener('click', closeVideoLightbox);
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) closeVideoLightbox(); });
  dialog?.addEventListener('cancel', (e) => { e.preventDefault(); closeVideoLightbox(); });
</script>

<style>
  .on-film { padding: 6rem 0 4rem; }
  .head { max-width: 60ch; margin-bottom: 3rem; }
  .head h2 { margin: 1rem 0 1.25rem; }
  .head .lede { color: var(--ink); opacity: 0.78; font-size: 1.05rem; }

  .sub-head { margin: 3rem 0 1.25rem; }
  .sub-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--bp-light);
    font-family: var(--font-display);
  }
  .sub-label::before {
    content: "";
    width: 32px; height: 1px;
    background: var(--bp-blue);
    display: inline-block;
  }

  .feature-block { margin-bottom: 1.25rem; }

  .film-grid { display: grid; gap: 1rem; }
  .film-grid--four { grid-template-columns: repeat(4, 1fr); }
  .film-grid--five { grid-template-columns: repeat(6, 1fr); }

  /* ── Tile shared styles ── */
  .film-tile {
    margin: 0;
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
    display: block;
    width: 100%;
  }
  .film-tile .img-wrap {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 16px;
    background: #0d111c;
    border: 1px solid var(--line);
    aspect-ratio: 9 / 16;
    transition: border-color 0.3s ease, transform 0.4s cubic-bezier(.2,.7,.3,1), box-shadow 0.3s ease;
  }
  .film-tile--feature .img-wrap,
  .film-tile[data-orientation="h"] .img-wrap { aspect-ratio: 16 / 9; }

  .film-tile:hover .img-wrap,
  .film-tile:focus-visible .img-wrap {
    transform: translateY(-3px);
    border-color: rgba(98, 166, 219, 0.55);
    box-shadow: 0 18px 44px -22px rgba(0, 0, 0, 0.7);
  }

  .film-tile .img-wrap > img,
  .film-tile .img-wrap .hover-video {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Video sits on top of the poster but stays invisible until hover, so the
     poster owns the static state. Fades in over the poster on hover. */
  .film-tile .hover-video {
    z-index: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .film-tile:hover .hover-video,
  .film-tile:focus-visible .hover-video { opacity: 1; }

  /* ── Background layer when no poster is set ── */
  .placeholder-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 80% at 30% 30%, rgba(98, 166, 219, 0.18), transparent 60%),
      radial-gradient(100% 80% at 80% 80%, rgba(38, 79, 160, 0.22), transparent 60%),
      linear-gradient(135deg, #0d111c 0%, #161a26 100%);
  }
  .placeholder-bg::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 26px 26px;
    mask-image: radial-gradient(70% 70% at 50% 50%, #000 30%, transparent 100%);
    pointer-events: none;
  }

  /* ── Always-visible centered artist name (works over poster OR placeholder).
        Fades out on hover so the video preview isn't obscured. ── */
  .tile-name {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    text-align: center;
    z-index: 2;
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    font-size: clamp(0.95rem, 1.7vw, 1.4rem);
    font-weight: 800;
    line-height: 1.05;
    max-width: 14ch;
    margin: 0 auto;
    /* Strong shadow so it reads over any background image */
    text-shadow:
      0 2px 18px rgba(0, 0, 0, 0.9),
      0 0 6px rgba(0, 0, 0, 0.6);
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(.2,.7,.3,1),
                transform 0.4s cubic-bezier(.2,.7,.3,1);
  }
  .film-tile--feature .tile-name {
    font-size: clamp(2rem, 4vw, 3.5rem);
    max-width: 18ch;
  }
  /* On hover the centered name fades so the video plays cleanly. The
     hover-meta at the bottom takes over labeling. */
  .film-tile:hover .tile-name,
  .film-tile:focus-visible .tile-name {
    opacity: 0;
    transform: scale(0.96);
  }

  /* ── Always-visible category badge (top-left corner) ── */
  .category-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 4;
    padding: 0.32rem 0.7rem;
    border: 1px solid rgba(98, 166, 219, 0.5);
    border-radius: 999px;
    background: rgba(10, 10, 15, 0.75);
    backdrop-filter: blur(6px);
    color: var(--bp-light);
    font-family: var(--font-display);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    pointer-events: none;
  }
  .film-tile--feature .category-badge {
    top: 1.25rem;
    left: 1.25rem;
    font-size: 0.72rem;
    padding: 0.42rem 0.9rem;
  }

  /* ── Play overlay (centered triangle) — hidden by default so the static
     state shows only the artist name. Swaps in as the name fades on hover. ── */
  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--bp-orange);
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.4s cubic-bezier(.2,.7,.3,1),
                transform 0.4s cubic-bezier(.2,.7,.3,1);
    filter: drop-shadow(0 4px 14px rgba(0, 0, 0, 0.7));
  }
  .film-tile:hover .play-overlay,
  .film-tile:focus-visible .play-overlay {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Hover-meta caption (bottom slide-up) ── */
  .hover-meta {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 2.2rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: linear-gradient(to top, rgba(10,10,15,0.94), rgba(10,10,15,0) 100%);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s cubic-bezier(.2,.7,.3,1),
                transform 0.4s cubic-bezier(.2,.7,.3,1);
    pointer-events: none;
    z-index: 3;
  }
  .film-tile:hover .hover-meta,
  .film-tile:focus-visible .hover-meta {
    opacity: 1;
    transform: translateY(0);
  }
  .hover-meta .meta-tag {
    color: var(--bp-blue);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .hover-meta strong {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 0.95rem;
    font-weight: 700;
  }

  /* ── Scale-reveal pattern for tiles ── */
  .film-tile[data-reveal="scale"] {
    opacity: 0;
    transform: translateY(36px) scale(0.92);
    transition:
      opacity 1s cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0s),
      transform 1s cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0s);
  }
  .film-tile[data-reveal="scale"].is-in {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .film-tile[data-reveal="scale"] { opacity: 1; transform: none; transition: none; }
  }

  /* ── Responsive ── */
  @media (max-width: 1080px) {
    .film-grid--four { grid-template-columns: repeat(2, 1fr); }
    .film-grid--five { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .film-grid--four,
    .film-grid--five { grid-template-columns: repeat(2, 1fr); }
  }

  /* ═════════ VIDEO LIGHTBOX ═════════ */
  .vlb {
    background: transparent;
    border: none;
    padding: 0;
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    color: #fff;
    overflow: visible;
  }
  .vlb::backdrop {
    background: rgba(5, 6, 12, 0.94);
    backdrop-filter: blur(14px);
  }
  .vlb[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: vlbFade 0.3s ease;
  }
  @keyframes vlbFade { from { opacity: 0; } to { opacity: 1; } }

  .vlb-figure {
    margin: 0;
    width: min(94vw, 1400px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem;
    pointer-events: none;
  }
  .vlb-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.85),
                0 0 0 1px rgba(98, 166, 219, 0.2);
    pointer-events: auto;
  }
  /* `:global()` is required because the iframe is injected via JS,
     so it doesn't carry Astro's auto-scoped cid attribute and the normal
     scoped selector wouldn't match. */
  .vlb-frame :global(iframe) {
    width: 100% !important;
    height: 100% !important;
    border: 0;
    display: block;
  }
  .vlb-caption {
    color: var(--bp-light);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
    text-align: center;
    pointer-events: auto;
  }
  .vlb-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    background: rgba(15, 17, 25, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.18);
    color: #fff;
    width: 46px; height: 46px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    z-index: 10;
  }
  .vlb-close:hover {
    background: var(--bp-orange);
    border-color: var(--bp-orange);
    transform: scale(1.05);
  }
</style>
