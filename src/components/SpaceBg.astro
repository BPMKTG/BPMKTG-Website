---
// SpaceBg — atmospheric cosmic backdrop for sections that would otherwise
// feel flat. Pure CSS + SVG (SMIL for drift); no JS, no canvas, so it scales
// across many instances on a page with negligible cost.
//
// Layers:
//   - Twinkling star dots (SVG <pattern>, tiled; drift via SMIL patternTransform,
//     twinkle via CSS opacity on the rect)
//   - Drifting nebula glows (large CSS radial gradients, blurred)
//   - Faint blueprint grid (optional, radial-masked)
//   - Shooting stars (optional thin streaks, used sparingly)
//
// Props:
//   tone     — 'mixed' (default, blue) | 'blue' | 'deep' | 'warm' | 'orange'
//   density  — 'low' | 'medium' (default) | 'high'
//   grid     — boolean, default true
//   shooting — boolean, default false
//
// Each instance generates unique pattern IDs so multiple SpaceBgs on one page
// can each carry their own SMIL animation without ID collisions.
interface Props {
  tone?: 'mixed' | 'blue' | 'deep' | 'warm' | 'orange';
  density?: 'low' | 'medium' | 'high';
  grid?: boolean;
  shooting?: boolean;
}
const { tone = 'mixed', density = 'medium', grid = true, shooting = false } = Astro.props;
const uid = Math.random().toString(36).slice(2, 9);
const idA = `sb-dots-a-${uid}`;
const idB = `sb-dots-b-${uid}`;
---
<div class={`space-bg sb-tone-${tone} sb-density-${density}`} aria-hidden="true">
  <svg class="sb-stars" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
    <defs>
      <pattern id={idA} x="0" y="0" width="280" height="280" patternUnits="userSpaceOnUse">
        <animateTransform attributeName="patternTransform" type="translate" from="0 0" to="280 140" dur="160s" repeatCount="indefinite"/>
        <circle cx="14"  cy="22"  r="0.9"  fill="#ffffff" opacity="0.85"/>
        <circle cx="60"  cy="68"  r="0.55" fill="#b3e0f6" opacity="0.6"/>
        <circle cx="118" cy="40"  r="1.1"  fill="#ffffff" opacity="0.9"/>
        <circle cx="178" cy="148" r="0.5"  fill="#ffffff" opacity="0.5"/>
        <circle cx="240" cy="80"  r="0.7"  fill="#62a6db" opacity="0.75"/>
        <circle cx="42"  cy="118" r="0.4"  fill="#ffffff" opacity="0.4"/>
        <circle cx="202" cy="222" r="0.8"  fill="#ffffff" opacity="0.75"/>
        <circle cx="100" cy="198" r="1.3"  fill="#ffffff" opacity="0.95"/>
        <circle cx="258" cy="178" r="0.5"  fill="#b3e0f6" opacity="0.55"/>
        <circle cx="22"  cy="248" r="0.6"  fill="#ffffff" opacity="0.65"/>
        <circle cx="160" cy="98"  r="0.4"  fill="#ffffff" opacity="0.45"/>
        <circle cx="82"  cy="160" r="0.85" fill="#ffffff" opacity="0.8"/>
      </pattern>
      <pattern id={idB} x="0" y="0" width="200" height="200" patternUnits="userSpaceOnUse">
        <animateTransform attributeName="patternTransform" type="translate" from="0 0" to="-200 100" dur="220s" repeatCount="indefinite"/>
        <circle cx="32"  cy="38"  r="0.4"  fill="#ffffff" opacity="0.5"/>
        <circle cx="108" cy="22"  r="0.5"  fill="#ffffff" opacity="0.55"/>
        <circle cx="170" cy="92"  r="0.3"  fill="#ffffff" opacity="0.4"/>
        <circle cx="62"  cy="118" r="0.6"  fill="#62a6db" opacity="0.55"/>
        <circle cx="138" cy="150" r="0.4"  fill="#ffffff" opacity="0.5"/>
        <circle cx="80"  cy="178" r="0.5"  fill="#b3e0f6" opacity="0.6"/>
        <circle cx="180" cy="170" r="0.35" fill="#ffffff" opacity="0.45"/>
        <circle cx="20"  cy="78"  r="0.4"  fill="#ffffff" opacity="0.5"/>
      </pattern>
    </defs>
    <rect class="sb-rect sb-rect--a" width="100%" height="100%" fill={`url(#${idA})`}/>
    <rect class="sb-rect sb-rect--b" width="100%" height="100%" fill={`url(#${idB})`}/>
  </svg>

  <div class="sb-nebula sb-nebula--a"></div>
  <div class="sb-nebula sb-nebula--b"></div>

  {grid && <div class="sb-grid"></div>}

  {shooting && (
    <>
      <span class="sb-shoot sb-shoot--1"></span>
      <span class="sb-shoot sb-shoot--2"></span>
      <span class="sb-shoot sb-shoot--3"></span>
    </>
  )}
</div>

<style>
  /* z-index: -1 keeps the bg behind ALL section content. Host section must
     be `position: relative; isolation: isolate; overflow: hidden;` so the
     negative z-index stays scoped and the bg can't escape the section. */
  .space-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  /* ── Star layers (tiled SVG patterns, twinkle via CSS opacity) ── */
  .sb-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .sb-rect--a { animation: sb-twinkle-a 6s ease-in-out infinite; transform-origin: center; }
  .sb-rect--b { animation: sb-twinkle-b 9s ease-in-out infinite 1.5s; opacity: 0.65; transform-origin: center; }
  @keyframes sb-twinkle-a {
    0%, 100% { opacity: 0.9; }
    50%      { opacity: 0.55; }
  }
  @keyframes sb-twinkle-b {
    0%, 100% { opacity: 0.65; }
    50%      { opacity: 0.3; }
  }

  /* Density variants */
  .sb-density-low .sb-rect--a { opacity: 0.55; }
  .sb-density-low .sb-rect--b { display: none; }
  .sb-density-high .sb-rect--a { opacity: 1; }
  .sb-density-high .sb-rect--b { opacity: 0.85; }

  /* ── Nebula glows ── */
  .sb-nebula {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform;
  }
  .sb-nebula--a {
    width: 540px; height: 540px;
    top: -160px; left: -120px;
    background: radial-gradient(circle, rgba(38,79,160,0.40), transparent 70%);
    animation: sb-drift-a 28s ease-in-out infinite alternate;
  }
  .sb-nebula--b {
    width: 480px; height: 480px;
    bottom: -180px; right: -140px;
    background: radial-gradient(circle, rgba(98,166,219,0.32), transparent 70%);
    animation: sb-drift-b 35s ease-in-out infinite alternate;
  }
  @keyframes sb-drift-a {
    from { transform: translate(0, 0)   scale(1); }
    to   { transform: translate(70px, 50px) scale(1.05); }
  }
  @keyframes sb-drift-b {
    from { transform: translate(0, 0)   scale(1); }
    to   { transform: translate(-60px, -70px) scale(1.04); }
  }

  /* Tone variants — recolor the two nebulas */
  .sb-tone-blue   .sb-nebula--a { background: radial-gradient(circle, rgba(98,166,219,0.32), transparent 70%); }
  .sb-tone-blue   .sb-nebula--b { background: radial-gradient(circle, rgba(38,79,160,0.28),  transparent 70%); }
  .sb-tone-deep   .sb-nebula--a { background: radial-gradient(circle, rgba(20,40,90,0.55),    transparent 70%); }
  .sb-tone-deep   .sb-nebula--b { background: radial-gradient(circle, rgba(38,79,160,0.40),  transparent 70%); }
  .sb-tone-warm   .sb-nebula--a { background: radial-gradient(circle, rgba(227,112,59,0.22), transparent 70%); }
  .sb-tone-warm   .sb-nebula--b { background: radial-gradient(circle, rgba(38,79,160,0.28),  transparent 70%); }
  .sb-tone-orange .sb-nebula--a { background: radial-gradient(circle, rgba(227,112,59,0.35), transparent 70%); }
  .sb-tone-orange .sb-nebula--b { background: radial-gradient(circle, rgba(180,80,40,0.25),  transparent 70%); }

  /* ── Blueprint grid ── */
  .sb-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(70% 70% at 50% 50%, #000 30%, transparent 100%);
  }

  /* ── Shooting stars (thin diagonal streaks, sparingly) ── */
  .sb-shoot {
    position: absolute;
    width: 140px; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.85), transparent);
    transform: rotate(-22deg);
    opacity: 0;
    will-change: transform, opacity;
  }
  .sb-shoot--1 { top: 18%; left: -160px; animation: sb-shoot 9s  ease-out infinite 2s;  }
  .sb-shoot--2 { top: 62%; left: -160px; animation: sb-shoot 12s ease-out infinite 6s;  }
  .sb-shoot--3 { top: 35%; left: -160px; animation: sb-shoot 15s ease-out infinite 11s; width: 200px; }
  @keyframes sb-shoot {
    0%   { transform: translate(0, 0)      rotate(-22deg); opacity: 0; }
    5%   { opacity: 0.9; }
    22%  { opacity: 0; }
    100% { transform: translate(120vw, 40vh) rotate(-22deg); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-rect, .sb-nebula, .sb-shoot { animation: none !important; }
    .sb-shoot { display: none; }
  }
</style>
