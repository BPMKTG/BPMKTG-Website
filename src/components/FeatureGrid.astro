---
interface Feature {
  title: string;
  body: string;
}
interface Props {
  features: Feature[];
  eyebrow?: string;
  heading?: string;
}
const { features, eyebrow, heading } = Astro.props;
---
<section class="section feature-section">
  <div class="container">
    {(eyebrow || heading) && (
      <header class="feature-header">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {heading && <h2>{heading}</h2>}
      </header>
    )}
    <div class="grid">
      {features.map(f => (
        <article class="card">
          <h3>{f.title}</h3>
          <p>{f.body}</p>
          <span class="card-arrow" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M7 17L17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-section { padding: 1rem 0 4rem; }
  .feature-header { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; max-width: 32ch; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.85rem;
  }
  .card {
    background: var(--color-card);
    color: var(--color-text);
    border-radius: var(--radius);
    padding: 1.5rem 1.5rem 1.75rem;
    position: relative;
    min-height: 180px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .card:hover { background: var(--color-card-2); transform: translateY(-2px); }
  .card h3 { color: #fff; font-weight: 700; }
  .card p { color: var(--color-muted); font-size: 0.95rem; }
  .card-arrow {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    color: var(--color-accent);
  }
</style>
