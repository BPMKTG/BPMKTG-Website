---
const steps = [
  { num: '1.', title: 'Discovery', subtitle: 'We Audit The Assets', body: "We analyze your brand, market, and competition. If there's potential to disrupt, we accept the engagement and prepare the blueprint." },
  { num: '2.', title: 'The Blueprint', subtitle: 'We Engineer The Path', body: 'We map the funnel — targets, creative, automation flows — and offer the structure needed to hit your goals and KPIs.' },
  { num: '3.', title: 'Launch', subtitle: 'We Build The Machine', body: 'We flip the switch and monetize your audience. You stop chasing leads and start running a business that compounds.' },
];
---
<section class="process">
  <div class="container">
    <header class="process-header">
      <h2>The Process</h2>
      <p>
        Once we know we're a good fit, we tailor a plan with accurate strategies
        to expand your brand and revenue. Whether it's a launch, rebrand, or
        full-funnel rebuild, we cover every base.
      </p>
    </header>

    <div class="steps">
      {steps.map(s => (
        <article class="step">
          <span class="num">{s.num}</span>
          <h3>{s.title}</h3>
          <p class="sub">{s.subtitle}</p>
          <p class="body">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process { padding: 4rem 0; }
  .process-header { text-align: center; max-width: 60ch; margin: 0 auto 2.5rem; }
  .process-header h2 { margin-bottom: 1rem; }
  .process-header p { color: var(--bp-muted); }

  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  .step {
    background: var(--bp-deep);
    color: #fff;
    padding: 1.75rem;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    overflow: hidden;
  }
  .step::before {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(80% 80% at 100% 0%, #000 30%, transparent 100%);
  }
  .step > * { position: relative; z-index: 2; }
  .num {
    color: var(--bp-orange);
    font-weight: 900;
    font-size: 1.2rem;
  }
  .step h3 {
    font-size: 1.85rem;
    text-transform: uppercase;
    line-height: 1;
    color: #fff;
  }
  .sub {
    color: var(--bp-light);
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 0.4rem;
  }
  .body { color: rgba(255,255,255,0.78); font-size: 0.95rem; }

  @media (max-width: 820px) { .steps { grid-template-columns: 1fr; } }
</style>
