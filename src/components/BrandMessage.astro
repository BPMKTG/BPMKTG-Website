---
// Brand Message Video — homepage section under the Artist Marquee.
import { Image } from 'astro:assets';
import bmvPoster from '../assets/images/thumbnails/BMV v1 Horizontal.jpg';

const vimeoId: string | null = '1196578279';   // Brand Message Video (Vimeo)
const videoSrc: string | null = null;          // self-hosted fallback: '/videos/brand-message.mp4'
---
<section class="brand-message" id="brand-message">
  <div class="container bmv-grid">
    <header class="head">
      <p class="label" data-reveal="left">The Manifesto</p>
      <h2 data-reveal>
        You're doing everything right.<br/>
        <span class="highlight">And still wondering why nothing's breaking through.</span>
      </h2>
      <p class="lede" data-reveal>
        Two minutes on why systems beat hustle in the scene that moves fastest — and what it actually takes to make your music, brand, and audience move in sync.
      </p>
    </header>

    <div class="bmv-stage" data-reveal="scale">
      {videoSrc && !vimeoId ? (
        <video class="bmv-player" controls playsinline>
          <source src={videoSrc} type="video/mp4" />
        </video>
      ) : (
        <button
          type="button"
          class="bmv-placeholder"
          data-bmv-placeholder
          data-bmv-vimeo={vimeoId ?? ''}
          aria-label="Play the Blueprint Marketing manifesto video"
        >
          <Image class="bmv-poster" src={bmvPoster} alt="" widths={[640, 960, 1280]} sizes="(max-width: 920px) 90vw, 55vw" loading="lazy" />
          <span class="bmv-shade" aria-hidden="true"></span>
          <span class="bmv-content">
            <span class="bmv-pill">{vimeoId ? '2 Min Watch' : 'Coming Soon'}</span>
            <span class="bmv-play" aria-hidden="true">
              <svg viewBox="0 0 32 32" width="72" height="72" fill="currentColor">
                <polygon points="9,5 27,16 9,27" />
              </svg>
            </span>
          </span>
        </button>
      )}
    </div>

  </div>

  <div class="container bmv-cta" data-reveal>
      <a href="#book" class="button">
        Skip the video, book the call
        <span class="arrow" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
</section>

<script>
  // Click-to-play: keep the branded poster, then swap in the autoplaying
  // Vimeo player (branding stripped) on click. Idempotent across view
  // transitions.
  function initBMV() {
    document.querySelectorAll('[data-bmv-placeholder]').forEach(el => {
      const btn = el as HTMLButtonElement;
      if (btn.dataset.bmvBound) return;
      const id = btn.getAttribute('data-bmv-vimeo');
      if (!id) return;                       // no video yet -> stays a poster
      btn.dataset.bmvBound = '1';
      btn.addEventListener('click', () => {
        const iframe = document.createElement('iframe');
        iframe.className = 'bmv-player';
        // Inline sizing: this element is created in JS so it carries no Astro
        // scoped-style attribute, so the scoped .bmv-player CSS won't match it.
        iframe.style.cssText = 'display:block;width:100%;height:100%;border:0;background:#000;';
        iframe.src = `https://player.vimeo.com/video/${id}?autoplay=1&title=0&byline=0&portrait=0&dnt=1`;
        iframe.allow = 'autoplay; fullscreen; picture-in-picture';
        iframe.setAttribute('allowfullscreen', '');
        iframe.title = 'Blueprint Marketing — Brand Message';
        btn.replaceWith(iframe);
      });
    });
  }
  document.addEventListener('astro:page-load', initBMV);
  if (document.readyState !== 'loading') initBMV();
  else document.addEventListener('DOMContentLoaded', initBMV, { once: true });
</script>

<style>
  .brand-message {
    padding: 5rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  /* Two-column spread: text left, video right. Stacks on narrow viewports. */
  .bmv-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: 3.5rem;
    align-items: center;
  }
  @media (max-width: 920px) {
    .bmv-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .head { max-width: 50ch; }
  .head h2 { margin: 1rem 0 1.25rem; text-wrap: balance; }
  .head .lede {
    color: var(--ink);
    opacity: 0.78;
    font-size: 1.05rem;
    max-width: 50ch;
  }

  .bmv-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;        /* defines the box; children fill it */
    border-radius: 24px;
    overflow: hidden;
    background: #05060a;
    box-shadow:
      0 30px 80px -30px rgba(0, 0, 0, 0.75),
      0 0 0 1px rgba(98, 166, 219, 0.25);
  }

  /* ── Player (Vimeo iframe / self-hosted) fills the stage ── */
  .bmv-player {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: #000;
  }

  /* ── Placeholder (thumbnail + play) fills the stage ── */
  .bmv-placeholder {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    cursor: pointer;
    color: inherit;
    overflow: hidden;
    background: #0d111c;
    isolation: isolate;
  }
  .bmv-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .bmv-shade {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(60% 60% at 50% 45%, rgba(5,6,10,0.15), rgba(5,6,10,0.55) 100%),
      linear-gradient(180deg, rgba(5,6,10,0.1) 0%, rgba(5,6,10,0.55) 100%);
    transition: background 0.3s;
  }
  .bmv-placeholder:hover .bmv-shade,
  .bmv-placeholder:focus-visible .bmv-shade {
    background:
      radial-gradient(60% 60% at 50% 45%, rgba(5,6,10,0.05), rgba(5,6,10,0.45) 100%),
      linear-gradient(180deg, rgba(5,6,10,0.05) 0%, rgba(5,6,10,0.45) 100%);
  }

  .bmv-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 2rem;
    text-align: center;
  }
  .bmv-pill {
    padding: 0.4rem 0.9rem;
    border: 1px solid rgba(98, 166, 219, 0.5);
    border-radius: 999px;
    color: var(--bp-light);
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .bmv-play {
    color: rgba(255, 255, 255, 0.92);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: rgba(10, 10, 15, 0.55);
    border: 1px solid rgba(98, 166, 219, 0.4);
    backdrop-filter: blur(6px);
    transition: transform 0.3s cubic-bezier(.2,.7,.3,1), color 0.3s, background 0.3s, border-color 0.3s;
    filter: drop-shadow(0 8px 28px rgba(0, 0, 0, 0.5));
  }
  .bmv-placeholder:hover .bmv-play,
  .bmv-placeholder:focus-visible .bmv-play {
    transform: scale(1.08);
    color: var(--bp-orange);
    background: rgba(227, 112, 59, 0.18);
    border-color: var(--bp-orange);
  }
  .bmv-caption {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 800;
  }
  .bmv-subcaption {
    color: var(--bp-light);
    font-style: italic;
    font-size: 0.95rem;
    max-width: 44ch;
    opacity: 0.85;
  }

  .bmv-cta {
    text-align: center;
    margin-top: 3rem;
  }
  .bmv-cta .button { background: transparent; border: 1px solid rgba(255,255,255,0.18); }
  .bmv-cta .button:hover { background: rgba(255,255,255,0.06); }

  @media (max-width: 700px) {
    .bmv-play { width: 80px; height: 80px; }
    .bmv-play svg { width: 48px; height: 48px; }
  }
</style>
