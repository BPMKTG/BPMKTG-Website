---
// Brand Message Video — homepage section under the Artist Marquee.
// Scaffolded with a placeholder player. When the final video is ready, drop
// the Vimeo ID into `vimeoId` (or set `videoSrc` for self-hosted) and the
// markup below picks it up automatically.

const vimeoId: string | null = null;          // e.g. '123456789'
const videoSrc: string | null = null;          // self-hosted fallback: '/videos/brand-message.mp4'
const poster: string | null = null;            // optional: '/videos/posters/brand-message.jpg'
---
<section class="brand-message" id="brand-message">
  <div class="container">
    <header class="head">
      <p class="label" data-reveal="left">The Manifesto</p>
      <h2 data-reveal>
        You're doing everything right.<br/>
        <span class="highlight">And still wondering why nothing's breaking through.</span>
      </h2>
      <p class="lede" data-reveal>
        Two minutes on why systems beat hustle in the scene that moves fastest — and what it actually takes to make your music, brand, and audience move in sync.
      </p>
    </header>

    <div class="bmv-stage" data-reveal="scale">
      {vimeoId ? (
        <div class="bmv-player">
          <iframe
            src={`https://player.vimeo.com/video/${vimeoId}?title=0&byline=0&portrait=0&dnt=1`}
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            title="Blueprint Marketing — Brand Message"
          ></iframe>
        </div>
      ) : videoSrc ? (
        <video class="bmv-player" controls playsinline poster={poster ?? undefined}>
          <source src={videoSrc} type="video/mp4" />
        </video>
      ) : (
        <button type="button" class="bmv-placeholder" data-bmv-placeholder>
          <span class="bmv-bg" aria-hidden="true"></span>
          <span class="bmv-content">
            <span class="bmv-pill">Coming Soon</span>
            <span class="bmv-play" aria-hidden="true">
              <svg viewBox="0 0 32 32" width="72" height="72" fill="currentColor">
                <polygon points="9,5 27,16 9,27" />
              </svg>
            </span>
            <span class="bmv-caption">Blueprint Marketing — The Manifesto</span>
            <span class="bmv-subcaption">Where creativity meets clarity, and your vision turns into momentum.</span>
          </span>
        </button>
      )}
    </div>

    <div class="bmv-cta" data-reveal>
      <a href="#book" class="button">
        Skip the video, book the call
        <span class="arrow" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .brand-message {
    padding: 5rem 0 6rem;
    position: relative;
    overflow: hidden;
  }
  .head { max-width: 60ch; margin-bottom: 2.5rem; }
  .head h2 { margin: 1rem 0 1.25rem; text-wrap: balance; }
  .head .lede {
    color: var(--ink);
    opacity: 0.78;
    font-size: 1.05rem;
    max-width: 60ch;
  }

  .bmv-stage {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    border-radius: 24px;
    overflow: hidden;
    box-shadow:
      0 30px 80px -30px rgba(0, 0, 0, 0.75),
      0 0 0 1px rgba(98, 166, 219, 0.25);
  }

  /* ── Final state: Vimeo iframe or self-hosted video ── */
  .bmv-player {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    background: #000;
  }
  iframe.bmv-player,
  video.bmv-player {
    width: 100%;
    height: 100%;
  }

  /* ── Placeholder state ── */
  .bmv-placeholder {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
    padding: 0;
    cursor: pointer;
    color: inherit;
    overflow: hidden;
    background: #0d111c;
    isolation: isolate;
  }
  .bmv-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(80% 60% at 30% 30%, rgba(98, 166, 219, 0.28), transparent 60%),
      radial-gradient(80% 60% at 75% 80%, rgba(38, 79, 160, 0.4), transparent 60%),
      radial-gradient(40% 50% at 50% 50%, rgba(227, 112, 59, 0.12), transparent 70%),
      linear-gradient(140deg, #0a0d18, #0f1424, #0a0d18);
  }
  .bmv-bg::after {
    content: "";
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 38px 38px;
    mask-image: radial-gradient(70% 70% at 50% 50%, #000 30%, transparent 100%);
  }

  .bmv-content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 2rem;
    text-align: center;
  }
  .bmv-pill {
    padding: 0.4rem 0.9rem;
    border: 1px solid rgba(98, 166, 219, 0.5);
    border-radius: 999px;
    color: var(--bp-light);
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .bmv-play {
    color: rgba(255, 255, 255, 0.92);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: rgba(10, 10, 15, 0.55);
    border: 1px solid rgba(98, 166, 219, 0.4);
    backdrop-filter: blur(6px);
    transition: transform 0.3s cubic-bezier(.2,.7,.3,1), color 0.3s, background 0.3s, border-color 0.3s;
    filter: drop-shadow(0 8px 28px rgba(0, 0, 0, 0.5));
  }
  .bmv-placeholder:hover .bmv-play,
  .bmv-placeholder:focus-visible .bmv-play {
    transform: scale(1.08);
    color: var(--bp-orange);
    background: rgba(227, 112, 59, 0.18);
    border-color: var(--bp-orange);
  }
  .bmv-caption {
    color: #fff;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 800;
  }
  .bmv-subcaption {
    color: var(--bp-light);
    font-style: italic;
    font-size: 0.95rem;
    max-width: 44ch;
    opacity: 0.85;
  }

  .bmv-cta {
    text-align: center;
    margin-top: 2.5rem;
  }
  .bmv-cta .button { background: transparent; border: 1px solid rgba(255,255,255,0.18); }
  .bmv-cta .button:hover { background: rgba(255,255,255,0.06); }

  @media (max-width: 700px) {
    .bmv-play { width: 80px; height: 80px; }
    .bmv-play svg { width: 48px; height: 48px; }
  }
</style>
