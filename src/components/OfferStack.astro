---
const tiers = [
  {
    tag: 'Tier 01 · Entry',
    name: 'Growth Blueprint Session™',
    price: '$1,000',
    cadence: 'one-time',
    pif: null,
    positioning: "Let's get your content actually working first.",
    buying: 'Immediate traction. Prove the system works without a big commitment.',
    deliverables: [
      'Content Audit + Growth Breakdown',
      'Performance Review (what\'s working vs not)',
      'EDM-specific content direction + formats',
      '5–15 short-form clips from existing footage',
      'Bio, profile + positioning optimization',
      '2–4 week posting plan',
    ],
    accent: '--bp-blue',
    featured: false,
  },
  {
    tag: 'Tier 02 · Consistency',
    name: 'Content Engine Starter™',
    price: '$1,000',
    cadence: '/month · 3-mo',
    pif: { amount: '$2,500', save: '$500' },
    positioning: 'A plug-and-play content system that drives consistent visibility.',
    buying: 'Consistency without thinking. Your output finally matches your level.',
    deliverables: [
      '8–12 short-form videos / month',
      'Editing + formatting for TikTok / Reels',
      'Monthly EDM-focused content direction',
      'Posting structure + cadence guidance',
      '1 strategy call / month',
      'Light show / footage repurposing',
    ],
    accent: '--bp-light',
    featured: false,
  },
  {
    tag: 'Tier 03 · Most Picked',
    name: 'Fan Growth Engine™',
    price: '$3,000',
    cadence: '/month · 6-mo',
    pif: { amount: '$15,000', save: '$3,000' },
    positioning: 'We turn your content into a system that actually grows your fanbase.',
    buying: 'Growth + direction + consistency, fully managed.',
    deliverables: [
      '15–25 short-form videos / month',
      'Show footage repurposing (1 → many)',
      'Caption + hook writing + optimization',
      'EDM trend alignment + show-based mapping',
      'Release-based content planning',
      'Proven format deployment, no guessing',
      'Performance tracking + monthly growth report',
      'Monthly growth strategy call',
    ],
    accent: '--bp-orange',
    featured: true,
  },
  {
    tag: 'Tier 04 · Infrastructure',
    name: 'Artist Growth Infrastructure™',
    price: '$10,000',
    cadence: '/month · 6-mo',
    pif: { amount: '$50,000', save: '$10,000' },
    positioning: 'Not just marketing — your entire growth infrastructure, managed.',
    buying: 'A complete growth machine: content → conversion → revenue.',
    deliverables: [
      'Everything in Tier 03',
      '20–40+ short-form videos / month',
      'Show-day capture (or via creator network)',
      'Multi-platform distribution (Reels, TikTok, Shorts)',
      'Link-in-bio funnel + email + SMS capture',
      'Release + show + merch campaigns',
      'Paid amplification + retargeting',
      'Vetted photographer / videographer network',
    ],
    accent: '--bp-deep',
    featured: false,
  },
];
---
<section class="offers" id="offers">
  <div class="container">
    <header class="offers-head">
      <p class="label" data-reveal="left">The Offer Stack</p>
      <h2 data-reveal>Four ways to plug in.</h2>
      <p class="lede" data-reveal>
        Start with a single session or roll into full-funnel infrastructure.
        Every tier ships a clear system you keep — not a campaign that ends.
      </p>
      <a class="offers-guarantee" href="#guarantee" data-reveal>
        <span class="og-dot" aria-hidden="true"></span>
        <span class="og-text"><strong>30-day guarantee.</strong> If we don't deliver a clear growth system in the first 30 days, we work for free until we do.</span>
        <span class="og-arrow" aria-hidden="true">→</span>
      </a>
    </header>

    <div class="tiers" data-reveal-group>
      {tiers.map(t => {
        const [tierNum, ...rest] = t.tag.split(' · ');
        const tierKind = rest.join(' · ');
        return (
        <article class={`tier ${t.featured ? 'featured' : ''}`} style={`--accent: var(${t.accent});`} data-reveal="flip" data-scroll-focus>
          {t.featured && <span class="ribbon">Most picked</span>}
          <p class="tag">
            <span class="tag-num">{tierNum} ·</span>
            <span class="tag-kind">{tierKind}</span>
          </p>
          <h3>{t.name}</h3>
          <p class="positioning">"{t.positioning}"</p>

          <div class="price">
            <span class="price-num" data-counter={t.price}>{t.price}</span>
            <span class="price-cadence">{t.cadence}</span>
            {t.pif && (
              <span class="price-pif">
                or <strong>{t.pif.amount}</strong> paid-in-full · <em>saves {t.pif.save}</em>
              </span>
            )}
          </div>

          <p class="buying">{t.buying}</p>

          <ul class="deliverables">
            {t.deliverables.map(d => (<li>{d}</li>))}
          </ul>

          <a href="#book" class={`tier-cta ${t.featured ? 'button accent' : 'button ghost'}`}>
            {t.featured ? 'Book a strategy call' : 'Get details'}
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </article>
      );
      })}
    </div>
  </div>
</section>

<style>
  .offers { padding: 5rem 0; }
  .offers-head { max-width: 60ch; margin-bottom: 3rem; }
  .offers-head h2 { margin: 1rem 0; }
  .lede { color: var(--ink); opacity: 0.72; font-size: 1.05rem; }

  .offers-guarantee {
    margin-top: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 1.1rem 0.7rem 0.95rem;
    background: rgba(227, 112, 59, 0.08);
    border: 1px solid rgba(227, 112, 59, 0.4);
    border-radius: 999px;
    color: var(--ink);
    font-size: 0.92rem;
    line-height: 1.4;
    max-width: 60ch;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .offers-guarantee:hover {
    background: rgba(227, 112, 59, 0.14);
    border-color: rgba(227, 112, 59, 0.6);
    transform: translateY(-1px);
  }
  .og-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--bp-orange);
    box-shadow: 0 0 12px rgba(227, 112, 59, 0.7);
    flex-shrink: 0;
  }
  .og-text { flex: 1; }
  .og-text strong { color: var(--bp-orange); font-weight: 700; }
  .og-arrow {
    color: var(--bp-orange);
    font-weight: 800;
    transition: transform 0.2s cubic-bezier(.2,.7,.3,1);
    flex-shrink: 0;
  }
  .offers-guarantee:hover .og-arrow { transform: translateX(3px); }

  .tiers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    align-items: stretch;
    /* Shared 3D scene so all four flip-in cards tilt toward one camera */
    perspective: 1800px;
    perspective-origin: center 40%;
  }
  .tier {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;

    /* ── Initial flip state (before .is-in lands) ── */
    opacity: 0;
    transform: translateY(60px) translateZ(-180px) rotateX(6deg) rotateY(-55deg);
    transform-origin: center center;

    /* Combined transition: slow reveal for opacity+transform, snappy hover
       for border + shadow. All four properties named explicitly so the
       shorthand can't reset anything. */
    transition:
      opacity   1.6s cubic-bezier(0.22, 1, 0.36, 1) var(--tier-flip-delay, 0s),
      transform 1.6s cubic-bezier(0.22, 1, 0.36, 1) var(--tier-flip-delay, 0s),
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }
  /* Sequential stagger — tighter so the whole scene runs ~2.5s */
  .tier:nth-child(1) { --tier-flip-delay: 0s; }
  .tier:nth-child(2) { --tier-flip-delay: 0.3s; }
  .tier:nth-child(3) { --tier-flip-delay: 0.6s; }
  .tier:nth-child(4) { --tier-flip-delay: 0.9s; }

  /* Settled state once the IntersectionObserver adds .is-in */
  .tier.is-in {
    opacity: 1;
    transform: translateY(0) translateZ(0) rotateX(0) rotateY(0);
  }

  .tier:hover {
    border-color: rgba(255, 255, 255, 0.25);
    box-shadow: 0 18px 44px -22px rgba(0, 0, 0, 0.65);
  }

  @media (prefers-reduced-motion: reduce) {
    .tier {
      opacity: 1;
      transform: none;
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
    }
  }
  .tier.featured {
    background:
      radial-gradient(80% 70% at 50% 0%, rgba(227, 112, 59, 0.18), transparent 60%),
      var(--card-elev);
    border-color: rgba(227, 112, 59, 0.45);
    box-shadow: 0 24px 60px -30px rgba(227, 112, 59, 0.5);
  }
  .ribbon {
    position: absolute;
    top: -0.7rem;
    left: 1.5rem;
    background: var(--bp-orange);
    color: #fff;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 800;
    font-family: var(--font-display);
  }
  .tag {
    font-family: var(--font-display);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-transform: uppercase;
    font-weight: 700;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    line-height: 1.2;
  }
  .tag .tag-num { opacity: 0.85; }
  .tag .tag-kind { color: var(--accent); }
  .tier h3 {
    color: var(--ink);
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.55vw, 1.2rem);
    letter-spacing: -0.01em;
    text-transform: uppercase;
    line-height: 1.08;
    min-height: calc(1.08em * 2); /* lock to 2-line height */
    text-wrap: balance;
  }
  .positioning {
    color: var(--bp-light);
    opacity: 0.85;
    font-size: 0.88rem;
    font-style: italic;
    line-height: 1.4;
    min-height: calc(1.4em * 3); /* lock to 3-line height */
  }
  .price {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
  }
  .price-num {
    font-family: var(--font-display);
    font-size: 1.85rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.05;
  }
  .price-cadence {
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .price-pif {
    margin-top: 0.4rem;
    font-size: 0.78rem;
    color: var(--bp-light);
    line-height: 1.35;
  }
  .price-pif strong { color: var(--ink); font-weight: 700; }
  .price-pif em { font-style: normal; color: var(--bp-orange); font-weight: 700; }
  .buying {
    color: var(--ink);
    opacity: 0.78;
    font-size: 0.9rem;
    border-top: 1px solid var(--line);
    padding-top: 0.8rem;
  }
  .deliverables { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
  .deliverables li {
    color: var(--ink);
    opacity: 0.82;
    font-size: 0.85rem;
    padding-left: 1.1rem;
    position: relative;
    line-height: 1.4;
  }
  .deliverables li::before {
    content: "";
    position: absolute;
    left: 0; top: 0.5rem;
    width: 6px; height: 6px;
    border-radius: 2px;
    background: var(--accent);
    transform: rotate(45deg);
  }
  .tier-cta { margin-top: 0.5rem; align-self: flex-start; }

  @media (max-width: 1080px) { .tiers { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px)  { .tiers { grid-template-columns: 1fr; } }

  /* Mobile: the dramatic 3D flip looks broken on narrow viewports
     (clipping, perf-heavy, and stacked vertically the rotation reads weird).
     Replace it with a simple slide-up + fade. */
  @media (max-width: 760px) {
    .tier {
      transform: translateY(40px);
      transition:
        opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1) var(--tier-flip-delay, 0s),
        transform 0.9s cubic-bezier(0.22, 1, 0.36, 1) var(--tier-flip-delay, 0s),
        border-color 0.25s ease,
        box-shadow 0.25s ease;
    }
    .tier:nth-child(1) { --tier-flip-delay: 0s; }
    .tier:nth-child(2) { --tier-flip-delay: 0.12s; }
    .tier:nth-child(3) { --tier-flip-delay: 0.24s; }
    .tier:nth-child(4) { --tier-flip-delay: 0.36s; }
    .tier.is-in { transform: translateY(0); }
  }
</style>
