---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="brand-mark">BLUEPRINT</span>
      <span class="brand-sub">MKTG</span>
    </div>

    <ul class="links">
      <li><a href="/services">Services</a></li>
      <li><a href="/work">Our Work</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>

    <p class="copy">© {year} Blueprint Marketing. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-card);
    color: #d8d8d8;
    margin-top: 3rem;
    padding: 3rem 0 2.5rem;
    border-radius: 28px 28px 0 0;
  }
  .footer-inner {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .footer-brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 900;
    color: #fff;
    font-size: 1.25rem;
  }
  .footer-brand .brand-sub {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--color-ink);
    background: var(--color-accent);
    padding: 0.15rem 0.4rem;
    border-radius: 6px;
    font-weight: 800;
  }
  .links {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .links a { color: #d8d8d8; font-size: 0.95rem; }
  .links a:hover { color: #fff; }
  .copy { margin: 0; font-size: 0.85rem; color: #8a8a8a; text-align: right; }

  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr; text-align: center; }
    .copy { text-align: center; }
  }
</style>
