---
const diffs = [
  {
    title: 'Built for bass music.',
    body: 'We live in this scene. We know the difference between a Subtronics drop and a Rezz transition — and how each one plays on TikTok.',
  },
  {
    title: 'Systems, not campaigns.',
    body: 'Everyone else sells campaigns. We build infrastructure that compounds — so growth runs whether you\'re touring or in the studio.',
  },
  {
    title: 'Full-funnel, not just content.',
    body: 'Content → distribution → fan capture → monetization. We own the full loop. Most agencies stop at "post more."',
  },
  {
    title: 'National creator network.',
    body: 'Vetted photographers and videographers in LA, Denver, Miami, Austin, NY — wherever you tour. Content scales with your schedule.',
  },
  {
    title: 'Built on integrity.',
    body: 'Christian-values foundation. Honesty, transparency, and zero shady deliverable shuffling. Rare in this industry — we like it that way.',
  },
];
---
<section class="why" id="why">
  <div class="container">
    <header class="why-head">
      <p class="label" data-reveal="left">Why Blueprint</p>
      <h2 data-reveal>What every<br/>competitor doesn't do.</h2>
      <p class="lede" data-reveal>
        For artists who want more than just cool visuals. MPT, AMW, View Maniac — all
        campaign-based, exposure-focused, and not built for mid-level EDM artists. The
        white space they leave open is exactly where we live:
        <span class="glow-deep">the growth system behind the artist.</span>
      </p>
    </header>

    <div class="diff-grid" data-reveal-group>
      {diffs.map((d, i) => (
        <article class="diff card-trace card-inner-glow" data-reveal data-scroll-focus>
          <span class="diff-num" data-icon-pop>{String(i + 1).padStart(2, '0')}</span>
          <h3>{d.title}</h3>
          <p>{d.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why { padding: 5rem 0; position: relative; overflow: hidden; isolation: isolate; }
  .why-head { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: end; margin-bottom: 3rem; }
  .why-head .label { grid-column: 1 / -1; }
  .why-head h2 { margin-top: 0.75rem; }
  .lede { color: var(--ink); opacity: 0.72; font-size: 1.05rem; }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  .diff {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .diff:hover { border-color: rgba(98, 166, 219, 0.4); transform: translateY(-2px); }

  /* Each differentiator gets its own trace + inner-glow color so the row
     reads as five distinct ideas, not five interchangeable cards. */
  .diff:nth-child(1) { --trace-color: #62a6db; --inner-glow-color: rgba(98, 166, 219, 0.28); }  /* Bass music    — blue */
  .diff:nth-child(2) { --trace-color: #e3703b; --inner-glow-color: rgba(227, 112, 59, 0.25); }  /* Systems       — orange */
  .diff:nth-child(3) { --trace-color: #a070ff; --inner-glow-color: rgba(160, 112, 255, 0.22); } /* Full-funnel   — purple */
  .diff:nth-child(4) { --trace-color: #4dd9d9; --inner-glow-color: rgba(77, 217, 217, 0.22); }  /* Creator net   — cyan */
  .diff:nth-child(5) { --trace-color: #f5f7ff; --inner-glow-color: rgba(245, 247, 255, 0.18); } /* Integrity     — white */
  /* Match the diff-num accent to the card's own color too. */
  .diff:nth-child(2) .diff-num { color: var(--bp-orange); }
  .diff:nth-child(3) .diff-num { color: #a070ff; }
  .diff:nth-child(4) .diff-num { color: #4dd9d9; }
  .diff:nth-child(5) .diff-num { color: #f5f7ff; }
  .diff::before {
    content: "";
    position: absolute;
    inset: -1px -1px auto -1px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--bp-blue), transparent);
    opacity: 0.55;
  }
  .diff-num {
    font-family: var(--font-display);
    color: var(--bp-blue);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
  }
  .diff h3 { color: var(--ink); font-family: var(--font-display); text-transform: uppercase; font-size: 1.05rem; letter-spacing: 0.01em; }
  .diff p { color: var(--muted); font-size: 0.92rem; }

  @media (max-width: 980px) {
    .why-head { grid-template-columns: 1fr; }
    .diff-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) { .diff-grid { grid-template-columns: 1fr; } }
</style>
